<style>
.rad-cer-gallery { padding: 2rem 0; background: #f3f4f6; }
.rad-cer-gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
.rad-cer-gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 9/16; background: linear-gradient(135deg, #1e3a8a, #0f172a); cursor: pointer; position: relative; }
.rad-cer-gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
.rad-cer-gallery-item:hover img { transform: scale(1.05); }
.rad-cer-gallery-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; }
@media (max-width: 768px) { .rad-cer-gallery-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .rad-cer-gallery-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<section class="rad-cer-gallery">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title | default: "Our Work" }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle | default: "Real results from real cars we've detailed in Karachi" }}</p>
    <div class="rad-cer-gallery-grid">
      {%- for i in (1..4) -%}
        {%- assign img_key = 'gallery_img_' | append: i -%}
        <div class="rad-cer-gallery-item">
          {%- if section.settings[img_key] != blank -%}
            <img src="{{ section.settings[img_key] | image_url: width: 400 }}" alt="Ceramic Coating Work {{ i }}" loading="lazy">
          {%- else -%}
            <div class="rad-cer-gallery-fallback">✨</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ceramic Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Our Work"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real results from real cars we've detailed in Karachi"
    },
    {
      "type": "image_picker",
      "id": "gallery_img_1",
      "label": "Gallery Image 1"
    },
    {
      "type": "image_picker",
      "id": "gallery_img_2",
      "label": "Gallery Image 2"
    },
    {
      "type": "image_picker",
      "id": "gallery_img_3",
      "label": "Gallery Image 3"
    },
    {
      "type": "image_picker",
      "id": "gallery_img_4",
      "label": "Gallery Image 4"
    }
  ],
  "presets": [
    {
      "name": "Ceramic Gallery"
    }
  ]
}
{% endschema %}