<style>
.rad-uv-book { font-family: 'Nunito Sans', sans-serif; background: #f5f3ff; min-height: 60vh; padding: 3rem 0; }
.rad-uv-book-inner { max-width: 700px; margin: 0 auto; padding: 0 1.5rem; }
.rad-uv-book-hdr { text-align: center; margin-bottom: 2rem; }
.rad-uv-book-hdr h1 { font-size: 1.9rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; }
.rad-uv-book-hdr p { color: #6b7280; font-size: 0.95rem; }
.rad-uv-book-card { background: #fff; border-radius: 14px; padding: 2rem; box-shadow: 0 2px 16px rgba(0,0,0,0.07); }
.rad-uv-field { margin-bottom: 1.25rem; }
.rad-uv-field label { display: block; font-size: 0.85rem; font-weight: 700; color: #374151; margin-bottom: 0.4rem; }
.rad-uv-field input, .rad-uv-field select {
  width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 8px;
  font-family: 'Nunito Sans', sans-serif; font-size: 0.9rem; color: #1f2937;
  background: #fff; box-sizing: border-box; transition: border 0.2s;
}
.rad-uv-field input:focus, .rad-uv-field select:focus { outline: none; border-color: #7c3aed; }
.rad-uv-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.rad-uv-req { color: #ef4444; }
.rad-uv-section-lbl { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin: 1.75rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e5e7eb; }
.rad-uv-price-box { background: #f5f3ff; border: 2px solid #7c3aed; border-radius: 10px; padding: 1rem 1.25rem; margin: 1.25rem 0; display: none; }
.rad-uv-price-box.show { display: flex; justify-content: space-between; align-items: center; }
.rad-uv-price-lbl { font-size: 0.9rem; font-weight: 600; color: #4c1d95; }
.rad-uv-price-val { font-size: 1.4rem; font-weight: 800; color: #7c3aed; }
.rad-uv-submit-btn { width: 100%; padding: 1rem; background: #7c3aed; color: #fff; border: none; border-radius: 10px; font-family: 'Nunito Sans', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.2s; margin-top: 1.5rem; }
.rad-uv-submit-btn:hover { background: #6d28d9; }
.rad-uv-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
.rad-uv-wa { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 1rem; padding: 0.85rem; background: #10b981; color: #fff; border-radius: 10px; font-weight: 700; font-size: 0.95rem; text-decoration: none; }
.rad-uv-notice { background: #f5f3ff; border: 1px solid #ddd6fe; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.82rem; color: #5b21b6; margin-bottom: 1.25rem; }
.rad-uv-success { display: none; text-align: center; padding: 2.5rem 1.5rem; }
.rad-uv-success-icon { font-size: 3.5rem; margin-bottom: 1rem; }
.rad-uv-success h2 { font-size: 1.5rem; font-weight: 800; color: #1f2937; margin-bottom: 0.5rem; }
.rad-uv-success p { color: #6b7280; margin-bottom: 1.5rem; }
@media (max-width: 640px) {
  .rad-uv-book { padding: 2rem 0; }
  .rad-uv-book-hdr h1 { font-size: 1.5rem; }
  .rad-uv-field-row { grid-template-columns: 1fr; }
}
</style>

<div class="rad-uv-book">
  <div class="rad-uv-book-inner">
    <div class="rad-uv-book-hdr">
      <h1>{{ section.settings.title | default: "Book UV Paint Inspection" }}</h1>
      <p>{{ section.settings.subtitle | default: "Professional UV light car paint inspection in Karachi — detect hidden repaint, rust & damage" }}</p>
    </div>
    <div class="rad-uv-book-card">

      <div id="uv-form-wrap">
        <div class="rad-uv-notice">🔦 UV inspection takes 30–60 minutes. We'll confirm your slot via WhatsApp within 1 hour.</div>

        <div class="rad-uv-section-lbl">Personal Details</div>
        <div class="rad-uv-field-row">
          <div class="rad-uv-field">
            <label>First Name <span class="rad-uv-req">*</span></label>
            <input type="text" id="uv-fn" placeholder="Ahmed" required>
          </div>
          <div class="rad-uv-field">
            <label>Last Name</label>
            <input type="text" id="uv-ln" placeholder="Khan">
          </div>
        </div>
        <div class="rad-uv-field-row">
          <div class="rad-uv-field">
            <label>WhatsApp Number <span class="rad-uv-req">*</span></label>
            <input type="tel" id="uv-ph" placeholder="03XX-XXXXXXX" required>
          </div>
          <div class="rad-uv-field">
            <label>Email Address</label>
            <input type="email" id="uv-em" placeholder="email@example.com">
          </div>
        </div>

        <div class="rad-uv-section-lbl">Vehicle Details</div>
        <div class="rad-uv-field-row">
          <div class="rad-uv-field">
            <label>Car Make <span class="rad-uv-req">*</span></label>
            <input type="text" id="uv-mk" placeholder="Toyota" required>
          </div>
          <div class="rad-uv-field">
            <label>Car Model <span class="rad-uv-req">*</span></label>
            <input type="text" id="uv-mo" placeholder="Corolla" required>
          </div>
        </div>
        <div class="rad-uv-field-row">
          <div class="rad-uv-field">
            <label>Year</label>
            <input type="text" id="uv-yr" placeholder="2021">
          </div>
          <div class="rad-uv-field">
            <label>Vehicle Type <span class="rad-uv-req">*</span></label>
            <select id="uv-vt" onchange="uvUpdatePrice()" required>
              <option value="">Select vehicle type</option>
              <option value="hatchback" data-price="{{ section.settings.price_hatch | default: 5500 }}">Hatchback — PKR {{ section.settings.price_hatch | default: "5,500" }}</option>
              <option value="sedan" data-price="{{ section.settings.price_sedan | default: 6500 }}">Sedan — PKR {{ section.settings.price_sedan | default: "6,500" }}</option>
              <option value="suv" data-price="{{ section.settings.price_suv | default: 7500 }}">SUV — PKR {{ section.settings.price_suv | default: "7,500" }}</option>
              <option value="xl-suv" data-price="{{ section.settings.price_xlsuv | default: 10000 }}">XL SUV — PKR {{ section.settings.price_xlsuv | default: "10,000" }}</option>
            </select>
          </div>
        </div>

        <div class="rad-uv-price-box" id="uv-price-box">
          <span class="rad-uv-price-lbl">🔦 UV Inspection Fee</span>
          <span class="rad-uv-price-val" id="uv-price-val">PKR —</span>
        </div>

        <div class="rad-uv-section-lbl">Preferred Appointment</div>
        <div class="rad-uv-field-row">
          <div class="rad-uv-field">
            <label>Preferred Date <span class="rad-uv-req">*</span></label>
            <input type="date" id="uv-date" required>
          </div>
          <div class="rad-uv-field">
            <label>Preferred Time <span class="rad-uv-req">*</span></label>
            <select id="uv-time" required>
              <option value="">Select a time slot</option>
              <option>10:00 AM</option>
              <option>12:00 PM</option>
              <option>2:00 PM</option>
              <option>4:00 PM</option>
            </select>
          </div>
        </div>

        <button class="rad-uv-submit-btn" id="uv-submit-btn" onclick="uvSubmit()">Confirm Inspection Booking</button>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20book%20a%20UV%20paint%20inspection" target="_blank" class="rad-uv-wa">💬 Or WhatsApp Us Directly</a>
      </div>

      <div class="rad-uv-success" id="uv-success">
        <div class="rad-uv-success-icon">✅</div>
        <h2>Booking Confirmed!</h2>
        <p>Thank you! We've received your UV paint inspection request. Our team will confirm via WhatsApp within 1 hour.</p>
        <a href="https://wa.me/923037231111" target="_blank" class="rad-uv-wa">💬 WhatsApp Us for Quick Confirmation</a>
      </div>

    </div>
  </div>
</div>

<script>
function uvUpdatePrice() {
  var sel = document.getElementById('uv-vt');
  var box = document.getElementById('uv-price-box');
  var val = document.getElementById('uv-price-val');
  var opt = sel.options[sel.selectedIndex];
  if (opt && opt.dataset.price) {
    val.textContent = 'PKR ' + parseInt(opt.dataset.price).toLocaleString();
    box.classList.add('show');
  } else {
    box.classList.remove('show');
  }
}

function uvSubmit() {
  var fn   = document.getElementById('uv-fn').value.trim();
  var ph   = document.getElementById('uv-ph').value.trim();
  var mk   = document.getElementById('uv-mk').value.trim();
  var mo   = document.getElementById('uv-mo').value.trim();
  var vt   = document.getElementById('uv-vt').value;
  var date = document.getElementById('uv-date').value;
  var time = document.getElementById('uv-time').value;

  if (!fn || !ph || !mk || !mo || !vt || !date || !time) {
    alert('Please fill in all required fields marked with *');
    return;
  }

  var btn = document.getElementById('uv-submit-btn');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  var ref = 'RAD-UV-' + Date.now().toString(36).toUpperCase().slice(-6);
  var cleanPhone = ph.replace(/[^0-9]/g,'');
  var vtLabel = {hatchback:'Hatchback',sedan:'Sedan',suv:'SUV','xl-suv':'XL SUV'}[vt] || vt;
  var priceMap = {hatchback:'5,500',sedan:'6,500',suv:'7,500','xl-suv':'10,000'};

  var body =
    'NEW UV PAINT INSPECTION BOOKING — ' + ref + '\n' +
    'Submitted: ' + new Date().toLocaleString('en-PK',{timeZone:'Asia/Karachi'}) + '\n\n' +
    'Customer: ' + fn + ' ' + (document.getElementById('uv-ln').value||'') + '\n' +
    'WhatsApp: ' + ph + '\n' +
    'Email: ' + (document.getElementById('uv-em').value||'—') + '\n\n' +
    'Vehicle: ' + mk + ' ' + mo + ' ' + (document.getElementById('uv-yr').value||'') + '\n' +
    'Vehicle Type: ' + vtLabel + '\n' +
    'Inspection Fee: PKR ' + (priceMap[vt]||'—') + '\n\n' +
    'Date: ' + date + '\n' +
    'Time: ' + time + '\n' +
    'WhatsApp: https://wa.me/' + cleanPhone + '\n\n' +
    '[booking_type:uv-inspection] [booking_ref:' + ref + ']';

  fetch('https://formspree.io/f/xgoqpjvk', {
    method: 'POST',
    headers: {'Content-Type':'application/json','Accept':'application/json'},
    body: JSON.stringify({
      _subject: 'UV Inspection Booking: ' + ref + ' — ' + fn,
      _replyto: document.getElementById('uv-em').value || '',
      body: body
    })
  }).then(function(){
    document.getElementById('uv-form-wrap').style.display = 'none';
    document.getElementById('uv-success').style.display = 'block';
  }).catch(function(){
    document.getElementById('uv-form-wrap').style.display = 'none';
    document.getElementById('uv-success').style.display = 'block';
  });
}

document.getElementById('uv-date').min = new Date().toISOString().split('T')[0];
</script>

{% schema %}
{
  "name": "UV Inspection Booking",
  "settings": [
    {"type":"text","id":"title","label":"Page Title","default":"Book UV Paint Inspection"},
    {"type":"text","id":"subtitle","label":"Subtitle","default":"Professional UV light car paint inspection in Karachi — detect hidden repaint, rust & damage"},
    {"type":"header","content":"Pricing"},
    {"type":"text","id":"price_hatch","label":"Hatchback Price","default":"5,500"},
    {"type":"text","id":"price_sedan","label":"Sedan Price","default":"6,500"},
    {"type":"text","id":"price_suv","label":"SUV Price","default":"7,500"},
    {"type":"text","id":"price_xlsuv","label":"XL SUV Price","default":"10,000"}
  ],
  "presets":[{"name":"UV Inspection Booking"}]
}
{% endschema %}