<style>
.rad-hero {
  position: relative;
  color: #fff;
  padding: 6rem 0;
  overflow: hidden;
  min-height: 600px;
  display: flex;
  align-items: center;
}

/* Background Image */
.rad-hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.rad-hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Dark overlay on top of image */
.rad-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.80) 0%,
    rgba(0,0,0,0.55) 50%,
    rgba(0,0,0,0.25) 100%
  );
  z-index: 1;
}

/* Fallback if no image */
.rad-hero-bg-fallback {
  position: absolute;
  inset: 0;
  background: #000;
  z-index: 0;
}

.rad-hero-inner {
  position: relative;
  z-index: 2;
  width: 100%;
}

.rad-hero-content {
  max-width: 600px;
}

.rad-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(30,58,138,0.5);
  border: 1px solid rgba(96,165,250,0.4);
  padding: 0.35rem 1rem;
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #93c5fd;
  margin-bottom: 1.25rem;
  letter-spacing: 0.02em;
}

.rad-hero-headline {
  font-size: 3.75rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -1px;
  font-family: 'Nunito Sans', sans-serif;
  text-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.rad-hero-headline span { color: #60a5fa; }

.rad-hero-sub {
  font-size: 1.15rem;
  color: #e5e7eb;
  line-height: 1.7;
  margin-bottom: 2rem;
  text-shadow: 0 1px 4px rgba(0,0,0,0.4);
}

.rad-hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.rad-btn-blue {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 1.75rem;
  background: #1e3a8a;
  color: #fff;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: all 0.2s;
  border: 2px solid #1e3a8a;
}
.rad-btn-blue:hover { background: #1e40af; border-color: #1e40af; transform: translateY(-1px); }

.rad-btn-white {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 1.75rem;
  background: rgba(255,255,255,0.15);
  color: #fff;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  border: 2px solid rgba(255,255,255,0.6);
  transition: all 0.2s;
  backdrop-filter: blur(4px);
}
.rad-btn-white:hover { background: rgba(255,255,255,0.25); }

.rad-hero-stats {
  display: flex;
  gap: 2rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.15);
}
.rad-stat-num {
  font-size: 1.75rem;
  font-weight: 800;
  color: #60a5fa;
  display: block;
}
.rad-stat-lbl {
  font-size: 0.75rem;
  color: #9ca3af;
  display: block;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

@media (max-width: 900px) {
  .rad-hero { padding: 4rem 0; min-height: 500px; }
  .rad-hero-headline { font-size: 2.5rem; }
  .rad-hero-overlay {
    background: linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.65) 100%);
  }
}

@media (max-width: 640px) {
  .rad-hero { padding: 3rem 0; min-height: 450px; }
  .rad-hero-headline { font-size: 1.85rem; letter-spacing: -0.5px; }
  .rad-hero-sub { font-size: 1rem; }
  .rad-hero-btns { flex-direction: column; }
  .rad-hero-btns a { text-align: center; justify-content: center; }
  .rad-hero-stats { gap: 1.25rem; flex-wrap: wrap; }
}
</style>

<section class="rad-hero">

  {%- if section.settings.bg_image != blank -%}
    <div class="rad-hero-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1800 }}"
           alt="Revive Auto Detailing"
           loading="eager"
           width="1800">
    </div>
    <div class="rad-hero-overlay"></div>
  {%- else -%}
    <div class="rad-hero-bg-fallback"></div>
    <div class="rad-hero-overlay" style="background:rgba(0,0,0,0.6);"></div>
  {%- endif -%}

  <div class="container rad-hero-inner">
    <div class="rad-hero-content">
      <div class="rad-hero-badge">{{ section.settings.badge | default: "⭐ Karachi's Premium Auto Detailing" }}</div>
      <h1 class="rad-hero-headline">
        {{ section.settings.title | default: "Transform Your Car's Look with" }}
        <span>{{ section.settings.title_accent | default: "Revive Auto Detailing" }}</span>
      </h1>
      <p class="rad-hero-sub">
        {{ section.settings.subtitle | default: 'Professional car detailing, ceramic coating, and paint protection services to keep your vehicle looking pristine.' }}
      </p>
      <div class="rad-hero-btns">
        <a href="{{ section.settings.btn1_url | default: "/pages/paint-protection-film-ppf" }}" class="rad-btn-blue">{{ section.settings.btn1_text | default: "Get Free Quote" }}</a>
        <a href="tel:+923037231111" class="rad-btn-white">&#128222; Call Now</a>
      </div>
      <div class="rad-hero-stats">
        <div><span class="rad-stat-num">500+</span><span class="rad-stat-lbl">Cars Detailed</span></div>
        <div><span class="rad-stat-num">4.9&#9733;</span><span class="rad-stat-lbl">Google Rating</span></div>
        <div><span class="rad-stat-num">10yr</span><span class="rad-stat-lbl">PPF Warranty</span></div>
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "⭐ Karachi's Premium Auto Detailing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "Transform Your Car's Look with"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Headline Accent (blue)",
      "default": "Revive Auto Detailing"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Professional car detailing, ceramic coating, and paint protection services to keep your vehicle looking pristine."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button Text",
      "default": "Get Free Quote"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}