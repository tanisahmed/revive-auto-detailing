<style>
.rad-hero {
  background: #000;
  color: #fff;
  padding: 5rem 0;
  position: relative;
  overflow: hidden;
}
.rad-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 60% 50%, rgba(30,58,138,0.3) 0%, transparent 70%);
  pointer-events: none;
}
.rad-hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.rad-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(30,58,138,0.4);
  border: 1px solid rgba(96,165,250,0.3);
  padding: 0.35rem 1rem;
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #93c5fd;
  margin-bottom: 1.25rem;
}
.rad-hero-headline {
  font-size: 3.75rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -1px;
  font-family: 'Nunito Sans', sans-serif;
}
.rad-hero-headline span { color: #60a5fa; }
.rad-hero-sub {
  font-size: 1.15rem;
  color: #d1d5db;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 480px;
}
.rad-hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.rad-btn-blue {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 1.75rem;
  background: #1e3a8a;
  color: #fff;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: background 0.2s;
  border: 2px solid #1e3a8a;
}
.rad-btn-blue:hover { background: #1e40af; }
.rad-btn-white {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 1.75rem;
  background: #fff;
  color: #1e3a8a;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  border: 2px solid #fff;
  transition: background 0.2s;
}
.rad-btn-white:hover { background: #f3f4f6; }
.rad-hero-stats {
  display: flex;
  gap: 2rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.rad-stat-num {
  font-size: 1.75rem;
  font-weight: 800;
  color: #60a5fa;
  display: block;
}
.rad-stat-lbl {
  font-size: 0.8rem;
  color: #9ca3af;
  display: block;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.rad-hero-visual {
  display: flex;
  align-items: center;
  justify-content: center;
}
.rad-hero-emoji {
  font-size: 10rem;
  line-height: 1;
  animation: radfloat 6s ease-in-out infinite;
}
@keyframes radfloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}
@media (max-width: 900px) {
  .rad-hero { padding: 3rem 0; }
  .rad-hero-grid { grid-template-columns: 1fr; }
  .rad-hero-visual { display: none; }
  .rad-hero-headline { font-size: 2.25rem; }
}
@media (max-width: 640px) {
  .rad-hero-headline { font-size: 1.85rem; }
  .rad-hero-btns { flex-direction: column; }
}
</style>

<section class="rad-hero">
  <div class="container">
    <div class="rad-hero-grid">
      <div>
        <div class="rad-hero-badge">&#11088; Karachi's Premium Auto Detailing</div>
        <h1 class="rad-hero-headline">
          Transform Your Car's Look with
          <span>Revive Auto Detailing</span>
        </h1>
        <p class="rad-hero-sub">Professional car detailing, ceramic coating, and paint protection services to keep your vehicle looking pristine.</p>
        <div class="rad-hero-btns">
          <a href="/pages/paint-protection-film" class="rad-btn-blue">Get Free Quote</a>
          <a href="tel:+923037231111" class="rad-btn-white">&#128222; Call Now</a>
        </div>
        <div class="rad-hero-stats">
          <div><span class="rad-stat-num">500+</span><span class="rad-stat-lbl">Cars Detailed</span></div>
          <div><span class="rad-stat-num">4.9&#9733;</span><span class="rad-stat-lbl">Google Rating</span></div>
          <div><span class="rad-stat-num">10yr</span><span class="rad-stat-lbl">PPF Warranty</span></div>
        </div>
      </div>
      <div class="rad-hero-visual">
        <div class="rad-hero-emoji">&#128663;</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [],
  "presets": [{"name": "Hero"}]
}
{% endschema %}
