<style>
.rad-hero {
  position: relative; color: #fff;
  padding: 6rem 0; overflow: hidden;
  min-height: 600px; display: flex; align-items: center;
}
.rad-hero-bg { position: absolute; inset: 0; z-index: 0; }
.rad-hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-hero-fallback { position: absolute; inset: 0; background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #0f172a 100%); }
.rad-hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to right, rgba(0,0,0,0.80) 0%, rgba(0,0,0,0.3) 100%); }
.rad-hero-inner { position: relative; z-index: 2; width: 100%; }
.rad-hero-content { max-width: 660px; }
.rad-hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(30,58,138,0.5); border: 1px solid rgba(96,165,250,0.4);
  padding: 0.4rem 1.1rem; border-radius: 100px;
  font-size: 0.8rem; font-weight: 700; color: #93c5fd;
  margin-bottom: 1.25rem; letter-spacing: 0.05em; text-transform: uppercase;
}
.rad-hero-title {
  font-size: 3.5rem; font-weight: 800; line-height: 1.1;
  margin-bottom: 1rem; letter-spacing: -1.5px;
  font-family: 'Nunito Sans', sans-serif;
}
.rad-hero-title span { color: #60a5fa; }
.rad-hero-sub {
  font-size: 1.15rem; color: #d1d5db; line-height: 1.7;
  margin-bottom: 2.5rem; max-width: 520px;
}
.rad-hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
.rad-btn-blue {
  display: inline-flex; align-items: center; padding: 0.9rem 2rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none;
  border: 2px solid #1e3a8a; transition: all 0.2s;
}
.rad-btn-blue:hover { background: #1e40af; transform: translateY(-2px); }
.rad-btn-wa {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.9rem 2rem; background: #10b981; color: #fff;
  border-radius: 8px; font-weight: 700; font-size: 1rem;
  text-decoration: none; border: 2px solid #10b981; transition: all 0.2s;
}
.rad-btn-wa:hover { background: #059669; transform: translateY(-2px); }
.rad-hero-stats {
  display: flex; gap: 2.5rem; flex-wrap: wrap;
  padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
}
.rad-stat-num { font-size: 1.85rem; font-weight: 800; color: #60a5fa; display: block; }
.rad-stat-lbl { font-size: 0.75rem; color: #9ca3af; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
@media (max-width: 768px) {
  .rad-hero { padding: 4rem 0; min-height: 480px; }
  .rad-hero-title { font-size: 2.25rem; }
  .rad-hero-btns { flex-direction: column; }
}
@media (max-width: 640px) {
  .rad-hero { padding: 2.5rem 0; min-height: auto; }
  .rad-hero-inner { padding: 0 1rem; }
  .rad-hero-title { font-size: 1.65rem; line-height: 1.25; }
  .rad-hero-sub { font-size: 0.9rem; margin-bottom: 1.5rem; }
  .rad-hero-btns { gap: 0.65rem; margin-bottom: 1.75rem; }
  .rad-hero-btns a { width: 100%; justify-content: center; text-align: center; padding: 0.8rem 1rem; font-size: 0.9rem; }
  .rad-hero-stats { gap: 1.25rem; padding-top: 1.25rem; justify-content: center; }
  .rad-stat-num { font-size: 1.4rem; }
}
</style>

<section class="rad-hero">
  {%- if section.settings.bg_image != blank -%}
    <div class="rad-hero-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="Revive Auto Detailing Karachi" loading="eager">
    </div>
  {%- else -%}
    <div class="rad-hero-fallback"></div>
  {%- endif -%}
  <div class="rad-hero-overlay"></div>

  <div class="container rad-hero-inner">
    <div class="rad-hero-content">
      <div class="rad-hero-badge">{{ section.settings.badge }}</div>
      <h1 class="rad-hero-title">
        {{ section.settings.title }}<br>
        <span>{{ section.settings.title_accent }}</span>
      </h1>
      <p class="rad-hero-sub">{{ section.settings.subtitle }}</p>
      <div class="rad-hero-btns">
        <a href="{{ section.settings.btn1_url }}" class="rad-btn-blue">{{ section.settings.btn1_text }}</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20know%20about%20your%20services" target="_blank" class="rad-btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
      <div class="rad-hero-stats">
        <div><span class="rad-stat-num">{{ section.settings.stat1_num }}</span><span class="rad-stat-lbl">{{ section.settings.stat1_lbl }}</span></div>
        <div><span class="rad-stat-num">{{ section.settings.stat2_num }}</span><span class="rad-stat-lbl">{{ section.settings.stat2_lbl }}</span></div>
        <div><span class="rad-stat-num">{{ section.settings.stat3_num }}</span><span class="rad-stat-lbl">{{ section.settings.stat3_lbl }}</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type": "image_picker", "id": "bg_image", "label": "Background Image"},
    {"type": "header", "content": "Text"},
    {"type": "text", "id": "badge", "label": "Badge", "default": "⭐ Karachi's Premium Auto Detailing"},
    {"type": "text", "id": "title", "label": "Headline", "default": "Transform Your Car's Look with"},
    {"type": "text", "id": "title_accent", "label": "Headline Accent (blue)", "default": "Revive Auto Detailing"},
    {"type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Professional car detailing, ceramic coating, PPF and window tinting services in Karachi. Premium quality, guaranteed results."},
    {"type": "header", "content": "Button"},
    {"type": "text", "id": "btn1_text", "label": "Button Text", "default": "Explore Our Services"},
    {"type": "url", "id": "btn1_url", "label": "Button Link"},
    {"type": "header", "content": "Stats"},
    {"type": "text", "id": "stat1_num", "label": "Stat 1 Number", "default": "500+"},
    {"type": "text", "id": "stat1_lbl", "label": "Stat 1 Label", "default": "Cars Serviced"},
    {"type": "text", "id": "stat2_num", "label": "Stat 2 Number", "default": "4.9 ⭐"},
    {"type": "text", "id": "stat2_lbl", "label": "Stat 2 Label", "default": "Google Rating"},
    {"type": "text", "id": "stat3_num", "label": "Stat 3 Number", "default": "2+"},
    {"type": "text", "id": "stat3_lbl", "label": "Stat 3 Label", "default": "Years Experience"}
  ],
  "presets": [{"name": "Hero"}]
}
{% endschema %}
