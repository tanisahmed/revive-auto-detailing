<style>
  .not-found-section {
    padding: 6rem 0;
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .not-found-section .emoji { font-size: 5rem; display: block; margin-bottom: 1rem; }
  .not-found-section h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.75rem; }
  .not-found-section p { color: var(--color-text-light); margin-bottom: 2rem; }
</style>

<section class="not-found-section">
  <div class="container">
    <span class="emoji">🔍</span>
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary">Return to Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
