  "settings": [
    {
      "type": "header",
      "content": "Button Text"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Package Button Text",
      "default": "Select Package"
    },
    {
      "type": "header",
      "content": "Section Heading"
