            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Bonnet</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>All Doors</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Front Fenders</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Trunk</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Rear Fenders</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Headlights</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Pillars</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Roof</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Front Bumper</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Back Bumper</div>
          </div>
          <!-- Complementary -->
          <div style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#6b7280;padding-bottom:5px;border-bottom:1px solid #e5e7eb;margin-bottom:7px;">Complementary</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;row-gap:3px;column-gap:8px;">
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>Int/Ext Detailing</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>Ceramic Coatings</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; View</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Rims &amp; Tire</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Leather Shield</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Interior Trims</div>
          </div>
          <div style="flex:1;min-height:12px;"></div>
          <div id="classic-dur" style="font-size:12px;color:#6b7280;text-align:center;margin-top:12px;margin-bottom:8px;">&#9201; Process: 3 Working Days</div>
          <button style="display:block;width:100%;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#0C447C;color:#fff;border:none;cursor:pointer;font-family:inherit;" onclick="this.style.background='#10b981';this.textContent='Selected ✓';setTimeout(function(){window.location.href='/pages/ppf-booking';},300);">Select Package</button>
        </div>
      </div>

      <!-- PREMIUM CARD -->
      <div class="package-card" data-pkg="premium" onclick="selectPackage(this)" style="border:1.5px solid #e5e7eb;border-radius:12px;overflow:visible;display:flex;flex-direction:column;">
        <!-- Header -->
        <div style="background:#2C2C2A;padding:1.4rem 1.25rem 1rem;text-align:center;border-radius:10px 10px 0 0;">
          <div style="font-size:18px;font-weight:800;color:#fff;margin-bottom:8px;margin-top:4px;">{{ section.settings.premium_name }}</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;">
            <span style="font-size:11px;font-weight:500;padding:2px 10px;border-radius:100px;background:rgba(255,255,255,0.15);color:#fff;">{{ section.settings.premium_mil }}</span>
            <span style="font-size:11px;font-weight:500;padding:2px 10px;border-radius:100px;background:rgba(255,255,255,0.9);color:#2C2C2A;">&#9733; {{ section.settings.premium_warranty }}</span>
          </div>
        </div>
        <!-- Body -->
        <div style="padding:1rem 1.25rem;flex:1;display:flex;flex-direction:column;">
          <div id="premium-price" style="font-size:28px;font-weight:700;color:#1f2937;text-align:center;margin-bottom:2px;">PKR 330,000</div>
          <div style="font-size:13px;color:#6b7280;text-align:center;margin-bottom:12px;">Complete PPF from bumper to bumper</div>
          <!-- Panels -->
          <div style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#6b7280;padding-bottom:5px;border-bottom:1px solid #e5e7eb;margin-bottom:7px;">Panels Covered</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;row-gap:3px;column-gap:8px;margin-bottom:10px;">
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Bonnet</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>All Doors</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Front Fenders</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Trunk</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Rear Fenders</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Headlights</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Pillars</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Roof</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Front Bumper</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="width:5px;height:5px;background:#0C447C;border-radius:50%;flex-shrink:0;display:inline-block;"></span>Back Bumper</div>
          </div>
          <!-- Complementary -->
          <div style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#6b7280;padding-bottom:5px;border-bottom:1px solid #e5e7eb;margin-bottom:7px;">Complementary</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;row-gap:3px;column-gap:8px;">
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>Int/Ext Detailing</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>Ceramic Coatings</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; View</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Rims &amp; Tire</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Leather Shield</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:13px;color:#374151;"><span style="color:#0C447C;font-weight:700;font-size:12px;">&#10003;</span>GYEON Q&#178; Interior Trims</div>
          </div>
          <div style="flex:1;min-height:12px;"></div>
          <div id="premium-dur" style="font-size:12px;color:#6b7280;text-align:center;margin-top:12px;margin-bottom:8px;">&#9201; Process: 3 Working Days</div>
          <button style="display:block;width:100%;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#0C447C;color:#fff;border:none;cursor:pointer;font-family:inherit;" onclick="this.style.background='#10b981';this.textContent='Selected ✓';setTimeout(function(){window.location.href='/pages/ppf-booking';},300);">Select Package</button>
        </div>
      </div>

    </div>

    <div style="text-align:center;margin-top:2rem;">
      <a href="/pages/ppf-booking" class="btn btn-primary" style="font-size:1.05rem;padding:1rem 2.5rem;">
        Book Your PPF Installation →
      </a>
    </div>
  </div>
</section>

<script>
  (function() {
    var currentVehicle = 'hatchback';
    var pricing = {
      hatchback: {
        label: 'Hatchback',
        classic: { price: {{ section.settings.p_hatchback_classic }}, duration: '{{ section.settings.dur_hatchback }}' },
        premium: { price: {{ section.settings.p_hatchback_premium }}, duration: '{{ section.settings.dur_hatchback }}' }
      },
      sedan: {
        label: 'Sedan',
        classic: { price: {{ section.settings.p_sedan_classic }}, duration: '{{ section.settings.dur_sedan }}' },
        premium: { price: {{ section.settings.p_sedan_premium }}, duration: '{{ section.settings.dur_sedan }}' }
      },
      suv: {
        label: 'SUV',
        classic: { price: {{ section.settings.p_suv_classic }}, duration: '{{ section.settings.dur_suv }}' },
        premium: { price: {{ section.settings.p_suv_premium }}, duration: '{{ section.settings.dur_suv }}' }
      },
      'xl-suv': {
        label: 'XL SUV',
        classic: { price: {{ section.settings.p_xlsuv_classic }}, duration: '{{ section.settings.dur_xlsuv }}' },
        premium: { price: {{ section.settings.p_xlsuv_premium }}, duration: '{{ section.settings.dur_xlsuv }}' }
      }
    };

    var classicFeatures = [
      'Full exterior coverage',
      'NAR Classic 8.0mil film',
      'Self-healing technology',
      'UV resistant coating',
      '8 year manufacturer warranty',
      'Professional installation'
    ];

    var premiumFeatures = [
      'Full exterior coverage',
      'NAR Premium 8.5mil film',
      'Enhanced self-healing technology',
      'Superior UV + hydrophobic coating',
      '10 year manufacturer warranty',
      'Professional installation',
      'Post-install inspection report'
    ];

    function formatPrice(n) {
      return 'PKR ' + n.toLocaleString();
    }

    function renderPackages(vehicleKey) {
      var data = pricing[vehicleKey];
      currentVehicle = vehicleKey;
      var label = document.getElementById('vehicle-label');
      if(label) label.textContent = data.label;
      var vex = document.getElementById('ppf-vex');
      var exMap = {
        'hatchback': (vex && vex.dataset.hatchback) ? vex.dataset.hatchback : 'Swift, Mira, Dayz',
        'sedan':     (vex && vex.dataset.sedan)     ? vex.dataset.sedan     : 'Corolla, Civic, Sonata',
        'suv':       (vex && vex.dataset.suv)        ? vex.dataset.suv       : 'Sportage L, Tucson, Haval H6',
        'xl-suv':    (vex && vex.dataset.xlsuv)      ? vex.dataset.xlsuv     : 'Fortuner, Land Cruiser, Prado'
      };
      var exEl = document.getElementById('vehicle-examples');
      if(exEl) exEl.textContent = exMap[vehicleKey] ? '(' + exMap[vehicleKey] + ')' : '';
      // Update prices only
      var cp = document.getElementById('classic-price');
      var pp = document.getElementById('premium-price');
      var cd = document.getElementById('classic-dur');
      var pd = document.getElementById('premium-dur');
      if(cp) cp.textContent = formatPrice(data.classic.price);
      if(pp) pp.textContent = formatPrice(data.premium.price);
      if(cd) cd.innerHTML = '⏱ Process: ' + data.classic.duration;
      if(pd) pd.innerHTML = '⏱ Process: ' + data.premium.duration;
    }

    window.selectPackage = function(card) {
      document.querySelectorAll('.package-card').forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
    };

    window.handleSelectPkg = function(e, pkg, vehicle) {
      e.stopPropagation();
      var btn = e.currentTarget;
      document.querySelectorAll('.package-select-btn').forEach(function(b) {
        b.textContent = 'Select Package';
        b.classList.remove('selected-state');
      });
      btn.textContent = '✓ Selected';
      btn.classList.add('selected-state');

      // Save to sessionStorage for booking page
      var bookingData = {
        package: pkg === 'classic' ? 'NAR Classic PPF 8.0mil' : 'NAR Premium PPF 8.5mil',
        vehicle_type: pricing[vehicle].label,
        price: pricing[vehicle][pkg].price,
        duration: pricing[vehicle][pkg].duration
      };
      try { sessionStorage.setItem('rad_selected_pkg', JSON.stringify(bookingData)); } catch(err) {}
    };

    // Vehicle button listeners
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.vehicle-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.vehicle-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          renderPackages(btn.dataset.vehicle);
        });
      });
      renderPackages('hatchback');
    });
  })();
</script>

