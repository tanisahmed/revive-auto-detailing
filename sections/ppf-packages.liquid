<style>
  .ppf-pricing-section {
    padding: 2rem 0 3rem;
    background: var(--color-secondary);
  }
  .ppf-pricing-section .section-title { margin-bottom: 0.5rem; }
  .ppf-pricing-section .section-subtitle { margin-bottom: 1.25rem; display: block; }

  /* Vehicle Type Selector */
  .vehicle-selector {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .vehicle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.75rem;
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 0.9rem;
    color: #374151;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .vehicle-btn:hover {
    border-color: #1e3a8a;
    color: #1e3a8a;
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 8px 20px rgba(30,58,138,0.15);
  }
  .vehicle-btn.active {
    background: #1e3a8a;
    border-color: #1e3a8a;
    color: #fff;
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 8px 20px rgba(30,58,138,0.3);
  }

  /* Packages */
  .packages-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 1.75rem auto 0;
    align-items: start;
  }

  .package-card h3, .package-card .package-name { font-size: 15px !important; font-weight: 500 !important; }
  .package-card .package-price { font-size: 22px !important; font-weight: 500 !important; }
  .package-card .package-duration { font-size: 12px !important; }
  .ppf-badge { font-size: 11px !important; }
  .package-card {
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    transition: var(--transition);
    position: relative;
    cursor: pointer;
  }
  .package-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }
  .package-card.selected {
    border-color: var(--color-primary);
    transform: scale(1.02);
    box-shadow: var(--shadow-lg);
  }

  .package-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.85rem;
    border-radius: 100px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .package-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .package-mil {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
    display: block;
  }
  .package-price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .package-price span { font-size: 1rem; font-weight: 600; }
  .package-duration {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .package-features {
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .package-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text);
    padding: 0.35rem 0;
  }
  .package-feature::before {
    content: '✓';
    color: var(--color-success);
    font-weight: 700;
    flex-shrink: 0;
  }

  .package-select-btn {
    display: block; width: 100%; margin-top: 14px;
    padding: 10px; border-radius: 8px;
    font-family: var(--font-primary);
    font-size: 0.9rem; font-weight: 700;
    background: #1e3a8a; color: #fff;
    border: none; cursor: pointer; transition: background 0.2s;
  }
  .package-select-btn:hover { background: #1e40af; }
  .package-select-btn:hover { background: var(--color-primary-hover); }
  .package-select-btn.selected-state {
    background: var(--color-success);
    border-color: var(--color-success);
  }

  @media (max-width: 640px) {
    .ppf-pricing-section { padding: 3.5rem 0; }
    .packages-grid { grid-template-columns: 1fr; }
    .vehicle-btn { min-width: 90px; padding: 0.75rem 1rem; }
  }
</style>

