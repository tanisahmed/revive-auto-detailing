<style>
  .ppf-pricing-section {
    padding: 2.5rem 0;
    background: var(--color-secondary);
  }

  /* Vehicle Type Selector */
  .vehicle-selector {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .vehicle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .vehicle-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 8px 20px rgba(30,58,138,0.15);
  }
  .vehicle-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 8px 20px rgba(30,58,138,0.3);
  }

  /* Packages */
  .packages-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .package-card {
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    transition: var(--transition);
    position: relative;
    cursor: pointer;
  }
  .package-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }
  .package-card.selected {
    border-color: var(--color-primary);
    transform: scale(1.02);
    box-shadow: var(--shadow-lg);
  }

  .package-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.85rem;
    border-radius: 100px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .package-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .package-mil {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
    display: block;
  }
  .package-price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .package-price span { font-size: 1rem; font-weight: 600; }
  .package-duration {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .package-features {
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .ppf-card-top { margin-bottom: 1rem; }
  .ppf-feat-block { margin-bottom: 0.75rem; }
  .ppf-comp-block { background: rgba(30,58,138,0.04); border-radius: 8px; padding: 0.5rem 0.6rem; }
  .ppf-feat-hdr {
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 0.5rem; padding: 0.25rem 0.5rem;
    border-radius: 4px; display: inline-block;
  }
  .ppf-hdr-red { background: #fef2f2; color: #dc2626; }
  .ppf-hdr-blue { background: rgba(30,58,138,0.1); color: #1e3a8a; }
  .ppf-panels-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.2rem; }
  .ppf-panel-row { display: contents; }
  .ppf-panel-row > span { font-size: 0.8rem; color: #374151; padding: 0.15rem 0; display: flex; align-items: center; gap: 0.3rem; }
  .ppf-dot { width: 6px; height: 6px; background: #dc2626; border-radius: 50%; flex-shrink: 0; }
  .ppf-comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.2rem; }
  .ppf-comp-row { display: contents; }
  .ppf-comp-row > span { font-size: 0.8rem; color: #374151; padding: 0.15rem 0; display: flex; align-items: center; gap: 0.3rem; }
  .ppf-tick { color: #1e3a8a; font-weight: 800; font-size: 0.85rem; flex-shrink: 0; }
  .ppf-feat-hdr.pkg-section-hdr {
    font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.12em; color: #1e3a8a;
    background: rgba(30,58,138,0.08); border-radius: 4px;
    padding: 0.3rem 0.6rem; margin: 0.5rem 0 0.35rem;
  }
  .pkg-check { color: #10b981; font-weight: 800; margin-right: 0.4rem; }
  .package-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text);
    padding: 0.35rem 0;
  }
  .package-feature::before {
    content: '✓';
    color: var(--color-success);
    font-weight: 700;
    flex-shrink: 0;
  }

  .package-select-btn {
    display: block; width: 100%; margin-top: 14px;
    padding: 10px; border-radius: 8px;
    font-family: var(--font-primary);
    font-size: 0.9rem; font-weight: 700;
    background: #1e3a8a; color: #fff;
    border: none; cursor: pointer; transition: background 0.2s;
  }
  .package-select-btn:hover { background: #1e40af; }
  .package-select-btn:hover { background: var(--color-primary-hover); }
  .package-select-btn.selected-state {
    background: var(--color-success);
    border-color: var(--color-success);
  }

  @media (max-width: 640px) {
    .ppf-pricing-section { padding: 3.5rem 0; }
    .packages-grid { grid-template-columns: 1fr; }
    .vehicle-btn { min-width: 90px; padding: 0.75rem 1rem; }
  }
</style>

<section class="ppf-pricing-section" id="ppf-pricing">
  <div class="container">
    <h2 class="section-title">Choose Your Vehicle Type</h2>
    <p class="section-subtitle">Select your vehicle to see accurate pricing</p>

    <!-- Vehicle Selector Buttons -->
    <div class="vehicle-selector" role="group" aria-label="Vehicle type selector">
      <button class="vehicle-btn" data-vehicle="hatchback">Hatchback</button>
      <button class="vehicle-btn active" data-vehicle="sedan">Sedan</button>
      <button class="vehicle-btn" data-vehicle="suv">SUV</button>
      <button class="vehicle-btn" data-vehicle="xl-suv">XL SUV</button>
    </div>

    <h3 class="packages-title" id="packages-label">Select Your Package — <span id="vehicle-label">Sedan</span></h3>

    <!-- Package Cards -->
    <div class="packages-grid" id="packages-grid">
      <!-- Populated by JS -->
    </div>

    <div style="text-align:center;margin-top:2rem;">
      <a href="/pages/ppf-booking" class="btn btn-primary" style="font-size:1.05rem;padding:1rem 2.5rem;">
        Book Your PPF Installation →
      </a>
    </div>
  </div>
</section>

<script>
  (function() {
    var pricing = {
      hatchback: {
        label: 'Hatchback',
        classic: { price: {{ section.settings.p_hatchback_classic }}, duration: '{{ section.settings.dur_hatchback }}' },
        premium: { price: {{ section.settings.p_hatchback_premium }}, duration: '{{ section.settings.dur_hatchback }}' }
      },
      sedan: {
        label: 'Sedan',
        classic: { price: {{ section.settings.p_sedan_classic }}, duration: '{{ section.settings.dur_sedan }}' },
        premium: { price: {{ section.settings.p_sedan_premium }}, duration: '{{ section.settings.dur_sedan }}' }
      },
      suv: {
        label: 'SUV',
        classic: { price: {{ section.settings.p_suv_classic }}, duration: '{{ section.settings.dur_suv }}' },
        premium: { price: {{ section.settings.p_suv_premium }}, duration: '{{ section.settings.dur_suv }}' }
      },
      'xl-suv': {
        label: 'XL SUV',
        classic: { price: {{ section.settings.p_xlsuv_classic }}, duration: '{{ section.settings.dur_xlsuv }}' },
        premium: { price: {{ section.settings.p_xlsuv_premium }}, duration: '{{ section.settings.dur_xlsuv }}' }
      }
    };

    var panelsCovered = ['Bonnet','Front Fenders','Rear Fenders','Pillars','Front Bumper','All Doors','Trunk','Headlights','Roof','Back Bumper'];
    var complementary = ['Interior / Exterior Detailing','Q² View','Q² Leather Shield','Interior Ceramic Coatings','Q² Rims & Tire','Q² Interior Trims'];



    function formatPrice(n) {
      return 'PKR ' + n.toLocaleString();
    }

    function renderPackages(vehicleKey) {
      var data = pricing[vehicleKey];
      var grid = document.getElementById('packages-grid');
      var label = document.getElementById('vehicle-label');
      label.textContent = data.label;

      var panels = ['Bonnet','Front Fenders','Rear Fenders','Pillars','Front Bumper','All Doors','Trunk','Headlights','Roof','Back Bumper'];
      var comp = ['Int/Ext Detailing','GYEON Q² View','GYEON Q² Leather Shield','Ceramic Coatings','GYEON Q² Rims & Tire','GYEON Q² Interior Trims'];

      function panelItems() {
        var panels = ['Bonnet','Front Fenders','Rear Fenders','Pillars','Front Bumper','All Doors','Trunk','Headlights','Roof','Back Bumper'];
        var half = Math.ceil(panels.length/2);
        var html = '';
        for(var i=0;i<half;i++){
          html += '<div style="display:flex;gap:6px;margin-bottom:3px;">' +
            '<div style="flex:1;display:flex;align-items:center;gap:5px;font-size:12px;color:#4b5563;"><span style="width:4px;height:4px;background:#1e3a8a;border-radius:50%;flex-shrink:0;display:inline-block;"></span>' + panels[i] + '</div>' +
            (panels[i+half] ? '<div style="flex:1;display:flex;align-items:center;gap:5px;font-size:12px;color:#4b5563;"><span style="width:4px;height:4px;background:#1e3a8a;border-radius:50%;flex-shrink:0;display:inline-block;"></span>' + panels[i+half] + '</div>' : '<div style="flex:1;"></div>') +
          '</div>';
        }
        return html;
      }
      function compItems() {
        var comp = ['Int/Ext Detailing','GYEON Q² View','GYEON Q² Leather Shield','Ceramic Coatings','GYEON Q² Rims & Tire','GYEON Q² Interior Trims'];
        var half = Math.ceil(comp.length/2);
        var html = '';
        for(var i=0;i<half;i++){
          html += '<div style="display:flex;gap:6px;margin-bottom:3px;">' +
            '<div style="flex:1;display:flex;align-items:center;gap:5px;font-size:12px;color:#4b5563;"><span style="color:#1e3a8a;font-weight:700;font-size:11px;">✓</span>' + comp[i] + '</div>' +
            (comp[i+half] ? '<div style="flex:1;display:flex;align-items:center;gap:5px;font-size:12px;color:#4b5563;"><span style="color:#1e3a8a;font-weight:700;font-size:11px;">✓</span>' + comp[i+half] + '</div>' : '<div style="flex:1;"></div>') +
          '</div>';
        }
        return html;
      }
      grid.innerHTML =
        '<div class="package-card" data-pkg="classic" onclick="selectPackage(this)">' +
          '<div class="package-badge">Most Popular</div>' +
          '<div class="ppf-card-top">' +
            '<div class="ppf-pkg-name">NAR Classic PPF</div>' +
            '<div class="ppf-badges">' +
              '<span class="ppf-badge ppf-badge-gray">8.0 mil thickness</span>' +
              '<span class="ppf-badge ppf-badge-blue">&#9733; 5 Years Warranty</span>' +
            '</div>' +
            '<div class="package-price">' + formatPrice(data.classic.price) + '</div>' +
            '<div class="package-duration">&#9201; ' + data.classic.duration + '</div>' +
          '</div>' +
          featHtml +
          '<button class="package-select-btn" onclick="handleSelectPkg(event, \'classic\', \'' + vehicleKey + '\')">Select Package</button>' +
        '</div>' +

        '<div class="package-card" data-pkg="premium" onclick="selectPackage(this)">' +
          '<div class="ppf-card-top">' +
            '<div class="ppf-pkg-name">NAR Premium PPF</div>' +
            '<div class="ppf-badges">' +
              '<span class="ppf-badge ppf-badge-gray">8.5 mil thickness</span>' +
              '<span class="ppf-badge ppf-badge-dark">&#9733; 7 Years Warranty</span>' +
            '</div>' +
            '<div class="package-price">' + formatPrice(data.premium.price) + '</div>' +
            '<div class="package-duration">&#9201; ' + data.premium.duration + '</div>' +
          '</div>' +
          featHtml +
          '<button class="package-select-btn" onclick="handleSelectPkg(event, \'premium\', \'' + vehicleKey + '\')">Select Package</button>' +
        '</div>';
    }

    window.selectPackage = function(card) {
      document.querySelectorAll('.package-card').forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
    };

    window.handleSelectPkg = function(e, pkg, vehicle) {
      e.stopPropagation();
      var btn = e.currentTarget;
      document.querySelectorAll('.package-select-btn').forEach(function(b) {
        b.textContent = 'Select Package';
        b.classList.remove('selected-state');
      });
      btn.textContent = '✓ Selected';
      btn.classList.add('selected-state');

      // Save to sessionStorage for booking page
      var bookingData = {
        package: pkg === 'classic' ? 'NAR Classic PPF 8.0mil' : 'NAR Premium PPF 8.5mil',
        vehicle_type: pricing[vehicle].label,
        price: pricing[vehicle][pkg].price,
        duration: pricing[vehicle][pkg].duration
      };
      try { sessionStorage.setItem('rad_selected_pkg', JSON.stringify(bookingData)); } catch(err) {}
    };

    // Vehicle button listeners
    document.querySelectorAll('.vehicle-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.vehicle-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        renderPackages(btn.dataset.vehicle);
      });
    });

    // Initial render
    renderPackages('sedan');
  })();
</script>

