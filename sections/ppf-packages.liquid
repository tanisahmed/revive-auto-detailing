      <!-- CLASSIC CARD -->
      <div class="package-card" data-pkg="classic" onclick="selectPackage(this)" style="border:2px solid #0C447C;border-radius:12px;overflow:visible;display:flex;flex-direction:column;position:relative;">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#10b981;color:#fff;font-size:11px;font-weight:600;padding:4px 16px;border-radius:100px;white-space:nowrap;z-index:2;box-shadow:0 2px 8px rgba(16,185,129,0.4);">MOST POPULAR</div>
        <!-- Header -->
        <div style="background:#0C447C;padding:1.4rem 1.25rem 1rem;text-align:center;border-radius:10px 10px 0 0;">
          <div style="font-size:17px;font-weight:800;color:#fff;margin-bottom:8px;margin-top:12px;">{{ section.settings.classic_name }}</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;">
