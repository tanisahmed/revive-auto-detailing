<style>
.ppf-cmp { padding: 3rem 0 3.5rem; background: #fff; font-family: 'Nunito Sans', sans-serif; }
.ppf-cmp-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }
.ppf-cmp-hdr { margin-bottom: 2.5rem; text-align: center; }
.ppf-cmp-hdr h2 { font-size: 2rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; }
.ppf-cmp-hdr p { color: #6b7280; font-size: 0.95rem; }

/* Table wrapper */
.ppf-cmp-grid-wrap {
  margin-top: 3rem;
  padding-top: 0;
  position: relative;
}
.ppf-cmp-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #d1d5db;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  margin-top: 0;
}
/* Clip inner cells to card radius */
.ppf-cmp-grid > *:first-child { border-radius: 12px 0 0 0; }
.ppf-cmp-grid > *:nth-child(4) { border-radius: 0 12px 0 0; }

/* All cells base */
.ppf-h-empty, .ppf-h-brand,
.ppf-bn-lbl, .ppf-bn-cr, .ppf-bn-cl, .ppf-bn-pr,
.ppf-lbl, .ppf-val {
  border-right: 1px solid #cbd5e1;
  border-bottom: 1px solid #cbd5e1;
}
.ppf-h-brand:last-child,
.ppf-bn-pr,
.ppf-val:last-child { border-right: none; }
.ppf-lbl-last, .ppf-val-last { border-bottom: none; }

/* Header row (logo row) */
.ppf-h-empty {
  background: #fff;
  padding: 1.25rem 1rem;
  display: flex; align-items: center;
}
.ppf-h-empty span {
  font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em;
  text-transform: uppercase; color: #64748b;
}
.ppf-h-brand {
  background: #fff;
  padding: 1.25rem 0.75rem 1rem;
  display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 0;
  position: relative; border-right: 1px solid #e2e8f0;
}
.ppf-h-feat { border-top: 3px solid #1e3a8a; }
.ppf-cmp-grid-wrap .ppf-rec {
  position: absolute; top: -32px; left: 50%; transform: translateX(-50%);
  background: #1e3a8a; color: #fff;
  font-size: 0.7rem; font-weight: 700; padding: 6px 20px;
  border-radius: 8px 8px 0 0; white-space: nowrap; letter-spacing: 0.05em;
  box-shadow: 0 -2px 8px rgba(30,58,138,0.25);
  z-index: 10;
  z-index: 10;
}
.ppf-logo-box {
  width: 100%; height: 64px;
  display: flex; align-items: center; justify-content: center;
}
.ppf-logo-box img { max-width: 140px; height: 56px; object-fit: contain; display: block; }
.ppf-logo-ph { font-size: 0.65rem; color: #64748b; }

/* Brand name row */
.ppf-bn-lbl {
  background: #1e293b;
  padding: 0.65rem 0.75rem 0.65rem 1rem;
  font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  color: #fff; border-bottom: 1px solid #0f172a; border-right: 1px solid #334155;
}
.ppf-bn-cr { background: #E24B4A; padding: 0.65rem 0.5rem; text-align: center; border-bottom: 1px solid #c13333; border-right: 1px solid #c13333; }
.ppf-bn-cl { background: #0C447C; padding: 0.65rem 0.5rem; text-align: center; border-bottom: 1px solid #093560; border-right: 1px solid #093560; }
.ppf-bn-pr { background: #2C2C2A; padding: 0.65rem 0.5rem; text-align: center; border-bottom: 1px solid #1a1a18; border-right: none; }
.ppf-bn-text { font-size: 0.8rem; font-weight: 800; color: #fff; font-family: 'Nunito Sans', sans-serif; }

/* Data rows */
.ppf-lbl {
  background: #fff;
  padding: 0.7rem 0.75rem 0.7rem 1rem;
  font-size: 0.82rem; font-weight: 600; color: #374151;
  border-right: 1px solid #e2e8f0;
}
.ppf-val {
  background: #fff;
  padding: 0.7rem 0.5rem; text-align: center;
  font-size: 0.82rem; color: #374151;
  border-right: 1px solid #e2e8f0;
}
/* Alternate rows */
.ppf-lbl:nth-child(8n+5), .ppf-lbl:nth-child(8n+6), .ppf-lbl:nth-child(8n+7), .ppf-lbl:nth-child(8n+8),
.ppf-val:nth-child(8n+5), .ppf-val:nth-child(8n+6), .ppf-val:nth-child(8n+7), .ppf-val:nth-child(8n+8) {
  background: #f8fafc;
}

/* Colored values */
.vr { color: #dc2626; font-weight: 700; }
.vb { color: #0C447C; font-weight: 700; }
.vg { color: #1e293b; font-weight: 700; }
.cr { color: #dc2626; font-size: 1rem; font-weight: 700; }
.cb { color: #0C447C; font-size: 1rem; font-weight: 700; }
.cg { color: #475569; font-size: 1rem; font-weight: 700; }

/* Rating bars */
.ppf-bars { display: flex; gap: 3px; justify-content: center; align-items: center; }
.ppf-bar { width: 16px; height: 7px; border-radius: 100px; }
.ppf-br { background: #ef4444; }
.ppf-bb { background: #0C447C; }
.ppf-bg { background: #2C2C2A; }
.ppf-bo { background: #e2e8f0; }

/* Mobile */
@media (max-width: 640px) {
  .ppf-cmp { padding: 2rem 0; }
  .ppf-cmp-hdr h2 { font-size: 1.4rem; }
  .ppf-cmp-inner { padding: 0 0.75rem; }
  .ppf-cmp-grid { grid-template-columns: 34% repeat(3, 1fr); font-size: 0.72rem; }
  .ppf-h-empty { padding: 0.75rem 0.5rem; }
  .ppf-h-brand { padding: 0.85rem 0.3rem 0.6rem; }
  .ppf-logo-box { height: 32px; }
  .ppf-logo-box img { max-width: 72px; height: 28px; }
  .ppf-bn-lbl, .ppf-bn-cr, .ppf-bn-cl, .ppf-bn-pr { padding: 0.5rem 0.25rem; }
  .ppf-bn-text { font-size: 0.62rem; }
  .ppf-lbl { padding: 0.55rem 0.4rem 0.55rem 0.5rem; font-size: 0.72rem; }
  .ppf-val { padding: 0.55rem 0.3rem; font-size: 0.72rem; }
  .ppf-bar { width: 10px; height: 5px; }
  .ppf-rec { font-size: 0.5rem; padding: 2px 6px; }
}
</style>

<section class="ppf-cmp">
  <div class="ppf-cmp-inner">
    <div class="ppf-cmp-hdr">
      <h2>{{ section.settings.title | default: "PPF Comparison" }}</h2>
      <p>{{ section.settings.subtitle | default: "Compare film properties across all three options" }}</p>
    </div>

    <div class="ppf-cmp-grid-wrap">
      <span class="ppf-rec">Recommended</span>
      <div class="ppf-cmp-grid">

      <!-- Logo row -->
      <div class="ppf-h-empty"><span>Properties</span></div>
      <div class="ppf-h-brand">
        <div class="ppf-logo-box">
          {%- if section.settings.logo1 != blank -%}
            <img src="{{ section.settings.logo1 | image_url: width: 400 }}" srcset="{{ section.settings.logo1 | image_url: width: 400 }} 1x, {{ section.settings.logo1 | image_url: width: 800 }} 2x" alt="{{ section.settings.brand1 }}">
          {%- else -%}<span class="ppf-logo-ph">LOGO</span>{%- endif -%}
        </div>
      </div>
      <div class="ppf-h-brand ppf-h-feat">
        <div class="ppf-logo-box">
          {%- if section.settings.logo2 != blank -%}
            <img src="{{ section.settings.logo2 | image_url: width: 400 }}" srcset="{{ section.settings.logo2 | image_url: width: 400 }} 1x, {{ section.settings.logo2 | image_url: width: 800 }} 2x" alt="{{ section.settings.brand2 }}">
          {%- else -%}<span class="ppf-logo-ph" style="color:#0C447C;font-weight:700;">NAR</span>{%- endif -%}
        </div>
      </div>
      <div class="ppf-h-brand">
        <div class="ppf-logo-box">
          {%- if section.settings.logo3 != blank -%}
            <img src="{{ section.settings.logo3 | image_url: width: 400 }}" srcset="{{ section.settings.logo3 | image_url: width: 400 }} 1x, {{ section.settings.logo3 | image_url: width: 800 }} 2x" alt="{{ section.settings.brand3 }}">
          {%- else -%}<span class="ppf-logo-ph">NAR</span>{%- endif -%}
        </div>
      </div>

      <!-- Brand name row -->
      <div class="ppf-bn-lbl">Brand</div>
      <div class="ppf-bn-cr"><span class="ppf-bn-text">{{ section.settings.brand1 | default: "Crystalline PPF" }}</span></div>
      <div class="ppf-bn-cl"><span class="ppf-bn-text">{{ section.settings.brand2 | default: "NAR Classic PPF" }}</span></div>
      <div class="ppf-bn-pr"><span class="ppf-bn-text">{{ section.settings.brand3 | default: "NAR Premium PPF" }}</span></div>

      <!-- Film type -->
      <div class="ppf-lbl">Film type</div>
      <div class="ppf-val"><span class="vm">{{ section.settings.r1_b1 | default: "TPU" }}</span></div>
      <div class="ppf-val ppf-val-feat"><span class="vb">{{ section.settings.r1_b2 | default: "TPU" }}</span></div>
      <div class="ppf-val"><span class="vg">{{ section.settings.r1_b3 | default: "TPU" }}</span></div>

      <!-- Thickness -->
      <div class="ppf-lbl">Thickness</div>
      <div class="ppf-val"><span class="vr">{{ section.settings.thick1 | default: "7.9 mil" }}</span></div>
      <div class="ppf-val ppf-val-feat"><span class="vb">{{ section.settings.thick2 | default: "8.0 mil" }}</span></div>
      <div class="ppf-val"><span class="vg">{{ section.settings.thick3 | default: "8.5 mil" }}</span></div>

      <!-- Pre-coated -->
      <div class="ppf-lbl">Pre-coated</div>
      <div class="ppf-val"><span class="cr">&#10003;</span></div>
      <div class="ppf-val ppf-val-feat"><span class="cb">&#10003;</span></div>
      <div class="ppf-val"><span class="cg">&#10003;</span></div>

      <!-- Self-healing -->
      <div class="ppf-lbl">Self-healing</div>
      <div class="ppf-val"><div class="ppf-bars">{%- assign sh1 = section.settings.sh1 | default: 3 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sh1 %} ppf-br{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val ppf-val-feat"><div class="ppf-bars">{%- assign sh2 = section.settings.sh2 | default: 4 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sh2 %} ppf-bb{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val"><div class="ppf-bars">{%- assign sh3 = section.settings.sh3 | default: 4 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sh3 %} ppf-bg{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>

      <!-- Chemical resistance -->
      <div class="ppf-lbl">Chemical resistance</div>
      <div class="ppf-val"><span class="cr">&#10003;</span></div>
      <div class="ppf-val ppf-val-feat"><span class="cb">&#10003;</span></div>
      <div class="ppf-val"><span class="cg">&#10003;</span></div>

      <!-- Product durability -->
      <div class="ppf-lbl">Product durability</div>
      <div class="ppf-val"><span class="vm">{{ section.settings.dur1 | default: "5 years" }}</span></div>
      <div class="ppf-val ppf-val-feat"><span class="vb">{{ section.settings.dur2 | default: "10 years" }}</span></div>
      <div class="ppf-val"><span class="vg">{{ section.settings.dur3 | default: "10 years" }}</span></div>

      <!-- Non-yellowing warranty -->
      <div class="ppf-lbl">Non-yellowing warranty</div>
      <div class="ppf-val"><span class="vm">{{ section.settings.nyw1 | default: "3 years" }}</span></div>
      <div class="ppf-val ppf-val-feat"><span class="vb">{{ section.settings.nyw2 | default: "3 years" }}</span></div>
      <div class="ppf-val"><span class="vg">{{ section.settings.nyw3 | default: "3 years" }}</span></div>

      <!-- Product warranty -->
      <div class="ppf-lbl">Product warranty</div>
      <div class="ppf-val"><span class="vm">{{ section.settings.pw1 | default: "3 years" }}</span></div>
      <div class="ppf-val ppf-val-feat"><span class="vb">{{ section.settings.pw2 | default: "5 years" }}</span></div>
      <div class="ppf-val"><span class="vg">{{ section.settings.pw3 | default: "7 years" }}</span></div>

      <!-- Scratch resistance -->
      <div class="ppf-lbl">Scratch resistance</div>
      <div class="ppf-val"><div class="ppf-bars">{%- assign sc1 = section.settings.sc1 | default: 3 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sc1 %} ppf-br{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val ppf-val-feat"><div class="ppf-bars">{%- assign sc2 = section.settings.sc2 | default: 3 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sc2 %} ppf-bb{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val"><div class="ppf-bars">{%- assign sc3 = section.settings.sc3 | default: 4 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= sc3 %} ppf-bg{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>

      <!-- Hydrophobic — last -->
      <div class="ppf-lbl ppf-lbl-last">Hydrophobic</div>
      <div class="ppf-val ppf-val-last"><div class="ppf-bars">{%- assign hy1 = section.settings.hy1 | default: 3 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= hy1 %} ppf-br{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val ppf-val-feat ppf-val-last"><div class="ppf-bars">{%- assign hy2 = section.settings.hy2 | default: 4 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= hy2 %} ppf-bb{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>
      <div class="ppf-val ppf-val-last"><div class="ppf-bars">{%- assign hy3 = section.settings.hy3 | default: 4 -%}{%- for i in (1..4) -%}<div class="ppf-bar{% if i <= hy3 %} ppf-bg{% else %} ppf-bo{% endif %}"></div>{%- endfor -%}</div></div>

    </div>
    </div><!-- /grid wrapper -->
  </div>
</section>

{% schema %}
{
  "name": "PPF Comparison",
  "settings": [
    {"type":"text","id":"title","label":"Section Title","default":"PPF Comparison"},
    {"type":"text","id":"subtitle","label":"Subtitle","default":"Compare film properties across all three options"},
    {"type":"color","id":"row_bg","label":"Table Row Background Color","default":"#ffffff"},
    {"type":"header","content":"Brand 1 — Crystalline"},
    {"type":"image_picker","id":"logo1","label":"Logo"},
    {"type":"text","id":"brand1","label":"Brand Name","default":"Crystalline PPF"},
    {"type":"header","content":"Brand 2 — NAR Classic"},
    {"type":"image_picker","id":"logo2","label":"Logo"},
    {"type":"text","id":"brand2","label":"Brand Name","default":"NAR Classic PPF"},
    {"type":"header","content":"Brand 3 — NAR Premium"},
    {"type":"image_picker","id":"logo3","label":"Logo"},
    {"type":"text","id":"brand3","label":"Brand Name","default":"NAR Premium PPF"},
    {"type":"header","content":"Film Type"},
    {"type":"text","id":"r1_b1","label":"Brand 1","default":"TPU"},
    {"type":"text","id":"r1_b2","label":"Brand 2","default":"TPU"},
    {"type":"text","id":"r1_b3","label":"Brand 3","default":"TPU"},
    {"type":"header","content":"Thickness"},
    {"type":"text","id":"thick1","label":"Brand 1","default":"7.9 mil"},
    {"type":"text","id":"thick2","label":"Brand 2","default":"8.0 mil"},
    {"type":"text","id":"thick3","label":"Brand 3","default":"8.5 mil"},
    {"type":"header","content":"Self-Healing Bars (1–4)"},
    {"type":"number","id":"sh1","label":"Brand 1","default":3},
    {"type":"number","id":"sh2","label":"Brand 2","default":4},
    {"type":"number","id":"sh3","label":"Brand 3","default":4},
    {"type":"header","content":"Product Durability"},
    {"type":"text","id":"dur1","label":"Brand 1","default":"5 years"},
    {"type":"text","id":"dur2","label":"Brand 2","default":"10 years"},
    {"type":"text","id":"dur3","label":"Brand 3","default":"10 years"},
    {"type":"header","content":"Non-Yellowing Warranty"},
    {"type":"text","id":"nyw1","label":"Brand 1","default":"3 years"},
    {"type":"text","id":"nyw2","label":"Brand 2","default":"3 years"},
    {"type":"text","id":"nyw3","label":"Brand 3","default":"3 years"},
    {"type":"header","content":"Product Warranty"},
    {"type":"text","id":"pw1","label":"Brand 1","default":"3 years"},
    {"type":"text","id":"pw2","label":"Brand 2","default":"5 years"},
    {"type":"text","id":"pw3","label":"Brand 3","default":"7 years"},
    {"type":"header","content":"Scratch Resistance Bars (1–4)"},
    {"type":"number","id":"sc1","label":"Brand 1","default":3},
    {"type":"number","id":"sc2","label":"Brand 2","default":3},
    {"type":"number","id":"sc3","label":"Brand 3","default":4},
    {"type":"header","content":"Hydrophobic Bars (1–4)"},
    {"type":"number","id":"hy1","label":"Brand 1","default":3},
    {"type":"number","id":"hy2","label":"Brand 2","default":4},
    {"type":"number","id":"hy3","label":"Brand 3","default":4}
  ],
  "presets":[{"name":"PPF Comparison"}]
}
{% endschema %}
