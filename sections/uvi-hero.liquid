<style>
.uvi-hero { background: linear-gradient(135deg, #0d0a1a 0%, #1a0a2e 50%, #0d0a1a 100%); min-height: 90vh; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 5rem 1.5rem; }
.uvi-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 40%, rgba(109,40,217,0.3) 0%, transparent 70%); }
.uvi-hero-inner { max-width: 860px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
.uvi-hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(109,40,217,0.2); border: 1px solid rgba(109,40,217,0.5); color: #c4b5fd; font-size: 0.75rem; font-weight: 700; padding: 0.4rem 1rem; border-radius: 100px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.75rem; }
.uvi-hero h1 { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 1.25rem; font-family: 'Nunito Sans', sans-serif; }
.uvi-hero h1 span { color: #a78bfa; }
.uvi-hero-sub { font-size: 1.15rem; color: #c4b5fd; max-width: 620px; margin: 0 auto 2.5rem; line-height: 1.7; }
.uvi-hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.uvi-btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: #6d28d9; color: #fff; padding: 1rem 2rem; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; box-shadow: 0 0 24px rgba(109,40,217,0.5); }
.uvi-btn-primary:hover { background: #7c3aed; transform: translateY(-2px); }
.uvi-btn-secondary { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: #c4b5fd; padding: 1rem 2rem; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; border: 1.5px solid rgba(196,181,253,0.4); transition: all 0.2s; }
.uvi-btn-secondary:hover { border-color: #a78bfa; color: #fff; }
.uvi-hero-trust { display: flex; justify-content: center; gap: 2rem; margin-top: 3rem; flex-wrap: wrap; }
.uvi-trust-item { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
.uvi-trust-num { font-size: 1.6rem; font-weight: 900; color: #a78bfa; }
.uvi-trust-lbl { font-size: 0.75rem; color: #7c6ea8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
@media (max-width: 640px) { .uvi-hero { min-height: 70vh; padding: 3rem 1rem; } .uvi-hero-trust { gap: 1.25rem; } .uvi-hero-btns { flex-direction: column; align-items: center; } }
</style>

<section class="uvi-hero">
  <div class="uvi-hero-inner">
    <div class="uvi-hero-badge">{{ section.settings.badge | default: "Karachi's Only UV Paint Inspection Studio" }}</div>
    <h1>
      {{ section.settings.h1_line1 | default: "Know Exactly What You're" }}<br>
      <span>{{ section.settings.h1_line2 | default: "Buying Before You Buy" }}</span>
    </h1>
    <p class="uvi-hero-sub">{{ section.settings.subtext | default: "Our UV light inspection reveals hidden repaints, accident damage, rust, and panel repairs — invisible to the naked eye. Don't pay full price for a compromised car." }}</p>
    <div class="uvi-hero-btns">
      <a href="{{ section.settings.btn1_url | default: '/pages/uv-inspection-booking' }}" class="uvi-btn-primary">🔦 {{ section.settings.btn1_text | default: "Book UV Inspection" }}</a>
      <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20book%20a%20UV%20paint%20inspection" target="_blank" class="uvi-btn-secondary">💬 WhatsApp Us</a>
    </div>
    <div class="uvi-hero-trust">
      <div class="uvi-trust-item"><span class="uvi-trust-num">{{ section.settings.s1n | default: "500+" }}</span><span class="uvi-trust-lbl">{{ section.settings.s1l | default: "Cars Inspected" }}</span></div>
      <div class="uvi-trust-item"><span class="uvi-trust-num">{{ section.settings.s2n | default: "30–60" }}</span><span class="uvi-trust-lbl">{{ section.settings.s2l | default: "Minutes Only" }}</span></div>
      <div class="uvi-trust-item"><span class="uvi-trust-num">{{ section.settings.s3n | default: "100%" }}</span><span class="uvi-trust-lbl">{{ section.settings.s3l | default: "Panel-by-Panel" }}</span></div>
      <div class="uvi-trust-item"><span class="uvi-trust-num">{{ section.settings.s4n | default: "PKR 5.5K" }}</span><span class="uvi-trust-lbl">{{ section.settings.s4l | default: "Starting Price" }}</span></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "UV Hero",
  "settings": [
    {"type":"text","id":"badge","label":"Badge Text","default":"Karachi's Only UV Paint Inspection Studio"},
    {"type":"text","id":"h1_line1","label":"Heading Line 1","default":"Know Exactly What You're"},
    {"type":"text","id":"h1_line2","label":"Heading Line 2 (highlighted)","default":"Buying Before You Buy"},
    {"type":"textarea","id":"subtext","label":"Sub Text","default":"Our UV light inspection reveals hidden repaints, accident damage, rust, and panel repairs — invisible to the naked eye."},
    {"type":"header","content":"Buttons"},
    {"type":"text","id":"btn1_text","label":"Primary Button Text","default":"Book UV Inspection"},
    {"type":"url","id":"btn1_url","label":"Primary Button URL","default":"/pages/uv-inspection-booking"},
    {"type":"header","content":"Trust Stats"},
    {"type":"text","id":"s1n","label":"Stat 1 Number","default":"500+"},
    {"type":"text","id":"s1l","label":"Stat 1 Label","default":"Cars Inspected"},
    {"type":"text","id":"s2n","label":"Stat 2 Number","default":"30–60"},
    {"type":"text","id":"s2l","label":"Stat 2 Label","default":"Minutes Only"},
    {"type":"text","id":"s3n","label":"Stat 3 Number","default":"100%"},
    {"type":"text","id":"s3l","label":"Stat 3 Label","default":"Panel-by-Panel"},
    {"type":"text","id":"s4n","label":"Stat 4 Number","default":"PKR 5.5K"},
    {"type":"text","id":"s4l","label":"Stat 4 Label","default":"Starting Price"}
  ],
  "presets": [{"name": "UV Hero"}]
}
{% endschema %}