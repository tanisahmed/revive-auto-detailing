<style>
.rad-ar-pricing { padding: 3rem 0; background: #f3f4f6; }

/* Top info bar */
.rad-ar-info-bar {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
  margin-bottom: 2.5rem;
}
.rad-ar-info-item {
  background: #fff; border-radius: 12px; padding: 1.25rem;
  text-align: center; border-top: 3px solid #1e3a8a;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.rad-ar-info-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
.rad-ar-info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; font-weight: 700; margin-bottom: 0.25rem; }
.rad-ar-info-value { font-size: 1rem; font-weight: 800; color: #1e3a8a; }

/* Main layout - 2 col */
.rad-ar-main { display: grid; grid-template-columns: 1fr 1.2fr; gap: 2rem; align-items: start; }

/* Left - Applied on + Benefits */
.rad-ar-left-card {
  background: #fff; border-radius: 12px; overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}
.rad-ar-left-header {
  background: linear-gradient(135deg, #1a0a00, #7c2d12);
  color: #fff; padding: 1.5rem; text-align: center;
}
.rad-ar-left-header-title { font-size: 1.25rem; font-weight: 800; font-family: 'Nunito Sans', sans-serif; }
.rad-ar-left-header-sub { font-size: 0.85rem; opacity: 0.85; margin-top: 0.25rem; }
.rad-ar-left-body { padding: 1.5rem; }

.rad-ar-section-label {
  font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.1em; color: #6b7280; margin-bottom: 0.85rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.rad-ar-section-label::after { content: ''; flex: 1; height: 1px; background: #e5e7eb; }

.rad-ar-applied-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 1.5rem; }
.rad-ar-applied-item {
  background: #f9fafb; border-radius: 8px; padding: 0.75rem;
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.875rem; font-weight: 700; color: #1f2937;
  border-left: 3px solid #7c2d12;
}
.rad-ar-applied-item span { font-size: 1.1rem; }

.rad-ar-benefits-list { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
.rad-ar-benefit-item {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.875rem; color: #1f2937; padding: 0.4rem 0;
  border-bottom: 1px solid #f3f4f6;
}
.rad-ar-benefit-item:last-child { border-bottom: none; }
.rad-ar-benefit-item::before { content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0; font-size: 0.9rem; }

.rad-ar-free-tag {
  background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;
  padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.875rem; font-weight: 700; color: #15803d;
}

/* Right - Pricing */
.rad-ar-right-card {
  background: #fff; border-radius: 12px; overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}
.rad-ar-right-header {
  background: #1e3a8a; color: #fff;
  padding: 1.5rem; text-align: center;
}
.rad-ar-right-header-title { font-size: 1.25rem; font-weight: 800; font-family: 'Nunito Sans', sans-serif; }
.rad-ar-right-header-sub { font-size: 0.85rem; opacity: 0.85; margin-top: 0.25rem; }
.rad-ar-right-body { padding: 1.5rem; }

.rad-ar-price-cards { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
.rad-ar-price-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.25rem; background: #f9fafb; border-radius: 10px;
  border: 2px solid #e5e7eb; transition: all 0.2s; gap: 1rem;
}
.rad-ar-price-card:hover { border-color: #7c2d12; background: #fff; box-shadow: 0 4px 12px rgba(124,45,18,0.1); }
.rad-ar-price-car-info { display: flex; align-items: center; gap: 0.75rem; }
.rad-ar-price-car-name { font-size: 1rem; font-weight: 800; color: #1f2937; }
.rad-ar-price-car-desc { font-size: 0.75rem; color: #6b7280; }
.rad-ar-price-amount { font-size: 1.35rem; font-weight: 800; color: #7c2d12; white-space: nowrap; }

.rad-ar-book-btns { display: flex; gap: 0.75rem; }
.rad-ar-book-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 0.875rem; background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s;
}
.rad-ar-book-btn:hover { background: #1e40af; }
.rad-ar-book-btn-wa {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.875rem; background: #10b981; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s;
}
.rad-ar-book-btn-wa:hover { background: #059669; }

@media (max-width: 900px) {
  .rad-ar-info-bar { grid-template-columns: repeat(2, 1fr); }
  .rad-ar-main { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .rad-ar-info-bar { grid-template-columns: repeat(2, 1fr); }
  .rad-ar-applied-grid { grid-template-columns: 1fr; }
  .rad-ar-book-btns { flex-direction: column; }
}
</style>

<section class="rad-ar-pricing" id="antirust-pricing">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle }}</p>

    <!-- Top Info Bar -->
    <div class="rad-ar-info-bar">
      <div class="rad-ar-info-item">
        <span class="rad-ar-info-icon">🇩🇪</span>
        <div class="rad-ar-info-label">Brand</div>
        <div class="rad-ar-info-value">MIPA Germany</div>
      </div>
      <div class="rad-ar-info-item">
        <span class="rad-ar-info-icon">📅</span>
        <div class="rad-ar-info-label">Durability</div>
        <div class="rad-ar-info-value">{{ section.settings.durability }}</div>
      </div>
      <div class="rad-ar-info-item">
        <span class="rad-ar-info-icon">🛡️</span>
        <div class="rad-ar-info-label">Warranty</div>
        <div class="rad-ar-info-value">{{ section.settings.warranty }}</div>
      </div>
      <div class="rad-ar-info-item">
        <span class="rad-ar-info-icon">🎁</span>
        <div class="rad-ar-info-label">Free Gift</div>
        <div class="rad-ar-info-value">{{ section.settings.free_gift }}</div>
      </div>
    </div>

    <!-- Main 2 col layout -->
    <div class="rad-ar-main">

      <!-- LEFT: Applied on + Benefits -->
      <div class="rad-ar-left-card">
        <div class="rad-ar-left-header">
          <div class="rad-ar-left-header-title">What Gets Protected</div>
          <div class="rad-ar-left-header-sub">Complete undercarriage coverage</div>
        </div>
        <div class="rad-ar-left-body">

          <div class="rad-ar-section-label">Applied On</div>
          <div class="rad-ar-applied-grid">
            <div class="rad-ar-applied-item"><span>🔧</span> Brakes</div>
            <div class="rad-ar-applied-item"><span>🏗️</span> Chassis</div>
            <div class="rad-ar-applied-item"><span>⚙️</span> Undercarriage</div>
            <div class="rad-ar-applied-item"><span>🔩</span> Suspension</div>
          </div>

          <div class="rad-ar-section-label">Benefits</div>
          <div class="rad-ar-benefits-list">
            <div class="rad-ar-benefit-item">Minimizes Road Noise</div>
            <div class="rad-ar-benefit-item">Prevents Rust &amp; Corrosion</div>
            <div class="rad-ar-benefit-item">Offers Heat Resistance</div>
            <div class="rad-ar-benefit-item">Provides Moisture Resistance</div>
            <div class="rad-ar-benefit-item">Protects Against Stone Chips &amp; Dampness</div>
            <div class="rad-ar-benefit-item">Extends the Lifespan of Your Vehicle</div>
          </div>

          <div class="rad-ar-free-tag">
            🎁 FREE with every booking: 1x Professional Exterior Wash
          </div>
        </div>
      </div>

      <!-- RIGHT: Pricing -->
      <div class="rad-ar-right-card">
        <div class="rad-ar-right-header">
          <div class="rad-ar-right-header-title">Select Your Vehicle</div>
          <div class="rad-ar-right-header-sub">Transparent pricing — no hidden charges</div>
        </div>
        <div class="rad-ar-right-body">

          <div class="rad-ar-price-cards">
            <div class="rad-ar-price-card">
              <div class="rad-ar-price-car-info">
                <div>
                  <div class="rad-ar-price-car-name">Hatchback</div>
                  <div class="rad-ar-price-car-desc">Alto, Cultus, Yaris etc.</div>
                </div>
              </div>
              <div class="rad-ar-price-amount">{{ section.settings.price_hatchback }}</div>
            </div>

            <div class="rad-ar-price-card">
              <div class="rad-ar-price-car-info">
                <div>
                  <div class="rad-ar-price-car-name">Sedan</div>
                  <div class="rad-ar-price-car-desc">Civic, Corolla, City etc.</div>
                </div>
              </div>
              <div class="rad-ar-price-amount">{{ section.settings.price_sedan }}</div>
            </div>

            <div class="rad-ar-price-card">
              <div class="rad-ar-price-car-info">
                <div>
                  <div class="rad-ar-price-car-name">SUV</div>
                  <div class="rad-ar-price-car-desc">Sportage, Tucson, Haval etc.</div>
                </div>
              </div>
              <div class="rad-ar-price-amount">{{ section.settings.price_suv }}</div>
            </div>

            <div class="rad-ar-price-card">
              <div class="rad-ar-price-car-info">
                <div>
                  <div class="rad-ar-price-car-name">XL SUV</div>
                  <div class="rad-ar-price-car-desc">Prado, Land Cruiser, Fortuner etc.</div>
                </div>
              </div>
              <div class="rad-ar-price-amount">{{ section.settings.price_xlsuv }}</div>
            </div>
          </div>

          <div class="rad-ar-book-btns">
            <a href="/pages/antirust-booking" class="rad-ar-book-btn">Book My Slot</a>
            <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20book%20Anti-Rust%20Undercoating" target="_blank" class="rad-ar-book-btn-wa">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

