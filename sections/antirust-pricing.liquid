<style>
.rad-ar-pricing { padding: 2rem 0; background: #f3f4f6; }
.rad-ar-pricing-inner { max-width: 860px; margin: 0 auto; }

/* Main card */
.rad-ar-main-card {
  background: #fff; border-radius: 16px; overflow: hidden;
  border: 2px solid #e5e7eb; box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.rad-ar-card-header {
  background: linear-gradient(135deg, #1a0a00 0%, #7c2d12 100%);
  color: #fff; padding: 2rem; text-align: center; position: relative; overflow: hidden;
}
.rad-ar-card-header::before { content: ''; position: absolute; top: -50%; right: -10%; width: 300px; height: 300px; background: rgba(255,255,255,0.05); border-radius: 50%; }
.rad-ar-card-brand { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; color: #fed7aa; margin-bottom: 0.4rem; }
.rad-ar-card-title { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; font-family: 'Nunito Sans', sans-serif; }
.rad-ar-card-sub { font-size: 0.9rem; opacity: 0.8; }

.rad-ar-card-body { padding: 2rem; }

/* Applied on + specs */
.rad-ar-specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.75rem; }
.rad-ar-spec-block { }
.rad-ar-spec-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 0.75rem; }
.rad-ar-applied-list { display: flex; flex-direction: column; gap: 0.4rem; }
.rad-ar-applied-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #1f2937; font-weight: 600; }
.rad-ar-applied-item::before { content: '✓'; color: #10b981; font-weight: 800; }
.rad-ar-spec-badges { display: flex; flex-direction: column; gap: 0.5rem; }
.rad-ar-spec-badge {
  display: flex; align-items: center; gap: 0.5rem;
  background: #f3f4f6; border-radius: 8px; padding: 0.6rem 0.85rem;
  font-size: 0.875rem; font-weight: 700; color: #1f2937;
}
.rad-ar-spec-badge span { font-size: 1rem; }
.rad-ar-free-badge {
  display: flex; align-items: center; gap: 0.5rem;
  background: #f0fdf4; border: 1px solid #bbf7d0;
  border-radius: 8px; padding: 0.6rem 0.85rem;
  font-size: 0.875rem; font-weight: 700; color: #15803d;
}

/* Benefits */
.rad-ar-benefits-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.6rem; margin-bottom: 1.75rem; }
.rad-ar-benefit {
  background: #f9fafb; border-radius: 8px; padding: 0.75rem;
  font-size: 0.8rem; color: #1f2937; font-weight: 600;
  display: flex; align-items: flex-start; gap: 0.4rem; line-height: 1.4;
}
.rad-ar-benefit::before { content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0; }

/* Pricing table */
.rad-ar-price-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 0.75rem; padding-top: 1rem; border-top: 1px solid #e5e7eb; }
.rad-ar-price-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
.rad-ar-price-item {
  background: #f9fafb; border-radius: 10px; padding: 1rem 0.75rem;
  text-align: center; border: 2px solid #e5e7eb; transition: all 0.2s;
}
.rad-ar-price-item:hover { border-color: #7c2d12; box-shadow: 0 4px 12px rgba(124,45,18,0.1); }
.rad-ar-price-vehicle { font-size: 0.75rem; color: #6b7280; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
.rad-ar-price-amount { font-size: 1.15rem; font-weight: 800; color: #7c2d12; }

.rad-ar-book-btns { display: flex; gap: 1rem; }
.rad-ar-book-btn {
  flex: 1; display: block; text-align: center; padding: 0.875rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s;
}
.rad-ar-book-btn:hover { background: #1e40af; }
.rad-ar-book-btn-wa {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.875rem; background: #10b981; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s;
}
.rad-ar-book-btn-wa:hover { background: #059669; }

@media (max-width: 640px) {
  .rad-ar-specs-grid { grid-template-columns: 1fr; }
  .rad-ar-benefits-grid { grid-template-columns: 1fr 1fr; }
  .rad-ar-price-grid { grid-template-columns: repeat(2,1fr); }
  .rad-ar-book-btns { flex-direction: column; }
}
</style>

