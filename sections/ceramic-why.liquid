<style>
.rad-cer-why { padding: 2rem 0; background: #fff; }
.rad-cer-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.rad-cer-why-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; background: linear-gradient(135deg, #1e3a8a, #1e40af); display: flex; align-items: center; justify-content: center; font-size: 6rem; }
.rad-cer-why-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-cer-why-tag { display: inline-block; background: rgba(30,58,138,0.1); color: #1e3a8a; padding: 0.3rem 0.85rem; border-radius: 100px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.75rem; }
.rad-cer-why-title { font-size: 1.85rem; font-weight: 800; color: #1f2937; line-height: 1.2; margin-bottom: 0.75rem; font-family: 'Nunito Sans', sans-serif; }
.rad-cer-why-sub { font-size: 1.1rem; font-weight: 700; color: #1e3a8a; margin-bottom: 1.25rem; }
.rad-cer-why-list { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
.rad-cer-why-item { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.95rem; color: #1f2937; }
.rad-cer-why-item::before { content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0; margin-top: 2px; }
.rad-cer-why-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
.rad-cer-why-btn { display: inline-flex; align-items: center; padding: 0.875rem 1.75rem; background: #1e3a8a; color: #fff; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-cer-why-btn:hover { background: #1e40af; transform: translateY(-1px); }
.rad-cer-why-btn-wa { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: transparent; color: #10b981; border: 2px solid #10b981; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-cer-why-btn-wa:hover { background: #10b981; color: #fff; }
/* Offer banner */
.rad-cer-offer {
  background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
  color: #fff; border-radius: 12px; padding: 1.5rem 2rem;
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; flex-wrap: wrap; margin-top: 2rem;
}
.rad-cer-offer-text h3 { font-size: 1.25rem; font-weight: 800; margin-bottom: 0.25rem; }
.rad-cer-offer-text p { font-size: 0.9rem; opacity: 0.85; }
.rad-cer-offer-badge { background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3); padding: 0.75rem 1.5rem; border-radius: 8px; font-size: 1.5rem; font-weight: 800; white-space: nowrap; text-align: center; }
.rad-cer-offer-btn { display: inline-flex; align-items: center; padding: 0.75rem 1.5rem; background: #fff; color: #1e3a8a; border-radius: 8px; font-weight: 700; font-size: 0.95rem; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
.rad-cer-offer-btn:hover { background: #f3f4f6; }
@media (max-width: 768px) { .rad-cer-why-grid { grid-template-columns: 1fr; } .rad-cer-why-title { font-size: 1.5rem; } }
</style>

<section class="rad-cer-why">
  <div class="container">
    <div class="rad-cer-why-grid">
      <div class="rad-cer-why-img">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Why Ceramic Coating" loading="lazy">
        {%- else -%}
          ✨
        {%- endif -%}
      </div>
      <div>
        <span class="rad-cer-why-tag">{{ section.settings.tag }}</span>
        <h2 class="rad-cer-why-title">{{ section.settings.title }}</h2>
        <p class="rad-cer-why-sub">The smartest investment for your car in Karachi's harsh climate</p>
        <ul class="rad-cer-why-list">
          <li class="rad-cer-why-item">Gives your car a glossy, showroom look</li>
          <li class="rad-cer-why-item">Shields paint from dirt, scratches, and UV rays for years</li>
          <li class="rad-cer-why-item">Easy to clean — dirt and water slide right off</li>
          <li class="rad-cer-why-item">Protect from Dust, Sun damage &amp; bird droppings</li>
          <li class="rad-cer-why-item">Long-lasting protection with GYEON certified products</li>
        </ul>
        <div class="rad-cer-why-btns">
          <a href="/pages/ceramic-booking" class="rad-cer-why-btn">Book Your Slot</a>
          <a href="https://wa.me/923357231111" target="_blank" class="rad-cer-why-btn-wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Get Free Estimate
          </a>
        </div>
      </div>
    </div>

    <!-- Offer Banner -->
    <div class="rad-cer-offer">
      <div class="rad-cer-offer-text">
        <h3>Protect Your Investment with Ceramic Coating</h3>
        <p>Limited time offer — book now and save!</p>
      </div>
      <div class="rad-cer-offer-badge">{{ section.settings.offer_badge }}</div>
      <a href="{{ section.settings.offer_url }}" class="rad-cer-offer-btn">Get Offer →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ceramic Why Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "Why Ceramic Coating?"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "It keeps your car paint protected & shiny while saving money on maintenance!"
    },
    {
      "type": "header",
      "content": "Offer Banner"
    },
    {
      "type": "text",
      "id": "offer_title",
      "label": "Offer Title",
      "default": "Protect Your Investment with Ceramic Coating"
    },
    {
      "type": "text",
      "id": "offer_text",
      "label": "Offer Text",
      "default": "Limited time offer — book now and save!"
    },
    {
      "type": "text",
      "id": "offer_badge",
      "label": "Offer Badge",
      "default": "10% Off!"
    },
    {
      "type": "url",
      "id": "offer_url",
      "label": "Offer Button Link"
    }
  ],
  "presets": [
    {
      "name": "Ceramic Why Section"
    }
  ]
}
{% endschema %}