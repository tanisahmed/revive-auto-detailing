<style>
.rad-services { padding: 5rem 0; background: #fff; }
.rad-services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.rad-svc-card {
  border: 1px solid #d1d5db;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.25s;
  background: #fff;
  display: flex;
  flex-direction: column;
}
.rad-svc-card:hover {
  box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  transform: translateY(-4px);
  border-color: #1e3a8a;
}
.rad-svc-img {
  height: 200px;
  overflow: hidden;
  position: relative;
  background: #f3f4f6;
}
.rad-svc-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.rad-svc-card:hover .rad-svc-img img { transform: scale(1.05); }
.rad-svc-img-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
  font-size: 3.5rem;
}
.rad-svc-body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.75rem;
}
.rad-svc-name { font-size: 1rem; font-weight: 700; color: #1f2937; line-height: 1.3; }
.rad-svc-desc { font-size: 0.875rem; color: #6b7280; line-height: 1.6; flex: 1; }
.rad-svc-btn {
  display: block; text-align: center; padding: 0.7rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.9rem; text-decoration: none;
  transition: background 0.2s; margin-top: auto;
}
.rad-svc-btn:hover { background: #1e40af; }
.rad-svc-btn-disabled {
  display: block; text-align: center; padding: 0.7rem;
  background: #d1d5db; color: #6b7280; border-radius: 8px;
  font-weight: 700; font-size: 0.9rem; cursor: not-allowed; margin-top: auto;
}
.rad-services-cta { text-align: center; }
.rad-btn-outline {
  display: inline-flex; align-items: center; padding: 0.875rem 1.75rem;
  background: transparent; color: #1e3a8a; border: 2px solid #1e3a8a;
  border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none;
  transition: all 0.2s;
}
.rad-btn-outline:hover { background: #1e3a8a; color: #fff; }
@media (max-width: 1024px) { .rad-services-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 640px) {
  .rad-services { padding: 3rem 0; }
  .rad-services-grid { grid-template-columns: 1fr; gap: 1rem; }
  .rad-svc-img { height: 180px; }
}
</style>

<section class="rad-services">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title | default: 'What We Offer' }}</h2>
    <div class="divider-with-text"><span>{{ section.settings.subtitle | default: 'Premium Auto Care Services' }}</span></div>
    <div class="rad-services-grid">

      <!-- Card 1 -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_1 != blank -%}
            <img src="{{ section.settings.img_1 | image_url: width: 600 }}" alt="{{ section.settings.name_1 }}" loading="lazy">
          {%- else -%}
            <div class="rad-svc-img-fallback">&#128737;</div>
          {%- endif -%}
        </div>
        <div class="rad-svc-body">
          <h3 class="rad-svc-name">{{ section.settings.name_1 | default: 'Paint Protection Film (PPF)' }}</h3>
          <p class="rad-svc-desc">{{ section.settings.desc_1 | default: 'Our PPF keeps your car brand new by shielding it from scratches, chips, and UV damage.' }}</p>
          {%- if section.settings.btn_active_1 -%}
            <a href="{{ section.settings.btn_url_1 }}" class="rad-svc-btn">{{ section.settings.btn_label_1 | default: 'View Pricing' }}</a>
          {%- else -%}
            <span class="rad-svc-btn-disabled">{{ section.settings.btn_label_1 | default: 'Coming Soon' }}</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Card 2 -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_2 != blank -%}
            <img src="{{ section.settings.img_2 | image_url: width: 600 }}" alt="{{ section.settings.name_2 }}" loading="lazy">
          {%- else -%}
            <div class="rad-svc-img-fallback">&#10024;</div>
          {%- endif -%}
        </div>
        <div class="rad-svc-body">
          <h3 class="rad-svc-name">{{ section.settings.name_2 | default: 'Ceramic Coating' }}</h3>
          <p class="rad-svc-desc">{{ section.settings.desc_2 | default: 'Give long-lasting shine and protection. Defends your car from scratches, dirt, and UV rays!' }}</p>
          {%- if section.settings.btn_active_2 -%}
            <a href="{{ section.settings.btn_url_2 }}" class="rad-svc-btn">{{ section.settings.btn_label_2 | default: 'View Pricing' }}</a>
          {%- else -%}
            <span class="rad-svc-btn-disabled">{{ section.settings.btn_label_2 | default: 'Coming Soon' }}</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Card 3 -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_3 != blank -%}
            <img src="{{ section.settings.img_3 | image_url: width: 600 }}" alt="{{ section.settings.name_3 }}" loading="lazy">
          {%- else -%}
            <div class="rad-svc-img-fallback">&#128663;</div>
          {%- endif -%}
        </div>
        <div class="rad-svc-body">
          <h3 class="rad-svc-name">{{ section.settings.name_3 | default: 'Exterior & Interior Detailing' }}</h3>
          <p class="rad-svc-desc">{{ section.settings.desc_3 | default: 'Full interior and exterior detailing to restore your car\'s showroom finish.' }}</p>
          {%- if section.settings.btn_active_3 -%}
            <a href="{{ section.settings.btn_url_3 }}" class="rad-svc-btn">{{ section.settings.btn_label_3 | default: 'View Pricing' }}</a>
          {%- else -%}
            <span class="rad-svc-btn-disabled">{{ section.settings.btn_label_3 | default: 'Coming Soon' }}</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Card 4 -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_4 != blank -%}
            <img src="{{ section.settings.img_4 | image_url: width: 600 }}" alt="{{ section.settings.name_4 }}" loading="lazy">
          {%- else -%}
            <div class="rad-svc-img-fallback">&#128274;</div>
          {%- endif -%}
        </div>
        <div class="rad-svc-body">
          <h3 class="rad-svc-name">{{ section.settings.name_4 | default: 'Anti-Rust Undercoating' }}</h3>
          <p class="rad-svc-desc">{{ section.settings.desc_4 | default: 'Guard your car against rust with our anti-rust undercoating for long-lasting protection.' }}</p>
          {%- if section.settings.btn_active_4 -%}
            <a href="{{ section.settings.btn_url_4 }}" class="rad-svc-btn">{{ section.settings.btn_label_4 | default: 'View Pricing' }}</a>
          {%- else -%}
            <span class="rad-svc-btn-disabled">{{ section.settings.btn_label_4 | default: 'Coming Soon' }}</span>
          {%- endif -%}
        </div>
      </div>

    </div>
    <div class="rad-services-cta">
      <a href="{{ section.settings.cta_url | default: '/pages/paint-protection-film' }}" class="rad-btn-outline">
        {{ section.settings.cta_label | default: 'View All Services' }}
      </a>
    </div>
  </div>
</section>

