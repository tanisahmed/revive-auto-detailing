<style>
  .services-section {
    padding: 5rem 0;
    background: var(--color-white);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .service-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--color-primary);
  }

  .service-icon-area {
    height: 180px;
    background: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .service-icon-area::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30,58,138,0.05) 0%, transparent 60%);
  }

  .service-icon-emoji {
    font-size: 4.5rem;
    line-height: 1;
    transition: var(--transition);
  }
  .service-card:hover .service-icon-emoji { transform: scale(1.1); }

  .service-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }

  .service-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .service-description {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
    flex: 1;
  }

  .service-btn {
    display: block;
    text-align: center;
    padding: 0.7rem;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--border-radius);
    font-weight: 700;
    font-size: 0.9rem;
    transition: var(--transition);
    border: none;
    cursor: pointer;
    width: 100%;
    text-decoration: none;
    margin-top: auto;
  }
  .service-btn:hover:not(:disabled) {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }
  .service-btn:disabled, .service-btn.disabled {
    background: var(--color-border);
    color: var(--color-text-light);
    cursor: not-allowed;
    transform: none;
  }

  .services-cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .services-section { padding: 3.5rem 0; }
    .services-grid { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>

<section class="services-section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title | default: 'What We Offer' }}</h2>
    <div class="divider-with-text">
      <span>{{ section.settings.subtitle | default: 'Premium Auto Care Services' }}</span>
    </div>

    <div class="services-grid">
      <!-- PPF Card -->
      <div class="service-card">
        <div class="service-icon-area">
          <span class="service-icon-emoji">🛡️</span>
        </div>
        <div class="service-body">
          <h3 class="service-name">Paint Protection Film (PPF)</h3>
          <p class="service-description">Our PPF keeps your car brand new by shielding it from scratches, chips, and UV damage.</p>
          <a href="/pages/paint-protection-film" class="service-btn">View Pricing</a>
        </div>
      </div>

      <!-- Ceramic Coating Card -->
      <div class="service-card">
        <div class="service-icon-area">
          <span class="service-icon-emoji">✨</span>
        </div>
        <div class="service-body">
          <h3 class="service-name">Ceramic Coating</h3>
          <p class="service-description">Give long-lasting shine and protection. Defends your car from scratches, dirt, and UV rays!</p>
          <button class="service-btn disabled" disabled>Coming Soon</button>
        </div>
      </div>

      <!-- Detailing Card -->
      <div class="service-card">
        <div class="service-icon-area">
          <span class="service-icon-emoji">🚗</span>
        </div>
        <div class="service-body">
          <h3 class="service-name">Exterior & Interior Detailing</h3>
          <p class="service-description">Give long-lasting shine and protection. Defends your car from scratches, dirt, and UV rays!</p>
          <button class="service-btn disabled" disabled>Coming Soon</button>
        </div>
      </div>

      <!-- Anti-Rust Card -->
      <div class="service-card">
        <div class="service-icon-area">
          <span class="service-icon-emoji">🔒</span>
        </div>
        <div class="service-body">
          <h3 class="service-name">Anti-Rust Undercoating</h3>
          <p class="service-description">Guard your car against rust with our anti-rust undercoating for long-lasting protection.</p>
          <button class="service-btn disabled" disabled>Coming Soon</button>
        </div>
      </div>
    </div>

    <div class="services-cta">
      <a href="/pages/paint-protection-film" class="btn btn-outline">
        View All Services →
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "What We Offer"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium Auto Care Services"
    }
  ],
  "presets": [
    {
      "name": "Services"
    }
  ]
}
{% endschema %}
