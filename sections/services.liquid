<style>
.rad-services { padding: 3rem 0; background: #fff; }
.rad-services-title { font-size: 2.25rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; font-family: 'Nunito Sans', sans-serif; }
.rad-services-sub { text-align: center; color: #6b7280; margin-bottom: 2.5rem; font-size: 1.05rem; }
.rad-svc-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.25rem; margin-bottom: 2.5rem; }
.rad-svc-card {
  border-radius: 12px; overflow: hidden; border: 2px solid #e5e7eb;
  background: #fff; transition: all 0.25s; display: flex; flex-direction: column;
}
.rad-svc-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.12); transform: translateY(-4px); border-color: #1e3a8a; }
.rad-svc-img {
  height: 180px; background: linear-gradient(135deg, #0f172a, #1e3a8a);
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem; overflow: hidden; position: relative;
}
.rad-svc-img img { width: 100%; height: 100%; object-fit: cover; }
.rad-svc-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
.rad-svc-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
.rad-svc-name { font-size: 1.05rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; font-family: 'Nunito Sans', sans-serif; }
.rad-svc-desc { font-size: 0.85rem; color: #6b7280; line-height: 1.6; margin-bottom: 1rem; flex: 1; }
.rad-svc-btn {
  display: block; text-align: center; padding: 0.65rem 1rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.875rem; text-decoration: none; transition: all 0.2s;
}
.rad-svc-btn:hover { background: #1e40af; }
.rad-svc-cta { text-align: center; }
.rad-svc-cta-btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.875rem 2.5rem; background: transparent;
  color: #1e3a8a; border: 2px solid #1e3a8a; border-radius: 8px;
  font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s;
}
.rad-svc-cta-btn:hover { background: #1e3a8a; color: #fff; }
@media (max-width: 1024px) { .rad-svc-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 480px) { .rad-svc-grid { grid-template-columns: 1fr; } .rad-services-title { font-size: 1.6rem; } }
</style>

<section class="rad-services">
  <div class="container">
    <h2 class="rad-services-title">{{ section.settings.title }}</h2>
    <p class="rad-services-sub">{{ section.settings.subtitle }}</p>

    <div class="rad-svc-grid">
      <!-- PPF -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_1 != blank -%}
            <img src="{{ section.settings.img_1 | image_url: width: 500 }}" alt="{{ section.settings.name_1 }}">
          {%- else -%}🛡️{%- endif -%}
        </div>
        <div class="rad-svc-body">
          <div class="rad-svc-name">{{ section.settings.name_1 }}</div>
          <p class="rad-svc-desc">{{ section.settings.desc_1 }}</p>
          <a href="{{ section.settings.url_1 }}" class="rad-svc-btn">{{ section.settings.btn_1 }}</a>
        </div>
      </div>
      <!-- Ceramic -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_2 != blank -%}
            <img src="{{ section.settings.img_2 | image_url: width: 500 }}" alt="{{ section.settings.name_2 }}">
          {%- else -%}✨{%- endif -%}
        </div>
        <div class="rad-svc-body">
          <div class="rad-svc-name">{{ section.settings.name_2 }}</div>
          <p class="rad-svc-desc">{{ section.settings.desc_2 }}</p>
          <a href="{{ section.settings.url_2 }}" class="rad-svc-btn">{{ section.settings.btn_2 }}</a>
        </div>
      </div>
      <!-- Detailing -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_3 != blank -%}
            <img src="{{ section.settings.img_3 | image_url: width: 500 }}" alt="{{ section.settings.name_3 }}">
          {%- else -%}🚗{%- endif -%}
        </div>
        <div class="rad-svc-body">
          <div class="rad-svc-name">{{ section.settings.name_3 }}</div>
          <p class="rad-svc-desc">{{ section.settings.desc_3 }}</p>
          <a href="{{ section.settings.url_3 }}" class="rad-svc-btn">{{ section.settings.btn_3 }}</a>
        </div>
      </div>
      <!-- Window Tint -->
      <div class="rad-svc-card">
        <div class="rad-svc-img">
          {%- if section.settings.img_4 != blank -%}
            <img src="{{ section.settings.img_4 | image_url: width: 500 }}" alt="{{ section.settings.name_4 }}">
          {%- else -%}🌑{%- endif -%}
        </div>
        <div class="rad-svc-body">
          <div class="rad-svc-name">{{ section.settings.name_4 }}</div>
          <p class="rad-svc-desc">{{ section.settings.desc_4 }}</p>
          <a href="{{ section.settings.url_4 }}" class="rad-svc-btn">{{ section.settings.btn_4 }}</a>
        </div>
      </div>
    </div>

    <div class="rad-svc-cta">
      <a href="/pages/all-services" class="rad-svc-cta-btn">View All Services →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "settings": [
    {"type": "text", "id": "title", "label": "Section Title", "default": "Our Services"},
    {"type": "text", "id": "subtitle", "label": "Subtitle", "default": "Premium auto care services in Karachi"},
    {"type": "header", "content": "Service 1 — PPF"},
    {"type": "image_picker", "id": "img_1", "label": "Image"},
    {"type": "text", "id": "name_1", "label": "Name", "default": "Paint Protection Film (PPF)"},
    {"type": "textarea", "id": "desc_1", "label": "Description", "default": "Invisible shield that protects your car's paint from scratches, chips and UV damage."},
    {"type": "url", "id": "url_1", "label": "Link"},
    {"type": "text", "id": "btn_1", "label": "Button Text", "default": "View Pricing"},
    {"type": "header", "content": "Service 2 — Ceramic"},
    {"type": "image_picker", "id": "img_2", "label": "Image"},
    {"type": "text", "id": "name_2", "label": "Name", "default": "Ceramic Coating"},
    {"type": "textarea", "id": "desc_2", "label": "Description", "default": "Long-lasting glossy finish that repels dirt, UV rays and minor scratches."},
    {"type": "url", "id": "url_2", "label": "Link"},
    {"type": "text", "id": "btn_2", "label": "Button Text", "default": "View Pricing"},
    {"type": "header", "content": "Service 3 — Detailing"},
    {"type": "image_picker", "id": "img_3", "label": "Image"},
    {"type": "text", "id": "name_3", "label": "Name", "default": "Exterior & Interior Detailing"},
    {"type": "textarea", "id": "desc_3", "label": "Description", "default": "Full interior and exterior detailing to restore your car's showroom finish."},
    {"type": "url", "id": "url_3", "label": "Link"},
    {"type": "text", "id": "btn_3", "label": "Button Text", "default": "View Pricing"},
    {"type": "header", "content": "Service 4 — Window Tint"},
    {"type": "image_picker", "id": "img_4", "label": "Image"},
    {"type": "text", "id": "name_4", "label": "Name", "default": "Car Window Tinting"},
    {"type": "textarea", "id": "desc_4", "label": "Description", "default": "NAR certified heat control window film — blocks UV rays and keeps your car cool."},
    {"type": "url", "id": "url_4", "label": "Link"},
    {"type": "text", "id": "btn_4", "label": "Button Text", "default": "View Pricing"}
  ],
  "presets": [{"name": "Services"}]
}
{% endschema %}
