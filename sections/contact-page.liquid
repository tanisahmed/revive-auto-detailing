<style>
.rad-contact { font-family: 'Nunito Sans', sans-serif; }
.rad-contact-hero { background: linear-gradient(135deg, #0f172a, #1e3a8a); padding: 4rem 0 3rem; text-align: center; color: #fff; }
.rad-contact-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
.rad-contact-hero p { color: #cbd5e1; font-size: 1rem; }

.rad-contact-body { padding: 3.5rem 0; background: #f8fafc; }
.rad-contact-body-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr 1.4fr; gap: 2.5rem; }

/* Info */
.rad-contact-info h2 { font-size: 1.5rem; font-weight: 800; color: #1f2937; margin-bottom: 0.5rem; }
.rad-contact-info > p { font-size: 0.9rem; color: #6b7280; line-height: 1.7; margin-bottom: 1.75rem; }
.rad-contact-item { display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.25rem; }
.rad-contact-item-icon { width: 42px; height: 42px; border-radius: 10px; background: #dbeafe; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
.rad-contact-item-text h4 { font-size: 0.85rem; font-weight: 700; color: #1f2937; margin-bottom: 0.15rem; }
.rad-contact-item-text p, .rad-contact-item-text a { font-size: 0.875rem; color: #6b7280; text-decoration: none; line-height: 1.5; }
.rad-contact-item-text a:hover { color: #1e3a8a; }
.rad-contact-hours { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.25rem; margin-top: 1.5rem; }
.rad-contact-hours h4 { font-size: 0.85rem; font-weight: 700; color: #1f2937; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e5e7eb; }
.rad-hours-row { display: flex; justify-content: space-between; font-size: 0.85rem; padding: 0.25rem 0; color: #4b5563; }
.rad-hours-row span:last-child { font-weight: 600; color: #1e3a8a; }

/* Form */
.rad-contact-form-wrap { background: #fff; border-radius: 14px; padding: 2rem; border: 1px solid #e5e7eb; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
.rad-contact-form-wrap h3 { font-size: 1.25rem; font-weight: 800; color: #1f2937; margin-bottom: 0.35rem; }
.rad-contact-form-wrap > p { font-size: 0.875rem; color: #6b7280; margin-bottom: 1.5rem; }
.rad-cf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.rad-cf-group { margin-bottom: 1rem; }
.rad-cf-label { display: block; font-size: 0.875rem; font-weight: 600; color: #1f2937; margin-bottom: 0.35rem; }
.rad-cf-input, .rad-cf-select, .rad-cf-textarea { width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 8px; font-size: 0.9rem; font-family: 'Nunito Sans', sans-serif; color: #1f2937; background: #fff; outline: none; transition: border 0.2s; box-sizing: border-box; }
.rad-cf-input:focus, .rad-cf-select:focus, .rad-cf-textarea:focus { border-color: #1e3a8a; box-shadow: 0 0 0 3px rgba(30,58,138,0.08); }
.rad-cf-textarea { resize: vertical; min-height: 110px; }
.rad-cf-btn { width: 100%; padding: 0.9rem; background: #1e3a8a; color: #fff; border: none; border-radius: 8px; font-family: 'Nunito Sans', sans-serif; font-weight: 700; font-size: 1rem; cursor: pointer; transition: background 0.2s; margin-top: 0.5rem; }
.rad-cf-btn:hover { background: #1e40af; }
.rad-cf-success { display: none; text-align: center; padding: 1.5rem; }
.rad-cf-success.show { display: block; }
.rad-cf-success-icon { font-size: 3rem; display: block; margin-bottom: 0.75rem; }
.rad-cf-success h4 { font-size: 1.1rem; font-weight: 700; color: #1f2937; margin-bottom: 0.35rem; }
.rad-cf-success p { font-size: 0.875rem; color: #6b7280; }

/* Map placeholder */
.rad-contact-map { padding: 0 0 3.5rem; background: #f8fafc; }
.rad-contact-map-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }
.rad-map-box { background: linear-gradient(135deg, #1e3a8a, #0f172a); border-radius: 14px; height: 280px; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.75rem; color: #fff; }
.rad-map-box h3 { font-size: 1.2rem; font-weight: 700; }
.rad-map-box p { font-size: 0.9rem; color: #93c5fd; }
.rad-map-btn { padding: 0.65rem 1.5rem; background: #fff; color: #1e3a8a; border-radius: 8px; font-weight: 700; font-size: 0.9rem; text-decoration: none; margin-top: 0.25rem; }

/* WA Float style */
.rad-contact-wa-banner { background: #10b981; padding: 1rem; text-align: center; }
.rad-contact-wa-banner a { color: #fff; font-weight: 700; text-decoration: none; font-size: 0.95rem; }

@media (max-width: 768px) {
  .rad-contact-body-inner { grid-template-columns: 1fr; }
  .rad-cf-row { grid-template-columns: 1fr; }
  .rad-contact-hero h1 { font-size: 1.75rem; }
}
</style>

<div class="rad-contact">

  <div class="rad-contact-hero">
    <h1>Get in Touch</h1>
    <p>We'd love to hear from you. Book a service or ask us anything.</p>
  </div>

  <div class="rad-contact-wa-banner">
    <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20enquire%20about%20your%20services" target="_blank">💬 Fastest response on WhatsApp — Chat with us now →</a>
  </div>

  <div class="rad-contact-body">
    <div class="rad-contact-body-inner">

      <div class="rad-contact-info">
        <h2>Contact Information</h2>
        <p>Visit us at our studio in Karachi or reach out through any of the channels below.</p>
        <div class="rad-contact-item">
          <div class="rad-contact-item-icon">📍</div>
          <div class="rad-contact-item-text"><h4>Location</h4><p>Karachi, Pakistan</p></div>
        </div>
        <div class="rad-contact-item">
          <div class="rad-contact-item-icon">📞</div>
          <div class="rad-contact-item-text"><h4>Phone / WhatsApp</h4><a href="tel:+923037231111">+92 303 7231111</a></div>
        </div>
        <div class="rad-contact-item">
          <div class="rad-contact-item-icon">📧</div>
          <div class="rad-contact-item-text"><h4>Email</h4><a href="mailto:info@reviveautodetailing.pk">info@reviveautodetailing.pk</a></div>
        </div>
        <div class="rad-contact-item">
          <div class="rad-contact-item-icon">🌐</div>
          <div class="rad-contact-item-text"><h4>Website</h4><a href="https://www.reviveautodetailing.pk">reviveautodetailing.pk</a></div>
        </div>
        <div class="rad-contact-hours">
          <h4>Business Hours</h4>
          <div class="rad-hours-row"><span>Monday – Saturday</span><span>10:00 AM – 7:00 PM</span></div>
          <div class="rad-hours-row"><span>Sunday</span><span>11:00 AM – 5:00 PM</span></div>
          <div class="rad-hours-row"><span>Appointments</span><span>Preferred</span></div>
        </div>
      </div>

      <div class="rad-contact-form-wrap">
        <div id="rad-cf-form-body">
          <h3>Send Us a Message</h3>
          <p>Fill in the form and we'll get back to you within a few hours.</p>
          <div class="rad-cf-row">
            <div class="rad-cf-group">
              <label class="rad-cf-label">Your Name *</label>
              <input type="text" id="cf-name" class="rad-cf-input" placeholder="Ahmed Khan">
            </div>
            <div class="rad-cf-group">
              <label class="rad-cf-label">Phone / WhatsApp *</label>
              <input type="tel" id="cf-phone" class="rad-cf-input" placeholder="+92 3XX XXXXXXX">
            </div>
          </div>
          <div class="rad-cf-group">
            <label class="rad-cf-label">Email Address</label>
            <input type="email" id="cf-email" class="rad-cf-input" placeholder="you@example.com">
          </div>
          <div class="rad-cf-group">
            <label class="rad-cf-label">Service Interested In</label>
            <select id="cf-service" class="rad-cf-select">
              <option value="" disabled selected>Select a service</option>
              <option>Paint Protection Film (PPF)</option>
              <option>Ceramic Coating</option>
              <option>Exterior & Interior Detailing</option>
              <option>Car Window Tinting</option>
              <option>Anti-Rust Undercoating</option>
              <option>General Enquiry</option>
            </select>
          </div>
          <div class="rad-cf-group">
            <label class="rad-cf-label">Your Message</label>
            <textarea id="cf-msg" class="rad-cf-textarea" placeholder="Tell us about your car or ask any questions..."></textarea>
          </div>
          <button class="rad-cf-btn" onclick="cfSubmit()">Send Message →</button>
        </div>
        <div class="rad-cf-success" id="rad-cf-success">
          <span class="rad-cf-success-icon">✅</span>
          <h4>Message Sent!</h4>
          <p>We'll get back to you on WhatsApp or email within a few hours.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="rad-contact-map">
    <div class="rad-contact-map-inner">
      <div class="rad-map-box">
        <h3>📍 Find Us in Karachi</h3>
        <p>Karachi, Pakistan</p>
        <a href="https://www.google.com/maps/search/Revive+Auto+Detailing+Karachi" target="_blank" class="rad-map-btn">Open in Google Maps →</a>
      </div>
    </div>
  </div>
</div>

<script>
function cfSubmit() {
  var name = document.getElementById('cf-name').value.trim();
  var phone = document.getElementById('cf-phone').value.trim();
  if(!name || !phone) { alert('Please enter your name and phone number.'); return; }
  fetch('https://formspree.io/f/xgoqpjvk', {
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
    body: JSON.stringify({
      _subject: 'Contact Form: ' + name,
      name: name, phone: phone,
      email: document.getElementById('cf-email').value,
      service: document.getElementById('cf-service').value,
      message: document.getElementById('cf-msg').value
    })
  }).catch(function(){});
  document.getElementById('rad-cf-form-body').style.display = 'none';
  document.getElementById('rad-cf-success').classList.add('show');
}
</script>

