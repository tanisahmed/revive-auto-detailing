<style>
  .booking-section {
    padding: 4rem 0 6rem;
    background: var(--color-white);
  }

  .booking-wrapper {
    max-width: 600px;
    margin: 0 auto;
  }

  /* Progress Bar */
  .booking-progress {
    margin-bottom: 2.5rem;
  }
  .progress-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }
  .progress-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-light);
  }
  .progress-step-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .progress-bar-track {
    height: 6px;
    background: var(--color-border);
    border-radius: 100px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 100px;
    transition: width 0.4s ease;
  }

  /* Step Indicators */
  .step-indicators {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .step-indicators::before {
    content: '';
    position: absolute;
    top: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    width: 75%;
    height: 2px;
    background: var(--color-border);
    z-index: 0;
  }
  .step-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }
  .step-dot {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 800;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    color: var(--color-text-light);
    transition: var(--transition);
  }
  .step-indicator.active .step-dot {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  .step-indicator.completed .step-dot {
    background: var(--color-success);
    border-color: var(--color-success);
    color: white;
  }
  .step-dot-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-light);
    text-align: center;
    white-space: nowrap;
  }
  .step-indicator.active .step-dot-label { color: var(--color-primary); }
  .step-indicator.completed .step-dot-label { color: var(--color-success); }

  /* Form Container */
  .booking-form-container {
    background: var(--color-secondary);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
  }

  .booking-step {
    display: none;
  }
  .booking-step.active { display: block; }

  .booking-step-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }
  .booking-step-desc {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.75rem;
  }

  /* Time slots */
  .time-slots {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-top: 0.4rem;
  }
  .time-slot {
    padding: 0.6rem;
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    text-align: center;
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    background: var(--color-white);
    transition: var(--transition);
    color: var(--color-text);
  }
  .time-slot:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .time-slot.selected {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  .time-slot-error { display: none; }
  .time-slot-error.visible { display: block; }

  /* Package radio */
  .package-radio-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .package-radio-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    cursor: pointer;
    transition: var(--transition);
  }
  .package-radio-option:hover { border-color: var(--color-primary); }
  .package-radio-option.selected {
    border-color: var(--color-primary);
    background: rgba(30,58,138,0.04);
  }
  .package-radio-option input[type="radio"] { display: none; }
  .package-radio-dot {
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid var(--color-border);
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }
  .package-radio-option.selected .package-radio-dot {
    border-color: var(--color-primary);
    background: var(--color-primary);
  }
  .package-radio-option.selected .package-radio-dot::after {
    content: '';
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
  }
  .package-radio-info { flex: 1; }
  .package-radio-name { font-weight: 700; font-size: 0.95rem; color: var(--color-text); }
  .package-radio-price { font-size: 0.875rem; color: var(--color-primary); font-weight: 700; }

  /* Price display */
  .price-display {
    background: rgba(30,58,138,0.08);
    border: 1px solid rgba(30,58,138,0.2);
    border-radius: var(--border-radius);
    padding: 1rem 1.25rem;
    margin-top: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .price-display-label { font-weight: 600; font-size: 0.9rem; color: var(--color-text-light); }
  .price-display-value { font-size: 1.35rem; font-weight: 800; color: var(--color-primary); }

  /* Review Step */
  .review-section-block {
    background: var(--color-white);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .review-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .review-section-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .review-edit-btn {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    cursor: pointer;
    background: none;
    border: none;
    font-family: var(--font-primary);
    transition: var(--transition);
  }
  .review-edit-btn:hover { color: var(--color-primary-hover); text-decoration: underline; }
  .review-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    padding: 0.25rem 0;
  }
  .review-row .r-label { color: var(--color-text-light); }
  .review-row .r-value { font-weight: 600; color: var(--color-text); text-align: right; }

  .review-total {
    background: var(--color-primary);
    color: white;
    border-radius: var(--border-radius);
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .review-total-label { font-size: 1rem; font-weight: 700; }
  .review-total-price { font-size: 1.5rem; font-weight: 800; }

  .terms-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    cursor: pointer;
  }
  .terms-checkbox input { width: 1.1rem; height: 1.1rem; margin-top: 2px; cursor: pointer; flex-shrink: 0; accent-color: var(--color-primary); }
  .terms-checkbox span { font-size: 0.875rem; color: var(--color-text-light); line-height: 1.5; }
  .terms-checkbox a { color: var(--color-primary); font-weight: 600; }

  /* Navigation Buttons */
  .booking-nav {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .btn-back {
    flex: 0.4;
    padding: 0.875rem;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-back:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .btn-back:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-next {
    flex: 1;
    padding: 0.875rem;
    background: var(--color-primary);
    border: 2px solid var(--color-primary);
    border-radius: var(--border-radius);
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 1rem;
    color: white;
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-next:hover { background: var(--color-primary-hover); }

  /* Success Screen */
  .booking-success {
    display: none;
    text-align: center;
    padding: 1rem;
  }
  .booking-success.visible { display: block; }
  .success-big-icon { font-size: 4rem; margin-bottom: 1rem; display: block; }
  .success-headline { font-size: 2rem; font-weight: 800; color: var(--color-text); margin-bottom: 0.5rem; }
  .success-sub { font-size: 1rem; color: var(--color-text-light); margin-bottom: 2rem; }
  .success-ref {
    background: var(--color-secondary);
    border-radius: var(--border-radius-lg);
    padding: 1.5rem;
    text-align: left;
    margin-bottom: 2rem;
  }
  .success-ref-title { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); font-weight: 700; margin-bottom: 1rem; }
  .success-ref-row { display: flex; justify-content: space-between; padding: 0.4rem 0; font-size: 0.9rem; border-bottom: 1px solid var(--color-border); }
  .success-ref-row:last-child { border-bottom: none; }
  .success-ref-row .s-label { color: var(--color-text-light); }
  .success-ref-row .s-value { font-weight: 700; color: var(--color-text); }
  .success-ref-row .s-price { font-weight: 800; color: var(--color-primary); font-size: 1.1rem; }
  .success-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 640px) {
    .booking-section { padding: 2.5rem 0 4rem; }
    .booking-form-container { padding: 1.5rem 1.25rem; }
    .time-slots { grid-template-columns: repeat(2, 1fr); }
    .booking-nav { flex-direction: column-reverse; }
    .btn-back, .btn-next { flex: auto; }
    .step-dot-label { display: none; }
  }
</style>

<section class="booking-section">
  <div class="container">
    <div class="booking-wrapper">

      <!-- Header -->
      <div style="text-align:center;margin-bottom:2rem;">
        <h1 style="font-size:2rem;font-weight:800;margin-bottom:0.4rem;">Book Your PPF Installation</h1>
        <p style="color:var(--color-text-light);">Complete the form below to reserve your slot</p>
      </div>

      <!-- Progress -->
      <div class="booking-progress">
        <div class="progress-label">
          <span class="progress-text" id="progress-text">Step 1 of 4</span>
          <span class="progress-step-name" id="progress-step-name">Personal Information</span>
        </div>
        <div class="progress-bar-track">
          <div class="progress-bar-fill" id="progress-bar" style="width:25%;"></div>
        </div>
      </div>

      <!-- Step Indicators -->
      <div class="step-indicators">
        <div class="step-indicator active" data-step="1">
          <div class="step-dot">1</div>
          <span class="step-dot-label">Personal</span>
        </div>
        <div class="step-indicator" data-step="2">
          <div class="step-dot">2</div>
          <span class="step-dot-label">Vehicle</span>
        </div>
        <div class="step-indicator" data-step="3">
          <div class="step-dot">3</div>
          <span class="step-dot-label">Appointment</span>
        </div>
        <div class="step-indicator" data-step="4">
          <div class="step-dot">4</div>
          <span class="step-dot-label">Confirm</span>
        </div>
      </div>

      <!-- Form Container -->
      <div class="booking-form-container" id="booking-form-container">

        <!-- STEP 1: Personal Info -->
        <div class="booking-step active" id="step-1">
          <h2 class="booking-step-title">Your Details</h2>
          <p class="booking-step-desc">We'll use this to confirm your booking via WhatsApp and email.</p>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="b-first-name">First Name <span class="required">*</span></label>
              <input type="text" id="b-first-name" class="form-input" placeholder="Ahmed" required autocomplete="given-name">
              <div class="form-error" id="err-first-name">Enter your first name</div>
            </div>
            <div class="form-group">
              <label class="form-label" for="b-last-name">Last Name <span class="required">*</span></label>
              <input type="text" id="b-last-name" class="form-input" placeholder="Khan" required autocomplete="family-name">
              <div class="form-error" id="err-last-name">Enter your last name</div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="b-phone">WhatsApp Number <span class="required">*</span></label>
            <input type="tel" id="b-phone" class="form-input" placeholder="+92 3XX XXXXXXX" required autocomplete="tel">
            <div class="form-error" id="err-phone">Enter a valid phone number</div>
          </div>

          <div class="form-group">
            <label class="form-label" for="b-email">Email Address <span class="required">*</span></label>
            <input type="email" id="b-email" class="form-input" placeholder="you@example.com" required autocomplete="email">
            <div class="form-error" id="err-email">Enter a valid email address</div>
          </div>

          <div class="booking-nav">
            <button class="btn-back" disabled>← Back</button>
            <button class="btn-next" onclick="nextStep(1)">Next: Vehicle Details →</button>
          </div>
        </div>

        <!-- STEP 2: Vehicle Info -->
        <div class="booking-step" id="step-2">
          <h2 class="booking-step-title">Your Vehicle</h2>
          <p class="booking-step-desc">Tell us about the car we'll be protecting.</p>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="b-make">Vehicle Make <span class="required">*</span></label>
              <input type="text" id="b-make" class="form-input" placeholder="e.g. Toyota" required>
              <div class="form-error" id="err-make">Enter vehicle make</div>
            </div>
            <div class="form-group">
              <label class="form-label" for="b-model">Vehicle Model <span class="required">*</span></label>
              <input type="text" id="b-model" class="form-input" placeholder="e.g. Corolla" required>
              <div class="form-error" id="err-model">Enter vehicle model</div>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="b-year">Year <span class="required">*</span></label>
              <select id="b-year" class="form-input" required>
                <option value="" disabled selected>Select year</option>
              </select>
              <div class="form-error" id="err-year">Select vehicle year</div>
            </div>
            <div class="form-group">
              <label class="form-label" for="b-color">Vehicle Color</label>
              <input type="text" id="b-color" class="form-input" placeholder="e.g. Pearl White">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="b-mileage">Mileage (km)</label>
            <input type="number" id="b-mileage" class="form-input" placeholder="e.g. 25000" min="0">
          </div>

          <div class="booking-nav">
            <button class="btn-back" onclick="prevStep(2)">← Back</button>
            <button class="btn-next" onclick="nextStep(2)">Next: Appointment →</button>
          </div>
        </div>

        <!-- STEP 3: Appointment -->
        <div class="booking-step" id="step-3">
          <h2 class="booking-step-title">Choose Your Appointment</h2>
          <p class="booking-step-desc">Pick a date, time, and package that works for you.</p>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="b-date">Preferred Date <span class="required">*</span></label>
              <input type="date" id="b-date" class="form-input" required>
              <div class="form-error" id="err-date">Please select a date</div>
            </div>
            <div class="form-group">
              <label class="form-label" for="b-vehicle-type">Vehicle Type <span class="required">*</span></label>
              <select id="b-vehicle-type" class="form-input" required onchange="updatePriceDisplay()">
                <option value="" disabled selected>Select type</option>
                <option value="hatchback">Hatchback</option>
                <option value="sedan">Sedan</option>
                <option value="suv">SUV</option>
                <option value="xl-suv">XL SUV</option>
              </select>
              <div class="form-error" id="err-vehicle-type">Select vehicle type</div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Preferred Time <span class="required">*</span></label>
            <div class="time-slots" id="time-slots">
              <div class="time-slot" data-time="9:00 AM" onclick="selectTime(this)">9:00 AM</div>
              <div class="time-slot" data-time="11:00 AM" onclick="selectTime(this)">11:00 AM</div>
              <div class="time-slot" data-time="2:00 PM" onclick="selectTime(this)">2:00 PM</div>
              <div class="time-slot" data-time="4:00 PM" onclick="selectTime(this)">4:00 PM</div>
            </div>
            <div class="form-error time-slot-error" id="err-time">Please select a time slot</div>
          </div>

          <div class="form-group">
            <label class="form-label">PPF Package <span class="required">*</span></label>
            <div class="package-radio-group" id="package-radio-group">
              <div class="package-radio-option" onclick="selectPackageRadio(this, 'classic')">
                <input type="radio" name="package" value="classic">
                <div class="package-radio-dot"></div>
                <div class="package-radio-info">
                  <div class="package-radio-name">NAR Classic PPF 8.0mil</div>
                  <div class="package-radio-price" id="classic-price">Select vehicle type to see price</div>
                </div>
              </div>
              <div class="package-radio-option" onclick="selectPackageRadio(this, 'premium')">
                <input type="radio" name="package" value="premium">
                <div class="package-radio-dot"></div>
                <div class="package-radio-info">
                  <div class="package-radio-name">NAR Premium PPF 8.5mil</div>
                  <div class="package-radio-price" id="premium-price">Select vehicle type to see price</div>
                </div>
              </div>
            </div>
            <div class="form-error" id="err-package">Please select a package</div>
          </div>

          <div class="price-display" id="price-display" style="display:none;">
            <span class="price-display-label" id="price-display-label">Package Total</span>
            <span class="price-display-value" id="price-display-value">PKR 0</span>
          </div>

          <div class="booking-nav">
            <button class="btn-back" onclick="prevStep(3)">← Back</button>
            <button class="btn-next" onclick="nextStep(3)">Review Booking →</button>
          </div>
        </div>

        <!-- STEP 4: Review & Confirm -->
        <div class="booking-step" id="step-4">
          <h2 class="booking-step-title">Confirm Your Booking</h2>
          <p class="booking-step-desc">Please review your details before confirming.</p>

          <div class="review-section-block">
            <div class="review-section-header">
              <span class="review-section-title">Personal Info</span>
              <button class="review-edit-btn" onclick="goToStep(1)">Edit</button>
            </div>
            <div class="review-row"><span class="r-label">Name</span><span class="r-value" id="rev-name">—</span></div>
            <div class="review-row"><span class="r-label">Phone</span><span class="r-value" id="rev-phone">—</span></div>
            <div class="review-row"><span class="r-label">Email</span><span class="r-value" id="rev-email">—</span></div>
          </div>

          <div class="review-section-block">
            <div class="review-section-header">
              <span class="review-section-title">Vehicle</span>
              <button class="review-edit-btn" onclick="goToStep(2)">Edit</button>
            </div>
            <div class="review-row"><span class="r-label">Make & Model</span><span class="r-value" id="rev-vehicle">—</span></div>
            <div class="review-row"><span class="r-label">Year</span><span class="r-value" id="rev-year">—</span></div>
            <div class="review-row"><span class="r-label">Color</span><span class="r-value" id="rev-color">—</span></div>
          </div>

          <div class="review-section-block">
            <div class="review-section-header">
              <span class="review-section-title">Appointment</span>
              <button class="review-edit-btn" onclick="goToStep(3)">Edit</button>
            </div>
            <div class="review-row"><span class="r-label">Date</span><span class="r-value" id="rev-date">—</span></div>
            <div class="review-row"><span class="r-label">Time</span><span class="r-value" id="rev-time">—</span></div>
            <div class="review-row"><span class="r-label">Vehicle Type</span><span class="r-value" id="rev-vtype">—</span></div>
            <div class="review-row"><span class="r-label">Package</span><span class="r-value" id="rev-package">—</span></div>
            <div class="review-row"><span class="r-label">Duration</span><span class="r-value" id="rev-duration">—</span></div>
          </div>

          <div class="review-total">
            <span class="review-total-label">Total Amount</span>
            <span class="review-total-price" id="rev-total">PKR —</span>
          </div>

          <label class="terms-checkbox">
            <input type="checkbox" id="terms-agree">
            <span>I agree to the <a href="/policies/terms-of-service" target="_blank">Terms and Conditions</a> and consent to RAD contacting me via WhatsApp and email regarding my booking.</span>
          </label>
          <div class="form-error" id="err-terms">Please agree to the terms to proceed</div>

          <div class="booking-nav">
            <button class="btn-back" onclick="prevStep(4)">← Back</button>
            <button class="btn-next" onclick="confirmBooking()">Confirm Booking ✓</button>
          </div>
        </div>

      </div>

      <!-- SUCCESS SCREEN -->
      <div class="booking-form-container booking-success" id="booking-success">
        <span class="success-big-icon">✅</span>
        <h2 class="success-headline">Booking Confirmed!</h2>
        <p class="success-sub">Thank you! We've received your booking request. Our team will confirm via WhatsApp and email shortly.</p>

        <div class="success-ref">
          <div class="success-ref-title">Booking Summary</div>
          <div class="success-ref-row">
            <span class="s-label">Booking Ref.</span>
            <span class="s-value" id="success-ref-id">RAD-XXXXXX</span>
          </div>
          <div class="success-ref-row">
            <span class="s-label">Date & Time</span>
            <span class="s-value" id="success-ref-datetime">—</span>
          </div>
          <div class="success-ref-row">
            <span class="s-label">Package</span>
            <span class="s-value" id="success-ref-package">—</span>
          </div>
          <div class="success-ref-row">
            <span class="s-label">Total</span>
            <span class="s-price" id="success-ref-price">—</span>
          </div>
        </div>

        <p style="font-size:0.875rem;color:var(--color-text-light);margin-bottom:1.5rem;">
          📱 We'll send a confirmation to your WhatsApp and email with all the details.
        </p>

        <div class="success-actions">
          <a href="/" class="btn btn-primary">Return to Home</a>
          <a href="tel:+923037231111" class="btn btn-outline">📞 Call Us</a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  // ---- Pricing data ----
  var ppfPricing = {
    hatchback: { classic: { price: 260000, duration: '8-10 hours' }, premium: { price: 290000, duration: '8-10 hours' } },
    sedan:     { classic: { price: 300000, duration: '8-10 hours' }, premium: { price: 330000, duration: '8-10 hours' } },
    suv:       { classic: { price: 330000, duration: '9-11 hours' }, premium: { price: 380000, duration: '9-11 hours' } },
    'xl-suv':  { classic: { price: 370000, duration: '10-12 hours' }, premium: { price: 420000, duration: '10-12 hours' } }
  };

  var vehicleTypeLabels = { hatchback: 'Hatchback', sedan: 'Sedan', suv: 'SUV', 'xl-suv': 'XL SUV' };
  var stepNames = ['', 'Personal Information', 'Vehicle Details', 'Appointment', 'Confirm Booking'];
  var currentStep = 1;
  var selectedTime = '';
  var selectedPackage = '';

  // State object
  var bookingData = {};

  // Populate year dropdown
  var yearSelect = document.getElementById('b-year');
  var currentYear = new Date().getFullYear();
  for (var y = currentYear; y >= 2000; y--) {
    var opt = document.createElement('option');
    opt.value = y;
    opt.textContent = y;
    yearSelect.appendChild(opt);
  }

  // Set min date to tomorrow
  var dateInput = document.getElementById('b-date');
  var tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  dateInput.min = tomorrow.toISOString().split('T')[0];

  // Try pre-fill from PPF page selection
  try {
    var saved = sessionStorage.getItem('rad_selected_pkg');
    if (saved) {
      var pkg = JSON.parse(saved);
      if (pkg.vehicle_type) {
        var vtSelect = document.getElementById('b-vehicle-type');
        for (var k in vehicleTypeLabels) {
          if (vehicleTypeLabels[k] === pkg.vehicle_type) { vtSelect.value = k; break; }
        }
      }
    }
  } catch(e) {}

  // ---- Navigation ----
  window.nextStep = function(from) {
    if (!validateStep(from)) return;
    saveStepData(from);
    goToStep(from + 1);
  };

  window.prevStep = function(from) {
    goToStep(from - 1);
  };

  window.goToStep = function(to) {
    document.getElementById('step-' + currentStep).classList.remove('active');
    document.querySelectorAll('.step-indicator').forEach(function(ind, i) {
      ind.classList.remove('active');
      if (i + 1 < to) { ind.classList.add('completed'); ind.querySelector('.step-dot').textContent = '✓'; }
      else { ind.classList.remove('completed'); ind.querySelector('.step-dot').textContent = (i + 1); }
    });
    currentStep = to;
    document.getElementById('step-' + currentStep).classList.add('active');
    document.querySelector('[data-step="' + currentStep + '"]').classList.add('active');

    // Update progress
    document.getElementById('progress-text').textContent = 'Step ' + currentStep + ' of 4';
    document.getElementById('progress-step-name').textContent = stepNames[currentStep];
    document.getElementById('progress-bar').style.width = (currentStep / 4 * 100) + '%';

    if (to === 4) populateReview();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // ---- Validation ----
  function validateStep(step) {
    var valid = true;
    function check(id, errId, fn) {
      var el = document.getElementById(id);
      var err = document.getElementById(errId);
      if (!el || !err) return;
      var ok = fn(el.value.trim());
      el.classList.toggle('error', !ok);
      err.classList.toggle('visible', !ok);
      if (!ok) valid = false;
    }
    var ne = function(v) { return v.length > 0; };
    var isEmail = function(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); };
    var isPhone = function(v) { return v.replace(/\D/g,'').length >= 10; };

    if (step === 1) {
      check('b-first-name', 'err-first-name', ne);
      check('b-last-name', 'err-last-name', ne);
      check('b-phone', 'err-phone', isPhone);
      check('b-email', 'err-email', isEmail);
    }
    if (step === 2) {
      check('b-make', 'err-make', ne);
      check('b-model', 'err-model', ne);
      check('b-year', 'err-year', ne);
    }
    if (step === 3) {
      check('b-date', 'err-date', ne);
      check('b-vehicle-type', 'err-vehicle-type', ne);
      // time
      var timeErr = document.getElementById('err-time');
      if (!selectedTime) {
        timeErr.classList.add('visible');
        valid = false;
      } else { timeErr.classList.remove('visible'); }
      // package
      var pkgErr = document.getElementById('err-package');
      if (!selectedPackage) {
        pkgErr.classList.add('visible');
        valid = false;
      } else { pkgErr.classList.remove('visible'); }
    }
    return valid;
  }

  function saveStepData(step) {
    if (step === 1) {
      bookingData.firstName = document.getElementById('b-first-name').value.trim();
      bookingData.lastName = document.getElementById('b-last-name').value.trim();
      bookingData.phone = document.getElementById('b-phone').value.trim();
      bookingData.email = document.getElementById('b-email').value.trim();
    }
    if (step === 2) {
      bookingData.make = document.getElementById('b-make').value.trim();
      bookingData.model = document.getElementById('b-model').value.trim();
      bookingData.year = document.getElementById('b-year').value;
      bookingData.color = document.getElementById('b-color').value.trim() || 'Not specified';
      bookingData.mileage = document.getElementById('b-mileage').value || 'Not specified';
    }
    if (step === 3) {
      bookingData.date = document.getElementById('b-date').value;
      bookingData.time = selectedTime;
      bookingData.vehicleType = document.getElementById('b-vehicle-type').value;
      bookingData.package = selectedPackage;
      var vt = bookingData.vehicleType;
      var pkg = bookingData.package;
      if (vt && pkg && ppfPricing[vt]) {
        bookingData.price = ppfPricing[vt][pkg].price;
        bookingData.duration = ppfPricing[vt][pkg].duration;
        bookingData.packageLabel = pkg === 'classic' ? 'NAR Classic PPF 8.0mil' : 'NAR Premium PPF 8.5mil';
      }
    }
  }

  function populateReview() {
    document.getElementById('rev-name').textContent = bookingData.firstName + ' ' + bookingData.lastName;
    document.getElementById('rev-phone').textContent = bookingData.phone;
    document.getElementById('rev-email').textContent = bookingData.email;
    document.getElementById('rev-vehicle').textContent = bookingData.make + ' ' + bookingData.model;
    document.getElementById('rev-year').textContent = bookingData.year;
    document.getElementById('rev-color').textContent = bookingData.color;

    var dateStr = bookingData.date ? new Date(bookingData.date + 'T12:00:00').toLocaleDateString('en-PK', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) : '—';
    document.getElementById('rev-date').textContent = dateStr;
    document.getElementById('rev-time').textContent = bookingData.time || '—';
    document.getElementById('rev-vtype').textContent = vehicleTypeLabels[bookingData.vehicleType] || '—';
    document.getElementById('rev-package').textContent = bookingData.packageLabel || '—';
    document.getElementById('rev-duration').textContent = bookingData.duration || '—';
    document.getElementById('rev-total').textContent = bookingData.price ? 'PKR ' + bookingData.price.toLocaleString() : '—';
  }

  // ---- Time selection ----
  window.selectTime = function(el) {
    document.querySelectorAll('.time-slot').forEach(function(t) { t.classList.remove('selected'); });
    el.classList.add('selected');
    selectedTime = el.dataset.time;
    document.getElementById('err-time').classList.remove('visible');
  };

  // ---- Package radio ----
  window.selectPackageRadio = function(el, pkg) {
    document.querySelectorAll('.package-radio-option').forEach(function(o) { o.classList.remove('selected'); });
    el.classList.add('selected');
    selectedPackage = pkg;
    document.getElementById('err-package').classList.remove('visible');
    updatePriceDisplay();
  };

  // ---- Price display ----
  window.updatePriceDisplay = function() {
    var vt = document.getElementById('b-vehicle-type').value;
    if (!vt || !ppfPricing[vt]) {
      document.getElementById('classic-price').textContent = 'Select vehicle type to see price';
      document.getElementById('premium-price').textContent = 'Select vehicle type to see price';
      document.getElementById('price-display').style.display = 'none';
      return;
    }
    document.getElementById('classic-price').textContent = 'PKR ' + ppfPricing[vt].classic.price.toLocaleString() + ' · ' + ppfPricing[vt].classic.duration;
    document.getElementById('premium-price').textContent = 'PKR ' + ppfPricing[vt].premium.price.toLocaleString() + ' · ' + ppfPricing[vt].premium.duration;

    if (selectedPackage && ppfPricing[vt][selectedPackage]) {
      document.getElementById('price-display').style.display = 'flex';
      document.getElementById('price-display-label').textContent = (selectedPackage === 'classic' ? 'NAR Classic' : 'NAR Premium') + ' – ' + vehicleTypeLabels[vt];
      document.getElementById('price-display-value').textContent = 'PKR ' + ppfPricing[vt][selectedPackage].price.toLocaleString();
    } else {
      document.getElementById('price-display').style.display = 'none';
    }
  };

  // ---- Confirm ----
  window.confirmBooking = function() {
    var termsCheck = document.getElementById('terms-agree');
    var termsErr = document.getElementById('err-terms');
    if (!termsCheck.checked) {
      termsErr.classList.add('visible');
      return;
    }
    termsErr.classList.remove('visible');

    // Generate reference
    var ref = 'RAD-' + Date.now().toString(36).toUpperCase().slice(-6);

    // Show success
    document.getElementById('booking-form-container').style.display = 'none';
    document.querySelector('.booking-progress').style.display = 'none';
    document.querySelector('.step-indicators').style.display = 'none';

    var success = document.getElementById('booking-success');
    success.classList.add('visible');

    document.getElementById('success-ref-id').textContent = ref;
    var dateStr = bookingData.date ? new Date(bookingData.date + 'T12:00:00').toLocaleDateString('en-PK', { weekday:'short', year:'numeric', month:'short', day:'numeric' }) : '—';
    document.getElementById('success-ref-datetime').textContent = dateStr + ' at ' + (bookingData.time || '—');
    document.getElementById('success-ref-package').textContent = (bookingData.packageLabel || '—') + ' · ' + (vehicleTypeLabels[bookingData.vehicleType] || '');
    document.getElementById('success-ref-price').textContent = bookingData.price ? 'PKR ' + bookingData.price.toLocaleString() : '—';

    window.scrollTo({ top: 0, behavior: 'smooth' });
  };
})();
</script>

