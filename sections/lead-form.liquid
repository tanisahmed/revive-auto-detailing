<style>
.rad-leadform { padding: 5rem 0; background: #fff; }
.rad-leadform-wrap { max-width: 42rem; margin: 0 auto; background: #f3f4f6; border-radius: 12px; padding: 2.5rem; }
.rad-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.rad-form-group { margin-bottom: 1.25rem; }
.rad-form-label { display: block; font-weight: 600; margin-bottom: 0.4rem; font-size: 0.95rem; color: #1f2937; }
.rad-form-label span { color: #ef4444; }
.rad-form-input { width: 100%; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; font-family: 'Nunito Sans', sans-serif; color: #1f2937; background: #fff; outline: none; transition: border 0.2s; }
.rad-form-input:focus { border-color: #1e3a8a; box-shadow: 0 0 0 3px rgba(30,58,138,0.12); }
.rad-form-error { color: #ef4444; font-size: 0.8rem; margin-top: 0.3rem; display: none; }
.rad-form-error.show { display: block; }
.rad-submit-btn { width: 100%; padding: 0.875rem; background: #1e3a8a; color: #fff; border: none; border-radius: 8px; font-family: 'Nunito Sans', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.2s; }
.rad-submit-btn:hover { background: #1e40af; }
.rad-form-success { display: none; text-align: center; padding: 2rem; }
.rad-form-success.show { display: block; }
@media (max-width: 640px) { .rad-leadform { padding: 3rem 0; } .rad-form-row { grid-template-columns: 1fr; } .rad-leadform-wrap { padding: 1.5rem 1.25rem; } }
</style>

<section class="rad-leadform">
  <div class="container">
    <h2 class="section-title">Get Your Free Estimate</h2>
    <p class="section-subtitle">Fill out the form below and we'll get back to you with a personalized quote.</p>
    <div class="rad-leadform-wrap">
      <form id="rad-lead-form" novalidate>
        <div class="rad-form-row">
          <div class="rad-form-group">
            <label class="rad-form-label" for="rlf-fname">First Name <span>*</span></label>
            <input type="text" id="rlf-fname" class="rad-form-input" placeholder="Ahmed" required>
            <div class="rad-form-error" id="rlf-err-fname">Enter your first name</div>
          </div>
          <div class="rad-form-group">
            <label class="rad-form-label" for="rlf-lname">Last Name <span>*</span></label>
            <input type="text" id="rlf-lname" class="rad-form-input" placeholder="Khan" required>
            <div class="rad-form-error" id="rlf-err-lname">Enter your last name</div>
          </div>
        </div>
        <div class="rad-form-row">
          <div class="rad-form-group">
            <label class="rad-form-label" for="rlf-phone">WhatsApp Number <span>*</span></label>
            <input type="tel" id="rlf-phone" class="rad-form-input" placeholder="+92 3XX XXXXXXX" required>
            <div class="rad-form-error" id="rlf-err-phone">Enter a valid phone number</div>
          </div>
          <div class="rad-form-group">
            <label class="rad-form-label" for="rlf-email">Email Address <span>*</span></label>
            <input type="email" id="rlf-email" class="rad-form-input" placeholder="you@example.com" required>
            <div class="rad-form-error" id="rlf-err-email">Enter a valid email</div>
          </div>
        </div>
        <div class="rad-form-group">
          <label class="rad-form-label" for="rlf-vehicle">Vehicle Make &amp; Model <span>*</span></label>
          <input type="text" id="rlf-vehicle" class="rad-form-input" placeholder="e.g. Toyota Corolla 2022" required>
          <div class="rad-form-error" id="rlf-err-vehicle">Enter your vehicle</div>
        </div>
        <div class="rad-form-group">
          <label class="rad-form-label" for="rlf-service">Service Package <span>*</span></label>
          <select id="rlf-service" class="rad-form-input" required>
            <option value="" disabled selected>Select a service...</option>
            <option value="ppf">Paint Protection Film (PPF)</option>
            <option value="ceramic">Ceramic Coating</option>
            <option value="detailing">Exterior &amp; Interior Detailing</option>
            <option value="antirust">Anti-Rust Undercoating</option>
          </select>
          <div class="rad-form-error" id="rlf-err-service">Select a service</div>
        </div>
        <button type="submit" class="rad-submit-btn">Calculate My Car Estimate</button>
      </form>
      <div class="rad-form-success" id="rlf-success">
        <div style="font-size:3rem;margin-bottom:1rem;">&#9989;</div>
        <h3 style="font-size:1.5rem;font-weight:800;margin-bottom:0.5rem;">Request Received!</h3>
        <p style="color:#6b7280;">We'll get back to you on WhatsApp within a few hours with your personalized quote.</p>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var form = document.getElementById('rad-lead-form');
  if(!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var ok = true;
    function chk(id, errId, fn){
      var el=document.getElementById(id), err=document.getElementById(errId);
      var v=fn(el.value.trim());
      el.style.borderColor=v?'#d1d5db':'#ef4444';
      err.classList.toggle('show',!v);
      if(!v) ok=false;
    }
    chk('rlf-fname','rlf-err-fname',function(v){return v.length>0;});
    chk('rlf-lname','rlf-err-lname',function(v){return v.length>0;});
    chk('rlf-phone','rlf-err-phone',function(v){return v.replace(/\D/g,'').length>=10;});
    chk('rlf-email','rlf-err-email',function(v){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);});
    chk('rlf-vehicle','rlf-err-vehicle',function(v){return v.length>0;});
    chk('rlf-service','rlf-err-service',function(v){return v.length>0;});
    if(ok){
      form.style.display='none';
      document.getElementById('rlf-success').classList.add('show');
    }
  });
})();
</script>

{% schema %}
{
  "name": "Lead Form",
  "settings": [],
  "presets": [{"name": "Lead Form"}]
}
{% endschema %}
