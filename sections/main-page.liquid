<style>
  .main-page-section {
    padding: 4rem 0;
    min-height: 50vh;
  }
  .main-page-section .page-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }
  .main-page-section .page-content {
    max-width: 720px;
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-light);
  }
  .main-page-section .page-content h2 { font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 1.5rem 0 0.5rem; }
  .main-page-section .page-content p { margin-bottom: 1rem; }
  .main-page-section .page-content ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
  .main-page-section .page-content ul li { margin-bottom: 0.4rem; }
</style>

<section class="main-page-section">
  <div class="container">
    <h1 class="page-title">{{ page.title }}</h1>
    <div class="page-content">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
