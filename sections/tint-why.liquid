<style>
.rad-tint-why { padding: 2rem 0; background: #fff; }
.rad-tint-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.rad-tint-why-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; background: linear-gradient(135deg, #0f172a, #1e3a8a); display: flex; align-items: center; justify-content: center; font-size: 6rem; }
.rad-tint-why-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-tint-why-tag { display: inline-block; background: rgba(30,58,138,0.1); color: #1e3a8a; padding: 0.3rem 0.85rem; border-radius: 100px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.75rem; }
.rad-tint-why-title { font-size: 1.85rem; font-weight: 800; color: #1f2937; line-height: 1.2; margin-bottom: 1.25rem; font-family: 'Nunito Sans', sans-serif; }
.rad-tint-why-list { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 2rem; }
.rad-tint-why-item { display: flex; align-items: flex-start; gap: 0.75rem; }
.rad-tint-why-item-icon { width: 2rem; height: 2rem; background: rgba(30,58,138,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem; }
.rad-tint-why-item-text h4 { font-size: 0.95rem; font-weight: 700; color: #1f2937; margin-bottom: 0.15rem; }
.rad-tint-why-item-text p { font-size: 0.85rem; color: #6b7280; line-height: 1.5; }
.rad-tint-why-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
.rad-tint-why-btn { display: inline-flex; align-items: center; padding: 0.875rem 1.75rem; background: #1e3a8a; color: #fff; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-tint-why-btn:hover { background: #1e40af; transform: translateY(-1px); }
.rad-tint-why-btn-wa { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: transparent; color: #10b981; border: 2px solid #10b981; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-tint-why-btn-wa:hover { background: #10b981; color: #fff; }
@media (max-width: 768px) { .rad-tint-why-grid { grid-template-columns: 1fr; } .rad-tint-why-title { font-size: 1.5rem; } }
@media (max-width: 640px) {
  .rad-tint-why-btns { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; }
  .rad-tint-why-btn, .rad-tint-why-btn-wa { flex: 1; width: auto; justify-content: center; text-align: center; padding: 0.65rem 0.5rem; font-size: 0.78rem; white-space: nowrap; }
}
</style>

<section class="rad-tint-why">
  <div class="container">
    <div class="rad-tint-why-grid">
      <div class="rad-tint-why-img">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Why Window Tint" loading="lazy">
        {%- else -%}
          🌑
        {%- endif -%}
      </div>
      <div>
        <span class="rad-tint-why-tag">{{ section.settings.tag }}</span>
        <h2 class="rad-tint-why-title">{{ section.settings.title }}</h2>
        <div class="rad-tint-why-list">
          <div class="rad-tint-why-item">
            <div class="rad-tint-why-item-icon">🔥</div>
            <div class="rad-tint-why-item-text">
              <h4>Reduces Interior Heat</h4>
              <p>Blocks up to 65% of solar energy — keeps your car significantly cooler</p>
            </div>
          </div>
          <div class="rad-tint-why-item">
            <div class="rad-tint-why-item-icon">☀️</div>
            <div class="rad-tint-why-item-text">
              <h4>99% UV Protection</h4>
              <p>Protects you and your passengers from harmful UV rays — prevents skin damage</p>
            </div>
          </div>
          <div class="rad-tint-why-item">
            <div class="rad-tint-why-item-icon">🔒</div>
            <div class="rad-tint-why-item-text">
              <h4>Privacy &amp; Security</h4>
              <p>Provides privacy from outside while maintaining clear visibility from inside</p>
            </div>
          </div>
          <div class="rad-tint-why-item">
            <div class="rad-tint-why-item-icon">✨</div>
            <div class="rad-tint-why-item-text">
              <h4>Premium Look</h4>
              <p>Enhances your car's appearance with a sleek, professional finish</p>
            </div>
          </div>
          <div class="rad-tint-why-item">
            <div class="rad-tint-why-item-icon">💺</div>
            <div class="rad-tint-why-item-text">
              <h4>Protects Interior</h4>
              <p>Prevents dashboard and seat fading caused by direct sunlight</p>
            </div>
          </div>
        </div>
        <div class="rad-tint-why-btns">
          <a href="/pages/tint-booking" class="rad-tint-why-btn">{{ section.settings.btn1_text }}</a>
          <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20window%20tinting%20for%20my%20car" target="_blank" class="rad-tint-why-btn-wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Get Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tint Why Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "Why Window Tinting?"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "Block Heat, Protect Your Car & Stay Cool in Karachi's Harsh Summers"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Book Your Slot"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 Link"
    }
  ],
  "presets": [
    {
      "name": "Tint Why Section"
    }
  ]
}
{% endschema %}