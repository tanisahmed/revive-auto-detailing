<style>
.uvi { font-family: 'Nunito Sans', sans-serif; }

/* HERO */
.uvi-hero { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); padding: 5rem 0 4rem; color: #fff; position: relative; overflow: hidden; min-height: 480px; display: flex; align-items: center; }
.uvi-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 65% 50%, rgba(139,92,246,0.3) 0%, transparent 65%); }
.uvi-hero-media { position:absolute; inset:0; z-index:0; }
.uvi-hero-media img, .uvi-hero-media video { width:100%; height:100%; object-fit:cover; }
.uvi-hero-overlay { position:absolute; inset:0; background: linear-gradient(to right, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.35) 100%); z-index:1; }
.uvi-hero-content { position:relative; z-index:2; max-width:640px; }
.uvi-hero-badge { display:inline-flex; align-items:center; gap:0.5rem; background:rgba(139,92,246,0.25); border:1px solid rgba(167,139,250,0.4); padding:0.35rem 1rem; border-radius:100px; font-size:0.78rem; font-weight:700; color:#c4b5fd; margin-bottom:1.1rem; letter-spacing:0.08em; text-transform:uppercase; }
.uvi-hero h1 { font-size:2.85rem; font-weight:800; line-height:1.12; margin-bottom:0.5rem; letter-spacing:-0.5px; }
.uvi-hero h1 span { color:#a78bfa; }
.uvi-hero-sub { font-size:1.2rem; font-weight:700; color:#a78bfa; margin-bottom:1rem; }
.uvi-hero-desc { font-size:1rem; color:#d1d5db; line-height:1.75; margin-bottom:1.75rem; max-width:520px; }
.uvi-hero-features { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem; }
.uvi-hero-feat { background:rgba(255,255,255,0.08); padding:0.35rem 0.85rem; border-radius:100px; font-size:0.875rem; font-weight:600; }
.uvi-hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
.uvi-btn-primary { display:inline-flex; align-items:center; padding:0.875rem 1.75rem; background:#7c3aed; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
.uvi-btn-primary:hover { background:#6d28d9; }
.uvi-btn-wa { display:inline-flex; align-items:center; gap:0.4rem; padding:0.875rem 1.75rem; background:#10b981; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
.uvi-btn-wa:hover { background:#059669; }

/* TRUST */
.uvi-trust { background:#fff; border-bottom:1px solid #e5e7eb; padding:1rem 0; }
.uvi-trust-inner { max-width:1060px; margin:0 auto; padding:0 1.5rem; display:flex; justify-content:center; gap:2.5rem; flex-wrap:wrap; }
.uvi-trust-item { display:flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:600; color:#374151; }

/* WHAT IS — AEO Answer Box */
.uvi-what { padding:4rem 0; background:#fff; }
.uvi-what-inner { max-width:960px; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:center; }
.uvi-sec-tag { font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#7c3aed; margin-bottom:0.6rem; }
.uvi-what h2 { font-size:1.9rem; font-weight:800; color:#1f2937; line-height:1.2; margin-bottom:1rem; }
.uvi-what-answer { background:#f5f3ff; border-left:4px solid #7c3aed; border-radius:0 10px 10px 0; padding:1.25rem 1.5rem; margin-bottom:1.25rem; }
.uvi-what-answer p { font-size:0.95rem; color:#374151; line-height:1.75; margin:0; }
.uvi-what p { font-size:0.9rem; color:#6b7280; line-height:1.7; }
.uvi-what-visual { background:linear-gradient(135deg,#1e1b4b,#2e1065); border-radius:16px; padding:2rem; text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; }
.uvi-lamp { font-size:5rem; filter: drop-shadow(0 0 20px rgba(139,92,246,0.6)); }
.uvi-what-visual p { color:#c4b5fd; font-size:0.85rem; line-height:1.6; }

/* WHAT REVEALS */
.uvi-reveals { padding:4rem 0; background:#f8fafc; }
.uvi-reveals-inner { max-width:1060px; margin:0 auto; padding:0 1.5rem; }
.uvi-sec-hdr { text-align:center; margin-bottom:2.5rem; }
.uvi-sec-hdr h2 { font-size:2rem; font-weight:800; color:#1f2937; margin-bottom:0.5rem; }
.uvi-sec-hdr p { color:#6b7280; font-size:0.95rem; max-width:600px; margin:0 auto; }
.uvi-reveals-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; }
.uvi-reveal-card { background:#fff; border-radius:12px; padding:1.5rem; border:1px solid #e5e7eb; border-top:3px solid #7c3aed; }
.uvi-reveal-icon { font-size:2rem; margin-bottom:0.75rem; display:block; }
.uvi-reveal-card h3 { font-size:0.95rem; font-weight:800; color:#1f2937; margin-bottom:0.4rem; }
.uvi-reveal-card p { font-size:0.82rem; color:#6b7280; line-height:1.55; }

/* PROCESS */
.uvi-process { padding:4rem 0; background:#fff; }
.uvi-process-inner { max-width:860px; margin:0 auto; padding:0 1.5rem; }
.uvi-steps { display:flex; flex-direction:column; gap:0; margin-top:2rem; }
.uvi-step { display:flex; gap:1.5rem; position:relative; padding-bottom:2rem; }
.uvi-step:last-child { padding-bottom:0; }
.uvi-step-left { display:flex; flex-direction:column; align-items:center; }
.uvi-step-num { width:2.5rem; height:2.5rem; border-radius:50%; background:#7c3aed; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.9rem; flex-shrink:0; }
.uvi-step-line { width:2px; background:#e5e7eb; flex:1; margin-top:0.25rem; }
.uvi-step:last-child .uvi-step-line { display:none; }
.uvi-step-body { padding-bottom:0.5rem; }
.uvi-step-body h3 { font-size:1rem; font-weight:700; color:#1f2937; margin-bottom:0.3rem; }
.uvi-step-body p { font-size:0.875rem; color:#6b7280; line-height:1.6; }

/* WHY IMPORTANT */
.uvi-why { padding:4rem 0; background:#f5f3ff; }
.uvi-why-inner { max-width:960px; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center; }
.uvi-why h2 { font-size:1.9rem; font-weight:800; color:#1f2937; margin-bottom:1rem; line-height:1.2; }
.uvi-why-list { display:flex; flex-direction:column; gap:0.85rem; }
.uvi-why-item { display:flex; align-items:flex-start; gap:0.75rem; }
.uvi-why-check { width:1.5rem; height:1.5rem; border-radius:50%; background:#7c3aed; display:flex; align-items:center; justify-content:center; font-size:0.65rem; color:#fff; flex-shrink:0; margin-top:2px; }
.uvi-why-text h4 { font-size:0.9rem; font-weight:700; color:#1f2937; margin-bottom:0.15rem; }
.uvi-why-text p { font-size:0.8rem; color:#6b7280; line-height:1.55; }
.uvi-why-callout { background:linear-gradient(135deg,#1e1b4b,#2e1065); border-radius:14px; padding:2rem; color:#fff; }
.uvi-why-callout h3 { font-size:1.1rem; font-weight:800; margin-bottom:0.75rem; }
.uvi-why-callout p { font-size:0.875rem; color:#c4b5fd; line-height:1.7; margin-bottom:1rem; }
.uvi-why-callout a { display:inline-flex; padding:0.7rem 1.5rem; background:#7c3aed; color:#fff; border-radius:8px; font-weight:700; font-size:0.875rem; text-decoration:none; }

/* FAQ — AEO/GEO optimized */
.uvi-faq { padding:4rem 0; background:#fff; }
.uvi-faq-inner { max-width:760px; margin:0 auto; padding:0 1.5rem; }
.uvi-faq-list { display:flex; flex-direction:column; gap:0.75rem; margin-top:2rem; }
.uvi-faq-item { background:#f8fafc; border-radius:10px; border:1px solid #e5e7eb; overflow:hidden; }
.uvi-faq-q { display:flex; justify-content:space-between; align-items:center; padding:1rem 1.25rem; cursor:pointer; font-weight:700; font-size:0.925rem; color:#1f2937; user-select:none; }
.uvi-faq-q:hover { color:#7c3aed; }
.uvi-faq-icon { font-size:1.25rem; transition:transform 0.25s; flex-shrink:0; }
.uvi-faq-item.open .uvi-faq-icon { transform:rotate(45deg); }
.uvi-faq-a { max-height:0; overflow:hidden; transition:max-height 0.35s ease; }
.uvi-faq-item.open .uvi-faq-a { max-height:400px; }
.uvi-faq-a p { padding:0 1.25rem 1.1rem; font-size:0.875rem; color:#4b5563; line-height:1.7; }

/* CTA */
.uvi-cta { padding:4rem 0; background:linear-gradient(135deg,#1e1b4b,#0f172a); text-align:center; color:#fff; }
.uvi-cta-inner { max-width:600px; margin:0 auto; padding:0 1.5rem; }
.uvi-cta h2 { font-size:2rem; font-weight:800; margin-bottom:0.75rem; }
.uvi-cta p { color:#c4b5fd; margin-bottom:2rem; font-size:1rem; }
.uvi-cta-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

/* MOBILE */
@media (max-width:900px) {
  .uvi-what-inner, .uvi-why-inner { grid-template-columns:1fr; }
  .uvi-reveals-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width:640px) {
  .uvi-hero { padding:2.25rem 0; min-height:auto; }
  .uvi-hero-content { padding:0 1rem; }
  .uvi-hero h1 { font-size:1.65rem; line-height:1.25; }
  .uvi-hero-sub { font-size:0.95rem; }
  .uvi-hero-desc { font-size:0.88rem; margin-bottom:1.25rem; }
  .uvi-hero-btns { flex-direction:row; flex-wrap:nowrap; gap:0.5rem; }
  .uvi-btn-primary, .uvi-btn-wa { flex:1; justify-content:center; text-align:center; padding:0.65rem 0.5rem; font-size:0.78rem; white-space:nowrap; }
  .uvi-hero-badge { font-size:0.65rem; }
  .uvi-hero-feat { font-size:0.7rem; }
  .uvi-reveals-grid { grid-template-columns:1fr; }
  .uvi-what { padding:2rem 0; }
  .uvi-reveals { padding:2rem 0; }
  .uvi-process { padding:2rem 0; }
  .uvi-why { padding:2rem 0; }
  .uvi-faq { padding:2rem 0; }
  .uvi-cta { padding:2rem 0; }
  .uvi-cta h2 { font-size:1.4rem; }
  .uvi-cta-btns { flex-direction:row; flex-wrap:nowrap; gap:0.5rem; }
  .uvi-cta-btns a { flex:1; justify-content:center; text-align:center; padding:0.65rem 0.5rem; font-size:0.78rem; white-space:nowrap; }
  .uvi-sec-hdr h2 { font-size:1.4rem; }
}
</style>

<div class="uvi">

  <!-- HERO -->
  <div class="uvi-hero">
    {%- if section.settings.bg_video != blank -%}
      <div class="uvi-hero-media"><video src="{{ section.settings.bg_video.sources.last.url }}" autoplay muted loop playsinline></video></div>
      <div class="uvi-hero-overlay"></div>
    {%- elsif section.settings.bg_image != blank -%}
      <div class="uvi-hero-media"><img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="UV Paint Inspection" loading="eager"></div>
      <div class="uvi-hero-overlay"></div>
    {%- endif -%}
    <div class="container">
      <div class="uvi-hero-content">
        <div class="uvi-hero-badge">🔦 {{ section.settings.badge | default: "UV Paint Inspection • Karachi" }}</div>
        <h1>{{ section.settings.hero_title | default: "UV Light" }} <span>{{ section.settings.hero_highlight | default: "Car Paint Inspection" }}</span> {{ section.settings.hero_end | default: "in Karachi" }}</h1>
        <p class="uvi-hero-sub">{{ section.settings.hero_sub | default: "See What the Naked Eye Can't" }}</p>
        <p class="uvi-hero-desc">{{ section.settings.hero_desc | default: "We use professional UV light devices to inspect your car's paint in a darkened environment — revealing hidden repaint, fading, rust damage, and paint defects before you buy or protect your vehicle." }}</p>
        <div class="uvi-hero-features">
          {%- if section.settings.feat1 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat1 }}</span>{%- endif -%}
          {%- if section.settings.feat2 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat2 }}</span>{%- endif -%}
          {%- if section.settings.feat3 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat3 }}</span>{%- endif -%}
          {%- if section.settings.feat4 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat4 }}</span>{%- endif -%}
        </div>
        <div class="uvi-hero-btns">
          <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-primary">{{ section.settings.btn1_text | default: "Book Inspection" }}</a>
          <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20a%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.btn2_text | default: "WhatsApp Us" }}</a>
        </div>
      </div>
    </div>
  </div>

  <!-- TRUST BAR -->
  <div class="uvi-trust">
    <div class="uvi-trust-inner">
      <div class="uvi-trust-item"><span>🔦</span><span>UV Device Inspection</span></div>
      <div class="uvi-trust-item"><span>🚗</span><span>Pre-Buy Paint Check</span></div>
      <div class="uvi-trust-item"><span>⭐</span><span>4.9 Google Rating</span></div>
      <div class="uvi-trust-item"><span>📍</span><span>Karachi, Pakistan</span></div>
    </div>
  </div>

  <!-- WHAT IS UV INSPECTION — AEO Answer Box -->
  <div class="uvi-what">
    <div class="uvi-what-inner">
      <div>
        <div class="uvi-sec-tag">What is it?</div>
        <h2>{{ section.settings.what_title | default: "What is UV Light Car Paint Inspection?" }}</h2>
        <div class="uvi-what-answer">
          <p>{{ section.settings.what_answer | default: "UV Light Car Paint Inspection is a process where a professional UV (ultraviolet) light device is used in a dark environment to examine a car's paint surface. Original factory paint appears uniform under UV light, while repainted panels, paint fading, rust damage, and body filler glow differently — making hidden defects clearly visible." }}</p>
        </div>
        <p>{{ section.settings.what_detail | default: "This technique is widely used before purchasing a used car, before applying PPF or ceramic coating, and to assess accident or hail damage. At Revive Auto Detailing Karachi, we perform UV paint inspections using professional-grade equipment to give you a clear, honest report of your car's paint condition." }}</p>
      </div>
      <div class="uvi-what-visual">
        <div class="uvi-lamp">🔦</div>
        <p>Under UV light, factory paint glows uniformly. Repainted panels, filler, and rust show up as bright or dark spots — invisible to the naked eye.</p>
      </div>
    </div>
  </div>

  <!-- WHAT UV INSPECTION REVEALS -->
  <div class="uvi-reveals">
    <div class="uvi-reveals-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.reveals_title | default: "What Does UV Light Reveal on Car Paint?" }}</h2>
        <p>{{ section.settings.reveals_sub | default: "6 hidden paint problems that only show up under UV light" }}</p>
      </div>
      <div class="uvi-reveals-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'reveal' -%}
          <div class="uvi-reveal-card">
            <span class="uvi-reveal-icon">{{ block.settings.icon | default: "🔍" }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- PROCESS -->
  <div class="uvi-process">
    <div class="uvi-process-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.process_title | default: "How Our UV Paint Inspection Works" }}</h2>
        <p>{{ section.settings.process_sub | default: "A step-by-step walkthrough of what happens when you book a UV inspection at Revive" }}</p>
      </div>
      <div class="uvi-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
          <div class="uvi-step">
            <div class="uvi-step-left"><div class="uvi-step-num">{{ forloop.index }}</div><div class="uvi-step-line"></div></div>
            <div class="uvi-step-body"><h3>{{ block.settings.title }}</h3><p>{{ block.settings.description }}</p></div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- WHY IT MATTERS -->
  <div class="uvi-why">
    <div class="uvi-why-inner">
      <div>
        <div class="uvi-sec-tag">Why it matters</div>
        <h2>{{ section.settings.why_title | default: "Why UV Paint Inspection Matters Before Buying a Used Car in Pakistan" }}</h2>
        <div class="uvi-why-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'why_item' -%}
            <div class="uvi-why-item">
              <div class="uvi-why-check">✓</div>
              <div class="uvi-why-text"><h4>{{ block.settings.title }}</h4><p>{{ block.settings.description }}</p></div>
            </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <div class="uvi-why-callout">
        <h3>🔦 Book a UV Paint Inspection Today</h3>
        <p>Bring your car to our Karachi studio — lights go off, UV light goes on, and within minutes you'll know the true condition of your vehicle's paint. No guesswork, no hidden surprises.</p>
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}">Book Now →</a>
      </div>
    </div>
  </div>

  <!-- FAQ — AEO/GEO optimized questions -->
  <div class="uvi-faq">
    <div class="uvi-faq-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.faq_title | default: "Frequently Asked Questions — UV Paint Inspection Karachi" }}</h2>
        <p>{{ section.settings.faq_sub | default: "Common questions about UV light car paint inspection in Pakistan" }}</p>
      </div>
      <div class="uvi-faq-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
          <div class="uvi-faq-item">
            <div class="uvi-faq-q">{{ block.settings.question }}<span class="uvi-faq-icon">+</span></div>
            <div class="uvi-faq-a"><p>{{ block.settings.answer }}</p></div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="uvi-cta">
    <div class="uvi-cta-inner">
      <h2>{{ section.settings.cta_title | default: "Know Your Car's True Paint Condition" }}</h2>
      <p>{{ section.settings.cta_sub | default: "Book a UV paint inspection at Revive Auto Detailing Karachi — before you buy, before you protect, before you sell." }}</p>
      <div class="uvi-cta-btns">
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-primary">🔦 {{ section.settings.cta_btn1 | default: "Book Inspection" }}</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20a%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.cta_btn2 | default: "WhatsApp Us" }}</a>
      </div>
    </div>
  </div>

</div>

<script>
document.querySelectorAll('.uvi-faq-q').forEach(function(q){
  q.addEventListener('click',function(){
    var item=q.closest('.uvi-faq-item');
    var wasOpen=item.classList.contains('open');
    document.querySelectorAll('.uvi-faq-item').forEach(function(i){i.classList.remove('open');});
    if(!wasOpen)item.classList.add('open');
  });
});
</script>

{% schema %}
{
  "name": "UV Paint Inspection Page",
  "settings": [
    {"type":"header","content":"Hero"},
    {"type":"image_picker","id":"bg_image","label":"Background Image"},
    {"type":"video","id":"bg_video","label":"Background Video (overrides image)"},
    {"type":"text","id":"badge","label":"Badge Text","default":"UV Paint Inspection • Karachi"},
    {"type":"text","id":"hero_title","label":"H1 Part 1","default":"UV Light"},
    {"type":"text","id":"hero_highlight","label":"H1 Highlighted","default":"Car Paint Inspection"},
    {"type":"text","id":"hero_end","label":"H1 Part 3","default":"in Karachi"},
    {"type":"text","id":"hero_sub","label":"Subheadline","default":"See What the Naked Eye Can't"},
    {"type":"textarea","id":"hero_desc","label":"Description"},
    {"type":"text","id":"feat1","label":"Feature 1","default":"✓ Repaint Detection"},
    {"type":"text","id":"feat2","label":"Feature 2","default":"✓ Paint Fade Check"},
    {"type":"text","id":"feat3","label":"Feature 3","default":"✓ Rust & Filler Reveal"},
    {"type":"text","id":"feat4","label":"Feature 4","default":"✓ Pre-Buy Inspection"},
    {"type":"text","id":"btn1_text","label":"Button 1 Text","default":"Book Inspection"},
    {"type":"url","id":"btn1_url","label":"Button 1 Link"},
    {"type":"text","id":"btn2_text","label":"Button 2 Text","default":"WhatsApp Us"},
    {"type":"header","content":"What Is Section"},
    {"type":"text","id":"what_title","label":"Heading","default":"What is UV Light Car Paint Inspection?"},
    {"type":"textarea","id":"what_answer","label":"Answer Box Text"},
    {"type":"textarea","id":"what_detail","label":"Detail Paragraph"},
    {"type":"header","content":"Reveals Section"},
    {"type":"text","id":"reveals_title","label":"Title","default":"What Does UV Light Reveal on Car Paint?"},
    {"type":"text","id":"reveals_sub","label":"Subtitle","default":"6 hidden paint problems that only show up under UV light"},
    {"type":"header","content":"Process Section"},
    {"type":"text","id":"process_title","label":"Title","default":"How Our UV Paint Inspection Works"},
    {"type":"text","id":"process_sub","label":"Subtitle"},
    {"type":"header","content":"Why It Matters Section"},
    {"type":"text","id":"why_title","label":"Title","default":"Why UV Paint Inspection Matters Before Buying a Used Car in Pakistan"},
    {"type":"header","content":"FAQ Section"},
    {"type":"text","id":"faq_title","label":"Title","default":"Frequently Asked Questions — UV Paint Inspection Karachi"},
    {"type":"text","id":"faq_sub","label":"Subtitle"},
    {"type":"header","content":"CTA"},
    {"type":"text","id":"cta_title","label":"Heading","default":"Know Your Car's True Paint Condition"},
    {"type":"textarea","id":"cta_sub","label":"Subtext"},
    {"type":"text","id":"cta_btn1","label":"Button 1","default":"Book Inspection"},
    {"type":"text","id":"cta_btn2","label":"Button 2","default":"WhatsApp Us"}
  ],
  "blocks": [
    {
      "type": "reveal",
