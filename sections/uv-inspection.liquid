<style>
.uvi { font-family: 'Nunito Sans', sans-serif; color: #1f2937; }

/* HERO — dark purple */
.uvi-hero {
  min-height: 90vh;
  background: #0d0d1a;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
}
.uvi-hero-bg { position: absolute; inset: 0; z-index: 0; }
.uvi-hero-bg img, .uvi-hero-bg video { width: 100%; height: 100%; object-fit: cover; }
.uvi-hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(13,13,26,0.95) 0%, rgba(88,28,135,0.6) 60%, rgba(13,13,26,0.85) 100%);
}
.uvi-hero-glow {
  position: absolute; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(147,51,234,0.4) 0%, transparent 55%),
    radial-gradient(ellipse at 80% 30%, rgba(124,58,237,0.2) 0%, transparent 45%);
}
.uvi-hero-inner { position: relative; z-index: 2; max-width: 1060px; margin: 0 auto; padding: 5rem 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.uvi-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(147,51,234,0.25); border: 1px solid rgba(192,132,252,0.4); color: #e9d5ff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.4rem 1.1rem; border-radius: 100px; margin-bottom: 1.25rem; }
.uvi-hero h1 { font-size: 3.25rem; font-weight: 900; line-height: 1.08; color: #fff; margin-bottom: 0.75rem; letter-spacing: -1px; }
.uvi-hero h1 em { font-style: normal; color: #c084fc; }
.uvi-hero-sub { font-size: 1.1rem; color: #d8b4fe; font-weight: 600; margin-bottom: 1.1rem; }
.uvi-hero-desc { font-size: 0.975rem; color: #e2e8f0; line-height: 1.8; margin-bottom: 1.75rem; max-width: 460px; }
.uvi-feat-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
.uvi-feat { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); padding: 0.35rem 0.85rem; border-radius: 100px; font-size: 0.82rem; font-weight: 600; color: #f3e8ff; }
.uvi-btn-row { display: flex; gap: 0.85rem; flex-wrap: wrap; }
.uvi-btn-book { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.9rem 1.75rem; background: linear-gradient(135deg,#9333ea,#7c3aed); color: #fff; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; box-shadow: 0 4px 20px rgba(147,51,234,0.4); transition: all 0.2s; }
.uvi-btn-book:hover { background: linear-gradient(135deg,#a855f7,#8b5cf6); transform: translateY(-2px); }
.uvi-btn-wa { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.9rem 1.75rem; background: #10b981; color: #fff; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.uvi-btn-wa:hover { background: #059669; }

/* Hero right — UV glow visual */
.uvi-hero-visual { display: flex; flex-direction: column; gap: 1rem; }
.uvi-uv-lamp { background: radial-gradient(ellipse at center, rgba(168,85,247,0.3) 0%, rgba(13,13,26,0.8) 70%); border: 1px solid rgba(168,85,247,0.3); border-radius: 20px; padding: 2.5rem 1.5rem; text-align: center; }
.uvi-lamp-icon { font-size: 5rem; display: block; filter: drop-shadow(0 0 30px rgba(192,132,252,0.8)); margin-bottom: 1rem; }
.uvi-lamp-text { font-size: 0.82rem; color: #c4b5fd; line-height: 1.6; }
.uvi-stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.uvi-stat { background: rgba(255,255,255,0.05); border: 1px solid rgba(168,85,247,0.25); border-radius: 12px; padding: 1rem; text-align: center; }
.uvi-stat-num { font-size: 1.65rem; font-weight: 800; color: #e9d5ff; display: block; }
.uvi-stat-lbl { font-size: 0.7rem; color: #a78bfa; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

/* PRICING — right below hero */
.uvi-pricing { background: #f5f3ff; padding: 3.5rem 0; }
.uvi-pricing-inner { max-width: 860px; margin: 0 auto; padding: 0 1.5rem; }
.uvi-sec { text-align: center; margin-bottom: 2.25rem; }
.uvi-sec-tag { display: inline-block; background: #ede9fe; color: #7c3aed; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.25rem 0.85rem; border-radius: 100px; margin-bottom: 0.6rem; }
.uvi-sec h2 { font-size: 1.9rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; }
.uvi-sec p { color: #6b7280; font-size: 0.9rem; }
.uvi-price-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
.uvi-price-card { background: #fff; border-radius: 14px; padding: 1.75rem 1rem 1.5rem; text-align: center; border: 2px solid #ede9fe; transition: all 0.25s; position: relative; }
.uvi-price-card.popular { border-color: #9333ea; box-shadow: 0 8px 32px rgba(147,51,234,0.18); }
.uvi-price-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(147,51,234,0.15); }
.uvi-popular-badge { position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: #9333ea; color: #fff; font-size: 0.6rem; font-weight: 700; padding: 3px 12px; border-radius: 100px; white-space: nowrap; letter-spacing: 0.05em; }
.uvi-price-icon { font-size: 2rem; display: block; margin-bottom: 0.6rem; }
.uvi-price-vehicle { font-size: 0.8rem; font-weight: 800; color: #7c3aed; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 0.4rem; }
.uvi-price-amount { font-size: 2rem; font-weight: 900; color: #1f2937; line-height: 1; }
.uvi-price-amount span { font-size: 0.75rem; font-weight: 600; color: #6b7280; }
.uvi-price-note { font-size: 0.72rem; color: #9ca3af; margin-top: 0.4rem; }
.uvi-price-footer { text-align: center; margin-top: 1.5rem; font-size: 0.82rem; color: #6b7280; }

/* WHAT IT REVEALS */
.uvi-reveals { background: #fff; padding: 4rem 0; }
.uvi-reveals-inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
.uvi-reveals-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2rem; }
.uvi-reveal-card { border-radius: 14px; padding: 1.5rem; border: 1px solid #e5e7eb; background: #fafafa; position: relative; overflow: hidden; transition: all 0.25s; }
.uvi-reveal-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(to right, #9333ea, #c084fc); }
.uvi-reveal-card:hover { box-shadow: 0 8px 24px rgba(147,51,234,0.1); transform: translateY(-3px); }
.uvi-reveal-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
.uvi-reveal-img { width: 100%; height: 160px; border-radius: 8px; overflow: hidden; margin-bottom: 0.75rem; }
.uvi-reveal-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.uvi-reveal-card h3 { font-size: 0.95rem; font-weight: 800; color: #1f2937; margin-bottom: 0.35rem; }
.uvi-reveal-card p { font-size: 0.8rem; color: #6b7280; line-height: 1.55; }

/* VIDEO / BEFORE-AFTER */
.uvi-media { background: #0d0d1a; padding: 4rem 0; }
.uvi-media-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }
.uvi-media h2 { font-size: 1.9rem; font-weight: 800; color: #fff; text-align: center; margin-bottom: 0.5rem; }
.uvi-media p { color: #c4b5fd; text-align: center; font-size: 0.9rem; margin-bottom: 2rem; }
.uvi-media-box { background: rgba(147,51,234,0.1); border: 2px dashed rgba(147,51,234,0.4); border-radius: 16px; padding: 3rem; text-align: center; color: #c4b5fd; }
.uvi-media-box-icon { font-size: 4rem; display: block; margin-bottom: 1rem; }
.uvi-media-upload { margin-top: 1rem; font-size: 0.8rem; color: #a78bfa; }
.uvi-media-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
.uvi-media-item { border-radius: 10px; overflow: hidden; aspect-ratio: 9/16; background: linear-gradient(135deg, #1e1b4b, #0d0d1a); cursor: pointer; position: relative; }
.uvi-media-item img, .uvi-media-item video { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
.uvi-media-item:hover img, .uvi-media-item:hover video { transform: scale(1.05); }
.uvi-play-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 44px; height: 44px; border-radius: 50%; background: rgba(147,51,234,0.6); display: flex; align-items: center; justify-content: center; pointer-events: none; }
@media (max-width: 768px) { .uvi-media-grid { grid-template-columns: repeat(2, 1fr); } }

/* PROCESS */
.uvi-process { background: #fff; padding: 4rem 0; }
.uvi-process-inner { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }
.uvi-steps { margin-top: 2rem; display: flex; flex-direction: column; gap: 0; }
.uvi-step { display: flex; gap: 1.25rem; padding-bottom: 2rem; position: relative; }
.uvi-step:last-child { padding-bottom: 0; }
.uvi-step-left { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.uvi-step-num { width: 2.5rem; height: 2.5rem; background: linear-gradient(135deg,#9333ea,#7c3aed); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; box-shadow: 0 4px 12px rgba(147,51,234,0.3); }
.uvi-step-line { width: 2px; flex: 1; background: #ede9fe; margin-top: 0.3rem; }
.uvi-step:last-child .uvi-step-line { display: none; }
.uvi-step h3 { font-size: 1rem; font-weight: 700; color: #1f2937; margin-bottom: 0.3rem; margin-top: 0.35rem; }
.uvi-step p { font-size: 0.85rem; color: #6b7280; line-height: 1.6; }

/* CTA */
.uvi-cta { background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #1e1b4b 100%); padding: 5rem 0; text-align: center; color: #fff; position: relative; overflow: hidden; }
.uvi-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(192,132,252,0.25) 0%, transparent 65%); }
.uvi-cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; padding: 0 1.5rem; }
.uvi-cta h2 { font-size: 2.25rem; font-weight: 900; margin-bottom: 0.75rem; }
.uvi-cta h2 em { font-style: normal; color: #e879f9; }
.uvi-cta p { color: #e9d5ff; margin-bottom: 2rem; font-size: 1rem; line-height: 1.7; }
.uvi-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

/* MOBILE */
@media (max-width: 900px) {
  .uvi-hero-inner { grid-template-columns: 1fr; }
  .uvi-hero-visual { display: none; }
  .uvi-price-grid { grid-template-columns: 1fr 1fr; }
  .uvi-reveals-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .uvi-hero { min-height: auto; }
  .uvi-hero-inner { padding: 3rem 1rem; }
  .uvi-hero h1 { font-size: 1.75rem; }
  .uvi-hero-sub { font-size: 0.95rem; }
  .uvi-hero-desc { font-size: 0.875rem; margin-bottom: 1.25rem; }
  .uvi-badge { font-size: 0.6rem; }
  .uvi-feat { font-size: 0.72rem; }
  .uvi-btn-row { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; }
  .uvi-btn-book, .uvi-btn-wa { flex: 1; justify-content: center; padding: 0.65rem 0.5rem; font-size: 0.78rem; white-space: nowrap; }
  .uvi-price-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .uvi-price-card { padding: 1.25rem 0.75rem; }
  .uvi-price-amount { font-size: 1.5rem; }
  .uvi-reveals-grid { grid-template-columns: 1fr; }
  .uvi-pricing { padding: 2.5rem 0; }
  .uvi-reveals { padding: 2.5rem 0; }
  .uvi-media { padding: 2.5rem 0; }
  .uvi-process { padding: 2.5rem 0; }
  .uvi-cta { padding: 3rem 0; }
  .uvi-cta h2 { font-size: 1.6rem; }
  .uvi-cta-btns { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; }
  .uvi-cta-btns a { flex: 1; justify-content: center; padding: 0.65rem 0.5rem; font-size: 0.78rem; white-space: nowrap; }
}
</style>

<div class="uvi">

  <!-- HERO -->
  <div class="uvi-hero">
    {%- if section.settings.bg_video != blank -%}
      <div class="uvi-hero-bg">
        <video src="{{ section.settings.bg_video.sources.last.url }}" autoplay muted loop playsinline></video>
      </div>
    {%- elsif section.settings.bg_image != blank -%}
      <div class="uvi-hero-bg">
        <img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="UV Paint Inspection">
      </div>
    {%- endif -%}
    <div class="uvi-hero-glow"></div>
    <div class="container">
      <div class="uvi-hero-inner">
        <div>
          <div class="uvi-badge">🔦 {{ section.settings.badge | default: "UV Light Inspection • Karachi" }}</div>
          <h1>{{ section.settings.h1_part1 | default: "UV Light" }} <em>{{ section.settings.h1_em | default: "Car Paint" }}</em><br>{{ section.settings.h1_part2 | default: "Inspection in Karachi" }}</h1>
          <p class="uvi-hero-sub">{{ section.settings.hero_sub | default: "See What the Naked Eye Can't" }}</p>
          <p class="uvi-hero-desc">{{ section.settings.hero_desc | default: "We use professional UV light devices in a darkened studio to reveal hidden repaint, rust, body filler, and paint defects — invisible under normal light. Know the true condition of your car before you buy, sell, or protect." }}</p>
          <div class="uvi-feat-row">
            {%- if section.settings.feat1 != blank -%}<span class="uvi-feat">{{ section.settings.feat1 }}</span>{%- endif -%}
            {%- if section.settings.feat2 != blank -%}<span class="uvi-feat">{{ section.settings.feat2 }}</span>{%- endif -%}
            {%- if section.settings.feat3 != blank -%}<span class="uvi-feat">{{ section.settings.feat3 }}</span>{%- endif -%}
            {%- if section.settings.feat4 != blank -%}<span class="uvi-feat">{{ section.settings.feat4 }}</span>{%- endif -%}
          </div>
          <div class="uvi-btn-row">
            <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-book">🔦 {{ section.settings.btn1 | default: "Book Inspection" }}</a>
            <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.btn2 | default: "WhatsApp Us" }}</a>
          </div>
        </div>
        <div class="uvi-hero-visual">
          <div class="uvi-uv-lamp">
            <span class="uvi-lamp-icon">🔦</span>
            <p class="uvi-lamp-text">Lights off. UV on. Hidden repaint, rust, filler — all revealed in seconds.</p>
          </div>
          <div class="uvi-stats-row">
            <div class="uvi-stat"><span class="uvi-stat-num">100%</span><span class="uvi-stat-lbl">Accuracy</span></div>
            <div class="uvi-stat"><span class="uvi-stat-num">30 Min</span><span class="uvi-stat-lbl">Full Inspection</span></div>
            <div class="uvi-stat"><span class="uvi-stat-num">4.9⭐</span><span class="uvi-stat-lbl">Google Rating</span></div>
            <div class="uvi-stat"><span class="uvi-stat-num">500+</span><span class="uvi-stat-lbl">Cars Inspected</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>



  <!-- WHAT UV REVEALS -->
  <div class="uvi-reveals">
    <div class="uvi-reveals-inner">
      <div class="uvi-sec">
        <div class="uvi-sec-tag">What We Find</div>
        <h2>{{ section.settings.reveals_title | default: "What UV Light Reveals on Your Car" }}</h2>
        <p>{{ section.settings.reveals_sub | default: "Things invisible under normal light — exposed under UV in seconds" }}</p>
      </div>
      <div class="uvi-reveals-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'reveal' -%}
          <div class="uvi-reveal-card">
            {%- if block.settings.image != blank -%}
              <div class="uvi-reveal-img"><img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" loading="lazy"></div>
            {%- else -%}
              <span class="uvi-reveal-icon">{{ block.settings.icon | default: "🔍" }}</span>
            {%- endif -%}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>



  <!-- PROCESS -->
  <div class="uvi-process">
    <div class="uvi-process-inner">
      <div class="uvi-sec">
        <div class="uvi-sec-tag">How It Works</div>
        <h2>{{ section.settings.process_title | default: "UV Paint Inspection — Step by Step" }}</h2>
        <p>{{ section.settings.process_sub | default: "Simple, fast, and honest — done in 30 minutes" }}</p>
      </div>
      <div class="uvi-steps">
        {%- assign step_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}
          <div class="uvi-step">
            <div class="uvi-step-left"><div class="uvi-step-num">{{ step_count }}</div><div class="uvi-step-line"></div></div>
            <div><h3>{{ block.settings.title }}</h3><p>{{ block.settings.description }}</p></div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>



  <!-- VIDEO / MEDIA SECTION -->
  <div class="uvi-media">
    <div class="uvi-media-inner">
      <h2>{{ section.settings.media_title | default: "Watch UV Inspection in Action" }}</h2>
      <p>{{ section.settings.media_sub | default: "See how hidden repaint and defects light up under our UV device" }}</p>
      <div class="uvi-media-grid">
        {%- for i in (1..4) -%}
          {%- assign vid_key = 'slot_vid_' | append: i -%}
          {%- assign img_key = 'slot_img_' | append: i -%}
          {%- assign vid = section.settings[vid_key] -%}
          {%- assign img = section.settings[img_key] -%}
          {%- if vid != blank or img != blank -%}
          <div class="uvi-media-item">
            {%- if vid != blank -%}
              <video src="{{ vid.sources.last.url }}" muted loop playsinline preload="metadata"
                onmouseover="this.play()" onmouseout="this.pause()"></video>
              <div class="uvi-play-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>
            {%- elsif img != blank -%}
              <img src="{{ img | image_url: width: 400 }}" alt="UV Inspection {{ i }}" loading="lazy">
            {%- endif -%}
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>



  <!-- PRICING -->
  <div class="uvi-pricing">
    <div class="uvi-pricing-inner">
      <div class="uvi-sec">
        <div class="uvi-sec-tag">Transparent Pricing</div>
        <h2>{{ section.settings.price_title | default: "UV Paint Inspection Pricing" }}</h2>
        <p>{{ section.settings.price_sub | default: "Flat rate per vehicle type — no hidden charges" }}</p>
      </div>
      <div class="uvi-price-grid">
        <div class="uvi-price-card">
          <div class="uvi-price-vehicle">Hatchback</div>
          <div class="uvi-price-amount">{{ section.settings.price_hatch | default: "5,500" }}<span> PKR</span></div>
          <div class="uvi-price-note">Swift, Mira, Cultus, Picanto</div>
        </div>
        <div class="uvi-price-card">
<div class="uvi-price-vehicle">Sedan</div>
          <div class="uvi-price-amount">{{ section.settings.price_sedan | default: "6,500" }}<span> PKR</span></div>
          <div class="uvi-price-note">Corolla, Civic, City, Sonata</div>
        </div>
        <div class="uvi-price-card">
          <div class="uvi-price-vehicle">SUV</div>
          <div class="uvi-price-amount">{{ section.settings.price_suv | default: "7,500" }}<span> PKR</span></div>
          <div class="uvi-price-note">Sportage, Tucson, Fortuner, MG ZS</div>
        </div>
        <div class="uvi-price-card">
          <div class="uvi-price-vehicle">XL SUV</div>
          <div class="uvi-price-amount">{{ section.settings.price_xlsuv | default: "10,000" }}<span> PKR</span></div>
          <div class="uvi-price-note">Prado, Land Cruiser, Patrol, Sequoia</div>
        </div>
      </div>
      <p class="uvi-price-footer">✅ Includes full panel-by-panel UV scan + verbal findings report. Written report available on request.</p>
    </div>
  </div>



  <!-- CTA -->
  <div class="uvi-cta">
    <div class="uvi-cta-inner">
      <h2>{{ section.settings.cta_title | default: "Don't Buy a Car Without" }} <em>{{ section.settings.cta_title_em | default: "UV Inspection" }}</em></h2>
      <p>{{ section.settings.cta_sub | default: "Book your UV paint inspection at Revive Auto Detailing Karachi — 30 minutes, honest report, zero pressure. Know exactly what you're buying or protecting." }}</p>
      <div class="uvi-cta-btns">
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-book">🔦 {{ section.settings.btn1 | default: "Book Inspection" }}</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.btn2 | default: "WhatsApp Us" }}</a>
      </div>
    </div>
  </div>

</div>


</div>
<script>
document.querySelectorAll('.uvi-faq-q').forEach(function(q){
  q.addEventListener('click',function(){
    var item=q.closest('.uvi-faq-item');
    var wasOpen=item.classList.contains('open');
    document.querySelectorAll('.uvi-faq-item').forEach(function(i){i.classList.remove('open');});
    if(!wasOpen)item.classList.add('open');
  });
});
</script>

