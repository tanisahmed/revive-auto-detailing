<style>
.uvi { font-family: 'Nunito Sans', sans-serif; }

/* HERO */
.uvi-hero { background: #0a0a0a; padding: 4.5rem 0; color: #fff; position: relative; overflow: hidden; min-height: 480px; display: flex; align-items: center; }
.uvi-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 65% 50%, rgba(30,58,138,0.35) 0%, transparent 70%); }
.uvi-hero-media { position:absolute; inset:0; z-index:0; }
.uvi-hero-media img, .uvi-hero-media video { width:100%; height:100%; object-fit:cover; }
.uvi-hero-overlay { position:absolute; inset:0; background: linear-gradient(to right, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.35) 100%); z-index:1; }
.uvi-hero-content { position:relative; z-index:2; max-width:600px; }
.uvi-hero-badge { display:inline-flex; align-items:center; background:rgba(30,58,138,0.4); border:1px solid rgba(96,165,250,0.3); padding:0.3rem 1rem; border-radius:100px; font-size:0.8rem; font-weight:700; color:#93c5fd; margin-bottom:1rem; letter-spacing:0.08em; text-transform:uppercase; }
.uvi-hero h1 { font-size:3rem; font-weight:800; line-height:1.1; margin-bottom:0.5rem; letter-spacing:-0.5px; }
.uvi-hero h1 span { color:#60a5fa; }
.uvi-hero-sub { font-size:1.35rem; font-weight:700; color:#60a5fa; margin-bottom:1rem; }
.uvi-hero-desc { font-size:1.05rem; color:#d1d5db; line-height:1.75; margin-bottom:1.75rem; max-width:520px; }
.uvi-hero-feats { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem; }
.uvi-hero-feat { background:rgba(255,255,255,0.08); padding:0.35rem 0.85rem; border-radius:100px; font-size:0.875rem; font-weight:600; }
.uvi-hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
.uvi-btn-blue { display:inline-flex; align-items:center; padding:0.875rem 1.75rem; background:#1e3a8a; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
.uvi-btn-blue:hover { background:#1e40af; }
.uvi-btn-wa { display:inline-flex; align-items:center; gap:0.4rem; padding:0.875rem 1.75rem; background:#10b981; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
.uvi-btn-wa:hover { background:#059669; }

/* WHAT IS — AEO answer box */
.uvi-what { padding:4rem 0; background:#fff; }
.uvi-what-inner { max-width:960px; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center; }
.uvi-tag { font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#1e3a8a; margin-bottom:0.6rem; }
.uvi-what h2 { font-size:1.9rem; font-weight:800; color:#1f2937; line-height:1.2; margin-bottom:1rem; }
.uvi-answer-box { background:#eff6ff; border-left:4px solid #1e3a8a; border-radius:0 10px 10px 0; padding:1.25rem 1.5rem; margin-bottom:1.25rem; }
.uvi-answer-box p { font-size:0.95rem; color:#1e40af; line-height:1.75; margin:0; font-weight:500; }
.uvi-what-detail { font-size:0.9rem; color:#6b7280; line-height:1.7; }
.uvi-what-video { border-radius:16px; overflow:hidden; background:#0f172a; aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; position:relative; }
.uvi-what-video video { width:100%; height:100%; object-fit:cover; }
.uvi-what-video-ph { font-size:4rem; opacity:0.4; }

/* REVEALS */
.uvi-reveals { padding:4rem 0; background:#f8fafc; }
.uvi-reveals-inner { max-width:1060px; margin:0 auto; padding:0 1.5rem; }
.uvi-sec-hdr { text-align:center; margin-bottom:2.5rem; }
.uvi-sec-hdr h2 { font-size:2rem; font-weight:800; color:#1f2937; margin-bottom:0.5rem; }
.uvi-sec-hdr p { color:#6b7280; font-size:0.95rem; max-width:600px; margin:0 auto; }
.uvi-reveals-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; }
.uvi-reveal-card { background:#fff; border-radius:12px; padding:1.5rem; border:1px solid #e5e7eb; border-top:3px solid #1e3a8a; }
.uvi-reveal-icon { font-size:2rem; margin-bottom:0.75rem; display:block; }
.uvi-reveal-card h3 { font-size:0.95rem; font-weight:800; color:#1f2937; margin-bottom:0.4rem; }
.uvi-reveal-card p { font-size:0.82rem; color:#6b7280; line-height:1.55; }

/* PRICING */
.uvi-pricing { padding:4rem 0; background:#fff; }
.uvi-pricing-inner { max-width:680px; margin:0 auto; padding:0 1.5rem; }
.uvi-price-cards { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-top:2rem; }
.uvi-price-card { background:#f8fafc; border:1px solid #e5e7eb; border-radius:12px; padding:1.5rem 1rem; text-align:center; transition:all 0.2s; }
.uvi-price-card:hover { border-color:#1e3a8a; box-shadow:0 4px 16px rgba(30,58,138,0.1); transform:translateY(-2px); }
.uvi-price-card.featured { background:#1e3a8a; border-color:#1e3a8a; color:#fff; }
.uvi-price-veh { font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#6b7280; margin-bottom:0.5rem; }
.uvi-price-card.featured .uvi-price-veh { color:#93c5fd; }
.uvi-price-amount { font-size:1.75rem; font-weight:800; color:#1e3a8a; display:block; }
.uvi-price-card.featured .uvi-price-amount { color:#fff; }
.uvi-price-label { font-size:0.72rem; color:#9ca3af; }
.uvi-price-card.featured .uvi-price-label { color:#bfdbfe; }
.uvi-price-note { font-size:0.8rem; color:#9ca3af; text-align:center; margin-top:1.25rem; }
.uvi-price-cta { text-align:center; margin-top:1.75rem; }

/* PROCESS */
.uvi-process { padding:4rem 0; background:#f8fafc; }
.uvi-process-inner { max-width:760px; margin:0 auto; padding:0 1.5rem; }
.uvi-steps { display:flex; flex-direction:column; gap:0; margin-top:2rem; }
.uvi-step { display:flex; gap:1.5rem; padding-bottom:2rem; }
.uvi-step:last-child { padding-bottom:0; }
.uvi-step-left { display:flex; flex-direction:column; align-items:center; }
.uvi-step-num { width:2.5rem; height:2.5rem; border-radius:50%; background:#1e3a8a; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.9rem; flex-shrink:0; }
.uvi-step-line { width:2px; background:#e5e7eb; flex:1; margin-top:0.25rem; }
.uvi-step:last-child .uvi-step-line { display:none; }
.uvi-step-body h3 { font-size:1rem; font-weight:700; color:#1f2937; margin-bottom:0.3rem; }
.uvi-step-body p { font-size:0.875rem; color:#6b7280; line-height:1.6; }

/* WHY MATTERS */
.uvi-why { padding:4rem 0; background:#fff; }
.uvi-why-inner { max-width:960px; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start; }
.uvi-why h2 { font-size:1.9rem; font-weight:800; color:#1f2937; margin-bottom:1rem; line-height:1.2; }
.uvi-why-list { display:flex; flex-direction:column; gap:0.85rem; }
.uvi-why-item { display:flex; align-items:flex-start; gap:0.75rem; }
.uvi-why-check { width:1.5rem; height:1.5rem; border-radius:50%; background:#1e3a8a; display:flex; align-items:center; justify-content:center; font-size:0.65rem; color:#fff; flex-shrink:0; margin-top:2px; }
.uvi-why-text h4 { font-size:0.9rem; font-weight:700; color:#1f2937; margin-bottom:0.15rem; }
.uvi-why-text p { font-size:0.8rem; color:#6b7280; line-height:1.55; }
.uvi-why-box { background:linear-gradient(135deg,#1e3a8a,#1e1b4b); border-radius:14px; padding:2rem; color:#fff; }
.uvi-why-box h3 { font-size:1.1rem; font-weight:800; margin-bottom:0.75rem; }
.uvi-why-box p { font-size:0.875rem; color:#bfdbfe; line-height:1.7; margin-bottom:1.25rem; }
.uvi-why-box a { display:inline-flex; padding:0.75rem 1.5rem; background:#fff; color:#1e3a8a; border-radius:8px; font-weight:700; font-size:0.875rem; text-decoration:none; }

/* FAQ */
.uvi-faq { padding:4rem 0; background:#f8fafc; }
.uvi-faq-inner { max-width:760px; margin:0 auto; padding:0 1.5rem; }
.uvi-faq-list { display:flex; flex-direction:column; gap:0.75rem; margin-top:2rem; }
.uvi-faq-item { background:#fff; border-radius:10px; border:1px solid #e5e7eb; overflow:hidden; }
.uvi-faq-q { display:flex; justify-content:space-between; align-items:center; padding:1rem 1.25rem; cursor:pointer; font-weight:700; font-size:0.925rem; color:#1f2937; user-select:none; }
.uvi-faq-q:hover { color:#1e3a8a; }
.uvi-faq-icon { font-size:1.25rem; transition:transform 0.25s; flex-shrink:0; }
.uvi-faq-item.open .uvi-faq-icon { transform:rotate(45deg); }
.uvi-faq-a { max-height:0; overflow:hidden; transition:max-height 0.35s ease; }
.uvi-faq-item.open .uvi-faq-a { max-height:400px; }
.uvi-faq-a p { padding:0 1.25rem 1.1rem; font-size:0.875rem; color:#4b5563; line-height:1.7; }

/* CTA */
.uvi-cta { padding:4rem 0; background:linear-gradient(135deg,#1e3a8a,#0f172a); text-align:center; color:#fff; }
.uvi-cta-inner { max-width:600px; margin:0 auto; padding:0 1.5rem; }
.uvi-cta h2 { font-size:2rem; font-weight:800; margin-bottom:0.75rem; }
.uvi-cta p { color:#bfdbfe; margin-bottom:2rem; font-size:1rem; }
.uvi-cta-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

/* MOBILE */
@media (max-width:900px) {
  .uvi-what-inner, .uvi-why-inner { grid-template-columns:1fr; }
  .uvi-reveals-grid { grid-template-columns:1fr 1fr; }
  .uvi-price-cards { grid-template-columns:1fr 1fr; }
}
@media (max-width:640px) {
  .uvi-hero { padding:2.25rem 0; min-height:auto; }
  .uvi-hero-content { padding:0 1rem; }
  .uvi-hero h1 { font-size:1.65rem; line-height:1.25; }
  .uvi-hero-sub { font-size:0.95rem; }
  .uvi-hero-desc { font-size:0.88rem; margin-bottom:1.25rem; }
  .uvi-hero-badge { font-size:0.65rem; }
  .uvi-hero-feat { font-size:0.7rem; padding:0.3rem 0.6rem; }
  .uvi-hero-btns { flex-direction:row; flex-wrap:nowrap; gap:0.5rem; }
  .uvi-btn-blue, .uvi-btn-wa { flex:1; justify-content:center; text-align:center; padding:0.65rem 0.5rem; font-size:0.78rem; white-space:nowrap; }
  .uvi-reveals-grid { grid-template-columns:1fr; }
  .uvi-price-cards { grid-template-columns:1fr 1fr; gap:0.75rem; }
  .uvi-price-amount { font-size:1.35rem; }
  .uvi-sec-hdr h2 { font-size:1.4rem; }
  .uvi-what, .uvi-reveals, .uvi-pricing, .uvi-process, .uvi-why, .uvi-faq, .uvi-cta { padding:2rem 0; }
  .uvi-cta h2 { font-size:1.4rem; }
  .uvi-cta-btns { flex-direction:row; flex-wrap:nowrap; gap:0.5rem; }
  .uvi-cta-btns a { flex:1; justify-content:center; text-align:center; padding:0.65rem 0.5rem; font-size:0.78rem; white-space:nowrap; }
}
</style>

<div class="uvi">

  <!-- HERO -->
  <div class="uvi-hero">
    {%- if section.settings.bg_video != blank -%}
      <div class="uvi-hero-media"><video src="{{ section.settings.bg_video.sources.last.url }}" autoplay muted loop playsinline></video></div>
      <div class="uvi-hero-overlay"></div>
    {%- elsif section.settings.bg_image != blank -%}
      <div class="uvi-hero-media"><img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="UV Paint Inspection Karachi" loading="eager"></div>
      <div class="uvi-hero-overlay"></div>
    {%- endif -%}
    <div class="container">
      <div class="uvi-hero-content">
        <div class="uvi-hero-badge">🔦 {{ section.settings.badge | default: "UV Paint Inspection • Karachi" }}</div>
        <h1>{{ section.settings.h1_1 | default: "UV Light" }} <span>{{ section.settings.h1_2 | default: "Car Paint Inspection" }}</span> {{ section.settings.h1_3 | default: "in Karachi" }}</h1>
        <p class="uvi-hero-sub">{{ section.settings.hero_sub | default: "See What the Naked Eye Can't" }}</p>
        <p class="uvi-hero-desc">{{ section.settings.hero_desc | default: "We use professional UV light devices to inspect your car's paint in a darkened studio — revealing hidden repaint, fading, rust, and body filler before you buy or apply any protection." }}</p>
        <div class="uvi-hero-feats">
          {%- if section.settings.feat1 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat1 }}</span>{%- endif -%}
          {%- if section.settings.feat2 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat2 }}</span>{%- endif -%}
          {%- if section.settings.feat3 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat3 }}</span>{%- endif -%}
          {%- if section.settings.feat4 != blank -%}<span class="uvi-hero-feat">{{ section.settings.feat4 }}</span>{%- endif -%}
        </div>
        <div class="uvi-hero-btns">
          <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-blue">{{ section.settings.btn1 | default: "Book Inspection" }}</a>
          <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.btn2 | default: "WhatsApp Us" }}</a>
        </div>
      </div>
    </div>
  </div>

  <!-- WHAT IS UV INSPECTION — AEO Answer Box -->
  <div class="uvi-what">
    <div class="uvi-what-inner">
      <div>
        <div class="uvi-tag">What is it?</div>
        <h2>{{ section.settings.what_h2 | default: "What is UV Light Car Paint Inspection?" }}</h2>
        <div class="uvi-answer-box">
          <p>{{ section.settings.what_answer | default: "UV Light Car Paint Inspection is a process where a professional UV (ultraviolet) light device is used in a darkened environment to examine a car's paint. Original factory paint appears uniform under UV light, while repainted panels, fading, rust, and body filler glow differently — revealing hidden defects invisible to the naked eye." }}</p>
        </div>
        <p class="uvi-what-detail">{{ section.settings.what_detail | default: "At Revive Auto Detailing Karachi, we perform UV paint inspections to give you a clear, honest report of your car's paint condition — before you buy, before you protect, and before you sell." }}</p>
      </div>
      <div class="uvi-what-video">
        {%- if section.settings.demo_video != blank -%}
          <video src="{{ section.settings.demo_video.sources.last.url }}" controls muted loop playsinline style="width:100%;height:100%;object-fit:cover;"></video>
        {%- elsif section.settings.demo_image != blank -%}
          <img src="{{ section.settings.demo_image | image_url: width: 800 }}" alt="UV Inspection Demo" style="width:100%;height:100%;object-fit:cover;">
        {%- else -%}
          <span class="uvi-what-video-ph">🔦</span>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- WHAT UV REVEALS -->
  <div class="uvi-reveals">
    <div class="uvi-reveals-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.reveals_h2 | default: "What Does UV Light Reveal on Car Paint?" }}</h2>
        <p>{{ section.settings.reveals_sub | default: "Hidden paint problems that only show up under UV light" }}</p>
      </div>
      <div class="uvi-reveals-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'reveal' -%}
          <div class="uvi-reveal-card">
            <span class="uvi-reveal-icon">{{ block.settings.icon | default: "🔍" }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- PRICING -->
  <div class="uvi-pricing" id="uvi-pricing">
    <div class="uvi-pricing-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.price_h2 | default: "UV Paint Inspection Pricing" }}</h2>
        <p>{{ section.settings.price_sub | default: "Flat-rate pricing by vehicle type — no hidden charges" }}</p>
      </div>
      <div class="uvi-price-cards">
        <div class="uvi-price-card">
          <div class="uvi-price-veh">Hatchback</div>
          <span class="uvi-price-amount">Rs {{ section.settings.p_hatch | default: "5,500" }}</span>
          <div class="uvi-price-label">Full UV Inspection</div>
        </div>
        <div class="uvi-price-card featured">
          <div class="uvi-price-veh">Sedan</div>
          <span class="uvi-price-amount">Rs {{ section.settings.p_sedan | default: "6,500" }}</span>
          <div class="uvi-price-label">Full UV Inspection</div>
        </div>
        <div class="uvi-price-card">
          <div class="uvi-price-veh">SUV</div>
          <span class="uvi-price-amount">Rs {{ section.settings.p_suv | default: "7,500" }}</span>
          <div class="uvi-price-label">Full UV Inspection</div>
        </div>
        <div class="uvi-price-card">
          <div class="uvi-price-veh">XL SUV</div>
          <span class="uvi-price-amount">Rs {{ section.settings.p_xlsuv | default: "10,000" }}</span>
          <div class="uvi-price-label">Full UV Inspection</div>
        </div>
      </div>
      <p class="uvi-price-note">{{ section.settings.price_note | default: "* Includes full panel-by-panel UV inspection + written report. Book in advance to secure your slot." }}</p>
      <div class="uvi-price-cta">
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-blue">🔦 Book My Inspection</a>
      </div>
    </div>
  </div>

  <!-- PROCESS -->
  <div class="uvi-process">
    <div class="uvi-process-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.process_h2 | default: "How UV Paint Inspection Works at Revive" }}</h2>
        <p>{{ section.settings.process_sub | default: "Simple, transparent, and takes less than an hour" }}</p>
      </div>
      <div class="uvi-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
          <div class="uvi-step">
            <div class="uvi-step-left"><div class="uvi-step-num">{{ forloop.index }}</div><div class="uvi-step-line"></div></div>
            <div class="uvi-step-body"><h3>{{ block.settings.title }}</h3><p>{{ block.settings.description }}</p></div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- WHY IT MATTERS -->
  <div class="uvi-why">
    <div class="uvi-why-inner">
      <div>
        <div class="uvi-tag">Why it matters</div>
        <h2>{{ section.settings.why_h2 | default: "Why UV Paint Inspection Matters Before Buying a Used Car in Pakistan" }}</h2>
        <div class="uvi-why-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'why_item' -%}
            <div class="uvi-why-item">
              <div class="uvi-why-check">✓</div>
              <div class="uvi-why-text"><h4>{{ block.settings.title }}</h4><p>{{ block.settings.description }}</p></div>
            </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <div class="uvi-why-box">
        <h3>🔦 Book a UV Paint Inspection</h3>
        <p>Bring your car to our Karachi studio. Lights go off, UV light goes on — within 30–60 minutes you'll know the true paint condition of every panel.</p>
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}">Book Now →</a>
      </div>
    </div>
  </div>

  <!-- FAQ — AEO/GEO -->
  <div class="uvi-faq">
    <div class="uvi-faq-inner">
      <div class="uvi-sec-hdr">
        <h2>{{ section.settings.faq_h2 | default: "Frequently Asked Questions — UV Paint Inspection Karachi" }}</h2>
        <p>{{ section.settings.faq_sub | default: "Common questions about UV light car paint inspection in Pakistan" }}</p>
      </div>
      <div class="uvi-faq-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
          <div class="uvi-faq-item">
            <div class="uvi-faq-q">{{ block.settings.question }}<span class="uvi-faq-icon">+</span></div>
            <div class="uvi-faq-a"><p>{{ block.settings.answer }}</p></div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="uvi-cta">
    <div class="uvi-cta-inner">
      <h2>{{ section.settings.cta_h2 | default: "Know Your Car's True Paint Condition" }}</h2>
      <p>{{ section.settings.cta_sub | default: "Book a UV paint inspection at Revive Auto Detailing Karachi — before you buy, before you protect, before you sell." }}</p>
      <div class="uvi-cta-btns">
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="uvi-btn-blue">🔦 {{ section.settings.btn1 | default: "Book Inspection" }}</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20UV%20paint%20inspection%20for%20my%20car" target="_blank" class="uvi-btn-wa">💬 {{ section.settings.btn2 | default: "WhatsApp Us" }}</a>
      </div>
    </div>
  </div>

</div>

<script>
document.querySelectorAll('.uvi-faq-q').forEach(function(q){
  q.addEventListener('click',function(){
    var item=q.closest('.uvi-faq-item');
    var wasOpen=item.classList.contains('open');
    document.querySelectorAll('.uvi-faq-item').forEach(function(i){i.classList.remove('open');});
    if(!wasOpen)item.classList.add('open');
  });
});
</script>

{% schema %}
{
  "name": "UV Paint Inspection Page",
