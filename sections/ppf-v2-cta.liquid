<style>
.ppf2-cta { padding: 4.5rem 0; background: linear-gradient(135deg, #0c1e3f, #1e3a8a); font-family: 'Nunito Sans', sans-serif; text-align: center; position: relative; overflow: hidden; }
.ppf2-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 100%, rgba(59,130,246,0.2) 0%, transparent 60%); }
.ppf2-cta-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; padding: 0 1.5rem; }
.ppf2-cta h2 { font-size: 2.25rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem; line-height: 1.2; }
.ppf2-cta p { color: #94a3b8; font-size: 1rem; line-height: 1.7; margin-bottom: 2rem; }
.ppf2-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
.ppf2-cta-btn1 { padding: 1rem 2.25rem; background: #fff; color: #1e3a8a; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.ppf2-cta-btn1:hover { background: #f1f5f9; transform: translateY(-2px); }
.ppf2-cta-btn2 { padding: 1rem 2.25rem; background: #10b981; color: #fff; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; display: flex; align-items: center; gap: 0.5rem; }
.ppf2-cta-btn2:hover { background: #059669; transform: translateY(-2px); }
.ppf2-cta-trust { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
.ppf2-cta-trust-item { font-size: 0.8rem; color: #64748b; display: flex; align-items: center; gap: 0.4rem; font-weight: 600; }
</style>

<section class="ppf2-cta">
  <div class="ppf2-cta-inner">
    <h2>{{ section.settings.title | default: "Ready to Protect Your Car?" }}</h2>
    <p>{{ section.settings.subtitle | default: "Book your free consultation today. Our team will walk you through the best package for your car and budget — with zero pressure." }}</p>
    <div class="ppf2-cta-btns">
      <a href="{{ section.settings.btn1_url | default: '/pages/ppf-booking' }}" class="ppf2-cta-btn1">{{ section.settings.btn1_text | default: "Book My Appointment" }}</a>
      <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20enquire%20about%20PPF" target="_blank" class="ppf2-cta-btn2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
    </div>
    <div class="ppf2-cta-trust">
      <div class="ppf2-cta-trust-item">✅ NAR Certified Studio</div>
      <div class="ppf2-cta-trust-item">⭐ 4.9 Google Rating</div>
      <div class="ppf2-cta-trust-item">🛡 5–7 Year Warranty</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPF V2 CTA",
  "settings": [
    {"type":"text","id":"title","label":"Heading","default":"Ready to Protect Your Car?"},
    {"type":"textarea","id":"subtitle","label":"Subtext","default":"Book your free consultation today. Our team will walk you through the best package for your car and budget — with zero pressure."},
    {"type":"text","id":"btn1_text","label":"Button 1 Text","default":"Book My Appointment"},
    {"type":"url","id":"btn1_url","label":"Button 1 Link"}
  ],
  "presets":[{"name":"PPF V2 CTA"}]
}
{% endschema %}
