<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #000;
    border-bottom: 1px solid #222;
    box-shadow: 0 1px 8px rgba(0,0,0,0.4);
  }
  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 4.5rem;
    gap: 1rem;
  }
  .header-left { display: flex; align-items: center; justify-content: flex-start; }
  .header-center { display: flex; justify-content: center; align-items: center; }
  .header-right { display: flex; align-items: center; justify-content: flex-end; }

  /* Logo */
  .header-logo-link { display: flex; align-items: center; text-decoration: none; }
  .header-logo-link img { height: 48px; width: auto; object-fit: contain; display: block; }
  .header-logo-text { font-size: 1.75rem; font-weight: 800; color: #fff; letter-spacing: -0.5px; font-family: 'Nunito Sans', sans-serif; }

  /* Nav */
  .header-nav { display: flex; align-items: center; gap: 0.1rem; }
  .nav-item { position: relative; }
  .nav-link {
    display: flex; align-items: center; gap: 0.25rem;
    padding: 0.5rem 0.75rem; font-weight: 600; font-size: 0.9rem;
    color: #d1d5db; border-radius: 6px; transition: all 0.2s;
    cursor: pointer; border: none; background: none;
    font-family: 'Nunito Sans', sans-serif; text-decoration: none; white-space: nowrap;
  }
  .nav-link:hover { background: #1a1a1a; color: #fff; }
  .nav-arrow { font-size: 0.6rem; color: #6b7280; }
  .dropdown-menu {
    position: absolute; top: calc(100% + 0.5rem); left: 0;
    min-width: 210px; background: #111; border: 1px solid #333;
    border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    padding: 0.5rem; opacity: 0; visibility: hidden;
    transform: translateY(-8px); transition: all 0.2s; z-index: 200;
  }
  .nav-item:hover .dropdown-menu,
  .nav-item:focus-within .dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-link {
    display: block; padding: 0.6rem 0.85rem; font-size: 0.875rem;
    font-weight: 600; color: #d1d5db; border-radius: 6px;
    transition: all 0.2s; text-decoration: none;
  }
  .dropdown-link:hover { background: #222; color: #fff; }

  /* Phone */
  .header-phone {
    display: flex; align-items: center; gap: 0.4rem;
    font-weight: 700; font-size: 0.875rem; color: #fff;
    padding: 0.5rem 1rem; border: 2px solid #1e3a8a;
    border-radius: 8px; background: #1e3a8a; white-space: nowrap;
    text-decoration: none; transition: all 0.2s;
  }
  .header-phone:hover { background: #1e40af; border-color: #1e40af; }

  /* Hamburger */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    cursor: pointer; background: none; border: none;
    padding: 0.4rem; border-radius: 6px;
  }
  .hamburger:hover { background: #1a1a1a; }
  .hamburger span { display: block; width: 24px; height: 2.5px; background: #fff; border-radius: 2px; transition: all 0.25s; }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* Mobile Menu */
  .mobile-menu {
    display: none; position: fixed; top: 4.5rem; left: 0; right: 0; bottom: 0;
    background: #000; z-index: 99; padding: 1.5rem; overflow-y: auto;
    flex-direction: column; gap: 0.25rem; border-top: 1px solid #222;
  }
  .mobile-menu.open { display: flex; }
  .mobile-nav-link {
    display: block; padding: 0.85rem 1rem; font-weight: 600; font-size: 1rem;
    color: #d1d5db; border-radius: 8px; border-bottom: 1px solid #1a1a1a;
    text-decoration: none; transition: all 0.2s;
  }
  .mobile-nav-link:hover { background: #1a1a1a; color: #fff; }
  .mob-toggle { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
  .mob-toggle .arr { transition: transform 0.2s; color: #6b7280; font-size: 0.8rem; }
  .mob-toggle.expanded .arr { transform: rotate(180deg); }
  .mob-sub { display: none; padding-left: 1rem; }
  .mob-sub.open { display: block; }
  .mobile-phone {
    margin-top: 1rem; display: flex; align-items: center; justify-content: center;
    gap: 0.5rem; padding: 0.85rem; background: #1e3a8a; color: #fff;
    border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none;
  }
  .mobile-phone:hover { background: #1e40af; }

  @media (max-width: 900px) {
    .header-nav { display: none; }
    .header-right { display: none; }
    .hamburger { display: flex; }
  }
  @media (min-width: 901px) {
    .mobile-menu { display: none !important; }
    .hamburger { display: none !important; }
  }
</style>

<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <!-- LEFT: Nav (desktop) / Hamburger (mobile) -->
      <div class="header-left">
        <button class="hamburger" id="rad-hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="header-nav" role="navigation" aria-label="Main navigation">
          <!-- Home -->
          <div class="nav-item">
            <a class="nav-link" href="/">
              {{ section.settings.nav_label_1 | default: 'Home' }}
            </a>
          </div>
          <!-- About -->
          <div class="nav-item">
            <a class="nav-link" href="/pages/about-us">
              {{ section.settings.nav_label_2 | default: 'About Us' }}
            </a>
          </div>
          <!-- Services Dropdown -->
          <div class="nav-item">
            <button class="nav-link" aria-haspopup="true">
              {{ section.settings.nav_label_3 | default: 'Services' }}
              <span class="nav-arrow">&#9660;</span>
            </button>
            <div class="dropdown-menu" role="menu">
              <a class="dropdown-link" href="/pages/paint-protection-film-ppf">Paint Protection Film (PPF)</a>
              <a class="dropdown-link" href="/pages/ceramic-coating">Ceramic Coating</a>
              <a class="dropdown-link" href="/pages/car-window-tints">Car Window Tint</a>
              <a class="dropdown-link" href="/pages/car-detailing">Exterior &amp; Interior Detailing</a>
              <a class="dropdown-link" href="/pages/car-anti-rust-undercoating">Anti-Rust Undercoating</a>
              <a class="dropdown-link" href="/pages/color-paint-protection-ppf">Color Paint Protection Film</a>
              <a class="dropdown-link" href="/pages/denting-painting-karachi">Denting &amp; Painting</a>
              <a class="dropdown-link" href="/pages/uv-paint-inspection-karachi">UV Light Paint Inspection</a>
              <div style="border-top:1px solid #333;margin:0.4rem 0.3rem;"></div>
              <a class="dropdown-link" href="/pages/all-services" style="color:#60a5fa;">View All Services →</a>
            </div>
          </div>
          <!-- Contact -->
          <div class="nav-item">
            <a class="nav-link" href="/pages/contact">
              {{ section.settings.nav_label_4 | default: 'Contact' }}
            </a>
          </div>
          <!-- More Dropdown -->
          <div class="nav-item">
            <button class="nav-link" aria-haspopup="true">
              {{ section.settings.nav_label_5 | default: 'More' }}
              <span class="nav-arrow">&#9660;</span>
            </button>
            <div class="dropdown-menu" role="menu">
              <a class="dropdown-link" href="/pages/book-appointment">Book Appointment</a>
              <a class="dropdown-link" href="/pages/faq">FAQ</a>
            </div>
          </div>
        </nav>
      </div>

      <!-- CENTER: Logo -->
      <div class="header-center">
        <a href="/" class="header-logo-link">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: height: 96 }}"
                 alt="{{ shop.name }}" height="48" loading="eager">
          {%- else -%}
            <span class="header-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- RIGHT: Phone -->
      <div class="header-right">
        <a href="tel:{{ section.settings.phone | default: '+923037231111' }}" class="header-phone">
          &#128222; {{ section.settings.phone_display | default: '+92 303 7231111' }}
        </a>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <nav class="mobile-menu" id="rad-mobile-menu">
    <a class="mobile-nav-link" href="/">Home</a>
    <a class="mobile-nav-link" href="/pages/about-us">About Us</a>
    <div>
      <div class="mobile-nav-link mob-toggle" id="mob-tog-3">
        Services <span class="arr">&#9660;</span>
      </div>
      <div class="mob-sub" id="mob-sub-3">
        <a class="mobile-nav-link" href="/pages/paint-protection-film-ppf">Paint Protection Film (PPF)</a>
        <a class="mobile-nav-link" href="/pages/ceramic-coating">Ceramic Coating</a>
        <a class="mobile-nav-link" href="/pages/car-window-tints">Car Window Tint</a>
        <a class="mobile-nav-link" href="/pages/car-detailing">Exterior &amp; Interior Detailing</a>
        <a class="mobile-nav-link" href="/pages/car-anti-rust-undercoating">Anti-Rust Undercoating</a>
              <a class="mobile-nav-link" href="/pages/color-paint-protection-ppf">Color Paint Protection Film</a>
              <a class="mobile-nav-link" href="/pages/denting-painting-karachi">Denting &amp; Painting</a>
              <a class="mobile-nav-link" href="/pages/uv-paint-inspection-karachi">UV Light Paint Inspection</a>
              <a class="mobile-nav-link" href="/pages/all-services" style="color:#60a5fa;font-weight:700;">View All Services →</a>
      </div>
    </div>
    <a class="mobile-nav-link" href="/pages/all-services">All Services</a>
    <a class="mobile-nav-link" href="/pages/contact">Contact</a>
    <div>
      <div class="mobile-nav-link mob-toggle" id="mob-tog-5">
        More <span class="arr">&#9660;</span>
      </div>
      <div class="mob-sub" id="mob-sub-5">
        <a class="mobile-nav-link" href="/pages/ppf-booking">Book Appointment</a>
        <a class="mobile-nav-link" href="/pages/faq">FAQ</a>
      </div>
    </div>
    <a href="tel:{{ section.settings.phone | default: '+923037231111' }}" class="mobile-phone">
      &#128222; {{ section.settings.phone_display | default: '+92 303 7231111' }}
    </a>
  </nav>
</header>

<script>
(function(){
  var ham  = document.getElementById('rad-hamburger');
  var menu = document.getElementById('rad-mobile-menu');
  var t3   = document.getElementById('mob-tog-3');
  var s3   = document.getElementById('mob-sub-3');
  var t5   = document.getElementById('mob-tog-5');
  var s5   = document.getElementById('mob-sub-5');
  if(ham) ham.addEventListener('click', function(){
    var o = menu.classList.toggle('open');
    ham.classList.toggle('open', o);
    ham.setAttribute('aria-expanded', o);
    document.body.style.overflow = o ? 'hidden' : '';
  });
  if(t3) t3.addEventListener('click', function(){ var o=s3.classList.toggle('open'); t3.classList.toggle('expanded',o); });
  if(t5) t5.addEventListener('click', function(){ var o=s5.classList.toggle('open'); t5.classList.toggle('expanded',o); });
  window.addEventListener('resize', function(){
    if(window.innerWidth>900 && menu){
      menu.classList.remove('open');
      if(ham) ham.classList.remove('open');
      document.body.style.overflow='';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image",
      "info": "PNG transparent background. Height: 48px."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (agar image nahi)",
      "default": "RAD"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+923037231111"
    },
    {
      "type": "text",
      "id": "phone_display",
      "label": "Phone Display Text",
      "default": "+92 303 7231111"
    },
    {
      "type": "header",
      "content": "Menu Labels"
    },
    {
      "type": "text",
      "id": "nav_label_1",
      "label": "Menu Item 1",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "nav_label_2",
      "label": "Menu Item 2",
      "default": "About Us"
    },
    {
      "type": "text",
      "id": "nav_label_3",
      "label": "Menu Item 3 (Services)",
      "default": "Services"
    },
    {
      "type": "text",
      "id": "nav_label_4",
      "label": "Menu Item 4",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "nav_label_5",
      "label": "Menu Item 5 (More)",
      "default": "More"
    }
  ]
}
{% endschema %}

