<style>
.rad-cform { padding: 2rem 0; background: #fff; }
.rad-cform-wrap { max-width: 42rem; margin: 0 auto; background: #f3f4f6; border-radius: 12px; padding: 2.5rem; }
.rad-cform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.rad-cform-group { margin-bottom: 1.25rem; }
.rad-cform-label { display: block; font-weight: 600; margin-bottom: 0.4rem; font-size: 0.95rem; color: #1f2937; }
.rad-cform-label span { color: #ef4444; }
.rad-cform-input { width: 100%; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; font-family: 'Nunito Sans', sans-serif; color: #1f2937; background: #fff; outline: none; transition: border 0.2s; }
.rad-cform-input:focus { border-color: #1e3a8a; box-shadow: 0 0 0 3px rgba(30,58,138,0.12); }
.rad-cform-error { color: #ef4444; font-size: 0.8rem; margin-top: 0.3rem; display: none; }
.rad-cform-error.show { display: block; }
.rad-cform-btn { width: 100%; padding: 0.875rem; background: #1e3a8a; color: #fff; border: none; border-radius: 8px; font-family: 'Nunito Sans', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.2s; }
.rad-cform-btn:hover { background: #1e40af; }
.rad-cform-success { display: none; text-align: center; padding: 2rem; }
.rad-cform-success.show { display: block; }
@media (max-width: 640px) { .rad-cform { padding: 1.5rem 0; } .rad-cform-row { grid-template-columns: 1fr; } .rad-cform-wrap { padding: 1.5rem 1.25rem; } }
</style>

<section class="rad-cform">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title | default: "Get Your Free Estimate" }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle | default: "Fill out the form below and we'll get back to you with a personalized quote." }}</p>
    <div class="rad-cform-wrap">
      <form id="rad-cf" novalidate>
        <div class="rad-cform-row">
          <div class="rad-cform-group">
            <label class="rad-cform-label" for="cf-fname">First Name <span>*</span></label>
            <input type="text" id="cf-fname" class="rad-cform-input" placeholder="Ahmed" required>
            <div class="rad-cform-error" id="cf-err-fname">Enter your first name</div>
          </div>
          <div class="rad-cform-group">
            <label class="rad-cform-label" for="cf-lname">Last Name <span>*</span></label>
            <input type="text" id="cf-lname" class="rad-cform-input" placeholder="Khan" required>
            <div class="rad-cform-error" id="cf-err-lname">Enter your last name</div>
          </div>
        </div>
        <div class="rad-cform-row">
          <div class="rad-cform-group">
            <label class="rad-cform-label" for="cf-phone">WhatsApp Number <span>*</span></label>
            <input type="tel" id="cf-phone" class="rad-cform-input" placeholder="+92 3XX XXXXXXX" required>
            <div class="rad-cform-error" id="cf-err-phone">Enter a valid number</div>
          </div>
          <div class="rad-cform-group">
            <label class="rad-cform-label" for="cf-email">Email Address <span>*</span></label>
            <input type="email" id="cf-email" class="rad-cform-input" placeholder="you@example.com" required>
            <div class="rad-cform-error" id="cf-err-email">Enter a valid email</div>
          </div>
        </div>
        <div class="rad-cform-group">
          <label class="rad-cform-label" for="cf-vehicle">Vehicle Make &amp; Model <span>*</span></label>
          <input type="text" id="cf-vehicle" class="rad-cform-input" placeholder="e.g. Toyota Corolla 2022" required>
          <div class="rad-cform-error" id="cf-err-vehicle">Enter your vehicle</div>
        </div>
        <div class="rad-cform-group">
          <label class="rad-cform-label" for="cf-service">Service Package <span>*</span></label>
          <select id="cf-service" class="rad-cform-input" required>
            <option value="" disabled selected>Select a service...</option>
            <option value="ppf">Paint Protection Film (PPF)</option>
            <option value="ceramic">Ceramic Coating</option>
            <option value="detailing">Exterior &amp; Interior Detailing</option>
            <option value="antirust">Anti-Rust Undercoating</option>
          </select>
          <div class="rad-cform-error" id="cf-err-service">Select a service</div>
        </div>
        <button type="submit" class="rad-cform-btn">{{ section.settings.btn_text | default: "Calculate My Car Estimate" }}</button>
      </form>
      <div class="rad-cform-success" id="cf-success">
        <div style="font-size:3rem;margin-bottom:1rem;">&#9989;</div>
        <h3 style="font-size:1.5rem;font-weight:800;margin-bottom:0.5rem;">Request Received!</h3>
        <p style="color:#6b7280;">We'll get back to you on WhatsApp within a few hours.</p>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var form=document.getElementById('rad-cf');
  if(!form) return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var ok=true;
    function chk(id,eid,fn){
      var el=document.getElementById(id),er=document.getElementById(eid);
      var v=fn(el.value.trim());
      el.style.borderColor=v?'':'#ef4444';
      er.classList.toggle('show',!v);
      if(!v) ok=false;
    }
    chk('cf-fname','cf-err-fname',function(v){return v.length>0;});
    chk('cf-lname','cf-err-lname',function(v){return v.length>0;});
    chk('cf-phone','cf-err-phone',function(v){return v.replace(/\D/g,'').length>=10;});
    chk('cf-email','cf-err-email',function(v){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);});
    chk('cf-vehicle','cf-err-vehicle',function(v){return v.length>0;});
    chk('cf-service','cf-err-service',function(v){return v.length>0;});
    if(ok){form.style.display='none';document.getElementById('cf-success').classList.add('show');}
  });
})();
</script>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Get Your Free Estimate"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fill out the form below and we'll get back to you with a personalized quote."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Submit Button Text",
      "default": "Calculate My Car Estimate"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}