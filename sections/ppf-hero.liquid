<style>
  .ppf-hero-section {
    background: var(--color-black);
    color: var(--color-white);
    padding: 4.5rem 0;
    position: relative;
    overflow: hidden;
  }
  .ppf-hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 65% 50%, rgba(30,58,138,0.35) 0%, transparent 70%);
  }

  .ppf-hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.7fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .ppf-hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(30,58,138,0.4);
    border: 1px solid rgba(96,165,250,0.3);
    padding: 0.3rem 1rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    color: #93c5fd;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ppf-hero-headline {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    letter-spacing: -1px;
  }

  .ppf-hero-subheadline {
    font-size: 1.35rem;
    font-weight: 700;
    color: #60a5fa;
    margin-bottom: 1rem;
  }

  .ppf-hero-desc {
    font-size: 1.05rem;
    color: #d1d5db;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .ppf-hero-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .ppf-hero-feature {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.08);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .ppf-hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .ppf-hero-emoji {
    font-size: 9rem;
    filter: drop-shadow(0 20px 60px rgba(30,58,138,0.5));
    animation: float 6s ease-in-out infinite;
  }
  .ppf-hero-glow {
    position: absolute;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(30,58,138,0.4) 0%, transparent 70%);
    border-radius: 50%;
  }

  @media (max-width: 900px) {
    .ppf-hero-grid { grid-template-columns: 1fr; }
    .ppf-hero-visual { display: none; }
    .ppf-hero-headline { font-size: 2.25rem; }
  }
  @media (max-width: 640px) {
    .ppf-hero-section { padding: 3rem 0; }
    .ppf-hero-headline { font-size: 1.85rem; }
  }
</style>

<section class="ppf-hero-section">
  <div class="container">
    <div class="ppf-hero-grid">
      <div>
        <div class="ppf-hero-tag">🛡️ PPF Service</div>
        <h1 class="ppf-hero-headline">Paint Protection Film (PPF)</h1>
        <p class="ppf-hero-subheadline">Ultimate Protection for Your Car's Paint</p>
        <p class="ppf-hero-desc">Invisible shield technology that protects against scratches, chips, UV damage, and environmental contaminants — keeping your car showroom-fresh.</p>
        <div class="ppf-hero-features">
          <span class="ppf-hero-feature">✓ Self-Healing</span>
          <span class="ppf-hero-feature">✓ UV Resistant</span>
          <span class="ppf-hero-feature">✓ Up to 10 Years</span>
          <span class="ppf-hero-feature">✓ Invisible Finish</span>
        </div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="#ppf-pricing" class="btn btn-primary">View Pricing</a>
          <a href="/pages/ppf-booking" class="btn btn-secondary">Book Now</a>
        </div>
      </div>
      <div class="ppf-hero-visual">
        <div class="ppf-hero-glow"></div>
        <div class="ppf-hero-emoji">🚗</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPF Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "🛡️ PPF Service"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "Paint Protection Film (PPF)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheadline",
      "default": "Ultimate Protection for Your Car's Paint"
    },
    {
      "type": "textarea",
      "id": "desc",
      "label": "Description",
      "default": "Invisible shield technology that protects against scratches, chips, UV damage, and environmental contaminants."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "View Pricing"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Book Now"
    }
  ],
  "presets": [
    {
      "name": "PPF Hero"
    }
  ]
}
{% endschema %}