        {"type":"text","id":"primary_text","label":"Primary Button Text","default":"View Pricing →"},
        {"type":"url","id":"primary_url","label":"Primary Button Link"},
        {"type":"text","id":"booking_text","label":"Booking Button Text","default":"Book Slot"},
        {"type":"url","id":"booking_url","label":"Booking Button Link"}
      ]
    }
  ],
