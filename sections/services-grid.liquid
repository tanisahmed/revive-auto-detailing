<style>
.rad-svc-list { padding: 3.5rem 0 4rem; background: #f8fafc; font-family: 'Nunito Sans', sans-serif; }
.rad-svc-list-inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
.rad-sec-title { font-size: 2rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; text-align: center; }
.rad-sec-sub { color: #6b7280; text-align: center; font-size: 1rem; }
.rad-svc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; margin-top: 2.5rem; }

.rad-svc-card {
  background: #fff; border-radius: 16px; overflow: hidden;
  border: 1px solid #e5e7eb; transition: all 0.25s;
  display: flex; flex-direction: column;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.rad-svc-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.10); transform: translateY(-4px); border-color: transparent; }
.rad-svc-card-header { padding: 2rem 2rem 1.5rem; position: relative; }
.rad-svc-card-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.1rem; }
.rad-svc-card-tag { position: absolute; top: 1.25rem; right: 1.25rem; font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 100px; letter-spacing: 0.05em; }
.rad-svc-card h2 { font-size: 1.3rem; font-weight: 800; color: #1f2937; margin-bottom: 0.5rem; }
.rad-svc-card-desc { font-size: 0.9rem; color: #6b7280; line-height: 1.7; margin-bottom: 1.25rem; }
.rad-svc-card-features { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.5rem; }
.rad-svc-card-feat { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #374151; }
.rad-svc-card-feat-icon { width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; flex-shrink: 0; }

.rad-svc-card-footer { padding: 0 2rem 2rem; margin-top: auto; }
.rad-svc-card-price { font-size: 0.8rem; color: #6b7280; margin-bottom: 0.85rem; }
.rad-svc-card-price strong { font-size: 1.1rem; color: #1f2937; font-weight: 700; }
.rad-svc-card-btns { display: flex; gap: 0.6rem; }
.rad-svc-card-btn-primary { flex: 1; display: block; text-align: center; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem; text-decoration: none; transition: all 0.2s; }
.rad-svc-card-btn-wa { display: flex; align-items: center; justify-content: center; padding: 0.75rem 0.875rem; background: #10b981; color: #fff; border-radius: 8px; font-size: 0.875rem; text-decoration: none; transition: background 0.2s; }
.rad-svc-card-btn-wa:hover { background: #059669; }

/* Color accents */
.color-blue .rad-svc-card-icon { background: #dbeafe; } .color-blue .rad-svc-card-btn-primary { background: #1e3a8a; color: #fff; } .color-blue .rad-svc-card-btn-primary:hover { background: #1e40af; } .color-blue .rad-svc-card-feat-icon { background: #dbeafe; color: #1e3a8a; } .color-blue .rad-svc-card-tag { background: #dbeafe; color: #1e3a8a; }
.color-pink .rad-svc-card-icon { background: #fce7f3; } .color-pink .rad-svc-card-btn-primary { background: #be185d; color: #fff; } .color-pink .rad-svc-card-btn-primary:hover { background: #9d174d; } .color-pink .rad-svc-card-feat-icon { background: #fce7f3; color: #be185d; } .color-pink .rad-svc-card-tag { background: #fce7f3; color: #be185d; }
.color-green .rad-svc-card-icon { background: #d1fae5; } .color-green .rad-svc-card-btn-primary { background: #065f46; color: #fff; } .color-green .rad-svc-card-btn-primary:hover { background: #064e3b; } .color-green .rad-svc-card-feat-icon { background: #d1fae5; color: #065f46; } .color-green .rad-svc-card-tag { background: #d1fae5; color: #065f46; }
.color-indigo .rad-svc-card-icon { background: #e0e7ff; } .color-indigo .rad-svc-card-btn-primary { background: #4338ca; color: #fff; } .color-indigo .rad-svc-card-btn-primary:hover { background: #3730a3; } .color-indigo .rad-svc-card-feat-icon { background: #e0e7ff; color: #4338ca; } .color-indigo .rad-svc-card-tag { background: #e0e7ff; color: #4338ca; }
.color-red .rad-svc-card-icon { background: #fee2e2; } .color-red .rad-svc-card-btn-primary { background: #9f1239; color: #fff; } .color-red .rad-svc-card-btn-primary:hover { background: #881337; } .color-red .rad-svc-card-feat-icon { background: #fee2e2; color: #9f1239; } .color-red .rad-svc-card-tag { background: #fee2e2; color: #9f1239; }
.color-purple .rad-svc-card-icon { background: #ede9fe; } .color-purple .rad-svc-card-btn-primary { background: #6d28d9; color: #fff; } .color-purple .rad-svc-card-btn-primary:hover { background: #5b21b6; } .color-purple .rad-svc-card-feat-icon { background: #ede9fe; color: #6d28d9; } .color-purple .rad-svc-card-tag { background: #ede9fe; color: #6d28d9; }

@media (max-width: 768px) {
  .rad-svc-list { padding: 1.75rem 0 2.5rem; }
  .rad-sec-title { font-size: 1.5rem; }
  .rad-sec-sub { font-size: 0.85rem; }
  .rad-svc-grid { grid-template-columns: 1fr; gap: 1.25rem; margin-top: 1.5rem; }
  .rad-svc-card-header { padding: 1.25rem 1.25rem 1rem; }
  .rad-svc-card-footer { padding: 0 1.25rem 1.25rem; }
}
</style>

<div class="rad-svc-list">
  <div class="rad-svc-list-inner">
    <div style="text-align:center;margin-bottom:0;">
      <h2 class="rad-sec-title">{{ section.settings.title | default: "Our Services" }}</h2>
      <p class="rad-sec-sub">{{ section.settings.subtitle | default: "Choose a service to learn more or book an appointment" }}</p>
    </div>
    <div class="rad-svc-grid">
      {%- for block in section.blocks -%}
        <div class="rad-svc-card color-{{ block.settings.color }}">
          <div class="rad-svc-card-header">
            <div class="rad-svc-card-icon">{{ block.settings.icon }}</div>
            {%- if block.settings.tag != blank -%}<div class="rad-svc-card-tag">{{ block.settings.tag }}</div>{%- endif -%}
            <h2>{{ block.settings.title }}</h2>
            <p class="rad-svc-card-desc">{{ block.settings.description }}</p>
            <div class="rad-svc-card-features">
              {%- if block.settings.feat1 != blank -%}<div class="rad-svc-card-feat"><div class="rad-svc-card-feat-icon">✓</div>{{ block.settings.feat1 }}</div>{%- endif -%}
              {%- if block.settings.feat2 != blank -%}<div class="rad-svc-card-feat"><div class="rad-svc-card-feat-icon">✓</div>{{ block.settings.feat2 }}</div>{%- endif -%}
              {%- if block.settings.feat3 != blank -%}<div class="rad-svc-card-feat"><div class="rad-svc-card-feat-icon">✓</div>{{ block.settings.feat3 }}</div>{%- endif -%}
              {%- if block.settings.feat4 != blank -%}<div class="rad-svc-card-feat"><div class="rad-svc-card-feat-icon">✓</div>{{ block.settings.feat4 }}</div>{%- endif -%}
            </div>
          </div>
          <div class="rad-svc-card-footer">
            <div class="rad-svc-card-price">Starting from <strong>{{ block.settings.price }}</strong></div>
            <div class="rad-svc-card-btns">
              <a href="{{ block.settings.primary_url }}" class="rad-svc-card-btn-primary">{{ block.settings.primary_text | default: "View Pricing →" }}</a>
              <a href="{{ block.settings.booking_url }}" class="rad-svc-card-btn-wa">{{ block.settings.booking_text | default: "Book Slot" }}</a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Services Grid",
  "settings": [
    {"type":"text","id":"title","label":"Section Title","default":"Our Services"},
    {"type":"text","id":"subtitle","label":"Section Subtitle","default":"Choose a service to learn more or book an appointment"}
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {"type":"text","id":"icon","label":"Icon (emoji)","default":"🛡"},
        {"type":"text","id":"tag","label":"Badge Text (leave blank to hide)","default":"Most Popular"},
        {"type":"select","id":"color","label":"Color Theme","options":[
          {"value":"blue","label":"Blue"},{"value":"pink","label":"Pink"},{"value":"green","label":"Green"},
