<!-- ══ WHAT UV REVEALS ══ -->
<section class="uvi-reveals">
  <div class="uvi-reveals-inner">
    <div class="uvi-sec-eyebrow">{{ section.settings.eyebrow | default: "What We Detect" }}</div>
    <h2 class="uvi-sec-h2">{{ section.settings.title | default: "UV Light Reveals What Human Eyes Can't" }}</h2>
    <p class="uvi-sec-sub">{{ section.settings.subtitle | default: "Under UV light, original factory paint glows differently than repainted panels." }}</p>
    <div class="uvi-reveals-grid">
      {%- for block in section.blocks -%}
      <div class="uvi-reveal-card">
        <div class="uvi-reveal-icon">{{ block.settings.icon }}</div>
        <div class="uvi-reveal-title">{{ block.settings.title }}</div>
        <div class="uvi-reveal-desc">{{ block.settings.desc }}</div>
        <span class="uvi-reveal-tag">{{ block.settings.tag }}</span>
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "UV — What It Reveals",
