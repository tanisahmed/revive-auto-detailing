<style>
.rad-reviews { padding: 3rem 0; background: #fff; }

.rad-reviews-header { text-align: center; margin-bottom: 2.5rem; }
.rad-reviews-rating-big { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
.rad-reviews-score {
  display: flex; flex-direction: column; align-items: center;
}
.rad-reviews-score-num { font-size: 4rem; font-weight: 800; color: #1e3a8a; line-height: 1; }
.rad-reviews-score-stars { font-size: 1.5rem; letter-spacing: 2px; margin: 0.25rem 0; }
.rad-reviews-score-count { font-size: 0.875rem; color: #6b7280; font-weight: 600; }
.rad-reviews-divider { width: 1px; height: 60px; background: #e5e7eb; }
.rad-reviews-badges { display: flex; flex-direction: column; gap: 0.5rem; }
.rad-reviews-badge {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.875rem; font-weight: 700; color: #1f2937;
}
.rad-reviews-badge span { color: #10b981; font-size: 1rem; }

/* Review Cards Grid */
.rad-reviews-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem; margin-bottom: 1.5rem;
}
.rad-review-card {
  background: #fff; border: 1px solid #e5e7eb;
  border-radius: 12px; padding: 1.5rem;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: all 0.25s; display: flex; flex-direction: column; gap: 1rem;
}
.rad-review-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); transform: translateY(-2px); }

.rad-review-top { display: flex; align-items: center; gap: 0.75rem; }
.rad-review-avatar {
  width: 2.75rem; height: 2.75rem; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; font-weight: 800; color: #fff; flex-shrink: 0;
}
.rad-review-info { flex: 1; }
.rad-review-name { font-size: 0.95rem; font-weight: 800; color: #1f2937; }
.rad-review-date { font-size: 0.75rem; color: #9ca3af; margin-top: 0.1rem; }
.rad-review-google-icon {
  width: 1.5rem; height: 1.5rem; flex-shrink: 0;
}

.rad-review-stars { font-size: 1rem; letter-spacing: 1px; }
.rad-review-text {
  font-size: 0.875rem; color: #4b5563; line-height: 1.7;
  flex: 1;
}
.rad-review-verified {
  display: inline-flex; align-items: center; gap: 0.35rem;
  font-size: 0.75rem; color: #10b981; font-weight: 700;
}

/* Bottom bar */
.rad-reviews-bottom {
  background: #f9fafb; border-radius: 12px; padding: 1.25rem 1.5rem;
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; flex-wrap: wrap; border: 1px solid #e5e7eb;
}
.rad-reviews-bottom-text { font-size: 0.875rem; color: #6b7280; }
.rad-reviews-bottom-text strong { color: #1f2937; }
.rad-reviews-google-badge {
  display: flex; align-items: center; gap: 0.5rem;
  background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
  padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 700; color: #1f2937;
}

@media (max-width: 900px) { .rad-reviews-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 600px) { .rad-reviews-grid { grid-template-columns: 1fr; } .rad-reviews-divider { display: none; } }
</style>

