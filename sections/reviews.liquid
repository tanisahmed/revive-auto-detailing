{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Google Rating (e.g. 4.9)",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Total Review Count (e.g. 50)",
      "default": "50"
    }
  ],
  "presets": [{"name": "Reviews"}]
}
{% endschema %}
