<style>
.rad-svc-page { font-family: 'Nunito Sans', sans-serif; }

/* Hero */
.rad-svc-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
  padding: 5rem 0 4rem; text-align: center; color: #fff; position: relative; overflow: hidden;
}
.rad-svc-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 60% 50%, rgba(96,165,250,0.15) 0%, transparent 60%); }
.rad-svc-hero-inner { position: relative; z-index: 1; max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
.rad-svc-hero-tag { display: inline-block; background: rgba(96,165,250,0.2); border: 1px solid rgba(96,165,250,0.4); color: #93c5fd; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.4rem 1.1rem; border-radius: 100px; margin-bottom: 1.25rem; }
.rad-svc-hero h1 { font-size: 3rem; font-weight: 800; line-height: 1.15; margin-bottom: 1rem; }
.rad-svc-hero h1 span { color: #60a5fa; }
.rad-svc-hero p { font-size: 1.05rem; color: #cbd5e1; line-height: 1.75; }

/* Trust bar */
.rad-svc-trust { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0; }
.rad-svc-trust-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: center; gap: 2.5rem; flex-wrap: wrap; }
.rad-svc-trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: #374151; }
.rad-svc-trust-item span:first-child { font-size: 1.25rem; }

/* Services grid */
.rad-svc-list { padding: 3.5rem 0 4rem; background: #f8fafc; }
.rad-svc-list-inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
.rad-svc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; }

/* Service card */
.rad-svc-card {
  background: #fff; border-radius: 16px; overflow: hidden;
  border: 1px solid #e5e7eb; transition: all 0.25s;
  display: flex; flex-direction: column;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.rad-svc-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.10); transform: translateY(-4px); border-color: transparent; }
.rad-svc-card-header { padding: 2rem 2rem 1.5rem; position: relative; }
.rad-svc-card-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.1rem; }
.rad-svc-card-tag { position: absolute; top: 1.25rem; right: 1.25rem; font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 100px; letter-spacing: 0.05em; }
.rad-svc-card h2 { font-size: 1.3rem; font-weight: 800; color: #1f2937; margin-bottom: 0.5rem; }
.rad-svc-card-desc { font-size: 0.9rem; color: #6b7280; line-height: 1.7; margin-bottom: 1.25rem; }
.rad-svc-card-features { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.5rem; }
.rad-svc-card-feat { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #374151; }
.rad-svc-card-feat-icon { width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; flex-shrink: 0; }

.rad-svc-card-footer { padding: 0 2rem 2rem; margin-top: auto; }
.rad-svc-card-price { font-size: 0.8rem; color: #6b7280; margin-bottom: 0.85rem; }
.rad-svc-card-price strong { font-size: 1.1rem; color: #1f2937; font-weight: 700; }
.rad-svc-card-btns { display: flex; gap: 0.6rem; }
.rad-svc-card-btn-primary { flex: 1; display: block; text-align: center; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem; text-decoration: none; transition: all 0.2s; }
.rad-svc-card-btn-wa { display: flex; align-items: center; justify-content: center; padding: 0.75rem 0.875rem; background: #10b981; color: #fff; border-radius: 8px; font-size: 0.875rem; text-decoration: none; transition: background 0.2s; }
.rad-svc-card-btn-wa:hover { background: #059669; }

/* Color accents per service */
.rad-svc-ppf .rad-svc-card-icon { background: #dbeafe; }
.rad-svc-ppf .rad-svc-card-btn-primary { background: #1e3a8a; color: #fff; }
.rad-svc-ppf .rad-svc-card-btn-primary:hover { background: #1e40af; }
.rad-svc-ppf .rad-svc-card-feat-icon { background: #dbeafe; color: #1e3a8a; }
.rad-svc-ppf .rad-svc-card-tag { background: #dbeafe; color: #1e3a8a; }

.rad-svc-ceramic .rad-svc-card-icon { background: #fce7f3; }
.rad-svc-ceramic .rad-svc-card-btn-primary { background: #be185d; color: #fff; }
.rad-svc-ceramic .rad-svc-card-btn-primary:hover { background: #9d174d; }
.rad-svc-ceramic .rad-svc-card-feat-icon { background: #fce7f3; color: #be185d; }
.rad-svc-ceramic .rad-svc-card-tag { background: #fce7f3; color: #be185d; }

.rad-svc-detailing .rad-svc-card-icon { background: #d1fae5; }
.rad-svc-detailing .rad-svc-card-btn-primary { background: #065f46; color: #fff; }
.rad-svc-detailing .rad-svc-card-btn-primary:hover { background: #064e3b; }
.rad-svc-detailing .rad-svc-card-feat-icon { background: #d1fae5; color: #065f46; }
.rad-svc-detailing .rad-svc-card-tag { background: #d1fae5; color: #065f46; }

.rad-svc-tint .rad-svc-card-icon { background: #e0e7ff; }
.rad-svc-tint .rad-svc-card-btn-primary { background: #4338ca; color: #fff; }
.rad-svc-tint .rad-svc-card-btn-primary:hover { background: #3730a3; }
.rad-svc-tint .rad-svc-card-feat-icon { background: #e0e7ff; color: #4338ca; }
.rad-svc-tint .rad-svc-card-tag { background: #e0e7ff; color: #4338ca; }

.rad-svc-antirust .rad-svc-card-icon { background: #fee2e2; }
.rad-svc-antirust .rad-svc-card-btn-primary { background: #9f1239; color: #fff; }
.rad-svc-antirust .rad-svc-card-btn-primary:hover { background: #881337; }
.rad-svc-antirust .rad-svc-card-feat-icon { background: #fee2e2; color: #9f1239; }
.rad-svc-antirust .rad-svc-card-tag { background: #fee2e2; color: #9f1239; }

.rad-svc-colorppf .rad-svc-card-icon { background: #ede9fe; }
.rad-svc-colorppf .rad-svc-card-btn-primary { background: #6d28d9; color: #fff; }
.rad-svc-colorppf .rad-svc-card-btn-primary:hover { background: #5b21b6; }
.rad-svc-colorppf .rad-svc-card-feat-icon { background: #ede9fe; color: #6d28d9; }
.rad-svc-colorppf .rad-svc-card-tag { background: #ede9fe; color: #6d28d9; }

/* Why RAD */
.rad-svc-why { padding: 3.5rem 0; background: #fff; }
.rad-svc-why-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }
.rad-svc-why-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.25rem; margin-top: 2rem; }
.rad-svc-why-item { text-align: center; padding: 1.5rem 1rem; border-radius: 12px; background: #f8fafc; border: 1px solid #e5e7eb; }
.rad-svc-why-item-icon { font-size: 2rem; margin-bottom: 0.75rem; }
.rad-svc-why-item h4 { font-size: 0.9rem; font-weight: 700; color: #1f2937; margin-bottom: 0.4rem; }
.rad-svc-why-item p { font-size: 0.8rem; color: #6b7280; line-height: 1.55; }

/* CTA */
.rad-svc-cta { padding: 4rem 0; background: linear-gradient(135deg, #1e3a8a, #0f172a); text-align: center; color: #fff; }
.rad-svc-cta-inner { max-width: 600px; margin: 0 auto; padding: 0 1.5rem; }
.rad-svc-cta h2 { font-size: 2rem; font-weight: 800; margin-bottom: 0.75rem; }
.rad-svc-cta p { color: #cbd5e1; margin-bottom: 2rem; font-size: 1rem; }
.rad-svc-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.rad-svc-cta-btn1 { padding: 0.9rem 2.25rem; background: #fff; color: #1e3a8a; border-radius: 8px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
.rad-svc-cta-btn1:hover { background: #f1f5f9; }
.rad-svc-cta-btn2 { padding: 0.9rem 2.25rem; background: #10b981; color: #fff; border-radius: 8px; font-weight: 700; text-decoration: none; transition: all 0.2s; display: flex; align-items: center; gap: 0.4rem; }
.rad-svc-cta-btn2:hover { background: #059669; }

.rad-sec-title { font-size: 2rem; font-weight: 800; color: #1f2937; margin-bottom: 0.4rem; text-align: center; }
.rad-sec-sub { color: #6b7280; text-align: center; font-size: 1rem; }

@media (max-width: 768px) {
  .rad-svc-hero h1 { font-size: 2rem; }
  .rad-svc-grid { grid-template-columns: 1fr; }
  .rad-svc-why-grid { grid-template-columns: repeat(2,1fr); }
  .rad-svc-trust-inner { gap: 1.25rem; }
}
