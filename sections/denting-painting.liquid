<script>
document.querySelectorAll('.rad-dp-faq-q').forEach(function(q) {
  q.addEventListener('click', function() {
    var item = q.closest('.rad-dp-faq-item');
    var wasOpen = item.classList.contains('open');
    document.querySelectorAll('.rad-dp-faq-item').forEach(function(i) { i.classList.remove('open'); });
    if (!wasOpen) item.classList.add('open');
  });
});
</script>

