<style>
.uvi-cta { background: linear-gradient(135deg, #0d0a1a 0%, #4c1d95 50%, #0d0a1a 100%); padding: 5rem 1.5rem; text-align: center; position: relative; overflow: hidden; }
.uvi-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(109,40,217,0.4) 0%, transparent 70%); }
.uvi-cta-inner { max-width: 700px; margin: 0 auto; position: relative; z-index: 2; }
.uvi-cta h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 900; color: #fff; margin-bottom: 1rem; font-family: 'Nunito Sans', sans-serif; }
.uvi-cta p { font-size: 1rem; color: #c4b5fd; margin-bottom: 2.5rem; line-height: 1.7; }
.uvi-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.uvi-cta-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: #6d28d9; color: #fff; padding: 1rem 1.75rem; border-radius: 10px; font-weight: 700; text-decoration: none; transition: all 0.2s; box-shadow: 0 0 24px rgba(109,40,217,0.5); }
.uvi-cta-primary:hover { background: #7c3aed; transform: translateY(-2px); }
.uvi-cta-wa { display: inline-flex; align-items: center; gap: 0.5rem; background: #10b981; color: #fff; padding: 1rem 1.75rem; border-radius: 10px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
.uvi-cta-wa:hover { background: #059669; transform: translateY(-2px); }
@media (max-width: 640px) { .uvi-cta { padding: 3rem 1rem; } .uvi-cta-btns { flex-direction: column; align-items: center; } }
</style>

<section class="uvi-cta">
  <div class="uvi-cta-inner">
    <h2>{{ section.settings.title | default: "Ready to See the Truth About Your Car?" }}</h2>
    <p>{{ section.settings.subtitle | default: "Book your UV paint inspection today. Results in 30–60 minutes. Full panel-by-panel report. Starting from PKR 5,500 only." }}</p>
    <div class="uvi-cta-btns">
      <a href="{{ section.settings.btn1_url | default: '/pages/uv-inspection-booking' }}" class="uvi-cta-primary">{{ section.settings.btn1_text | default: "🔦 Book UV Inspection" }}</a>
      <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20book%20UV%20paint%20inspection" target="_blank" class="uvi-cta-wa">{{ section.settings.btn2_text | default: "💬 WhatsApp Us" }}</a>
    </div>
  </div>
</section>

<script>
(function(){
  try { if(typeof fbq==='function') fbq('track','ViewContent',{content_name:'UV Light Inspection',content_category:'Automotive Service'}); } catch(e){}
})();
</script>

{% schema %}
{
  "name": "UV CTA Banner",
  "settings": [
    {"type":"text","id":"title","label":"Heading","default":"Ready to See the Truth About Your Car?"},
    {"type":"textarea","id":"subtitle","label":"Subtext","default":"Book your UV paint inspection today. Results in 30–60 minutes. Full panel-by-panel report. Starting from PKR 5,500 only."},
    {"type":"header","content":"Buttons"},
    {"type":"text","id":"btn1_text","label":"Primary Button Text","default":"🔦 Book UV Inspection"},
    {"type":"url","id":"btn1_url","label":"Primary Button URL","default":"/pages/uv-inspection-booking"},
    {"type":"text","id":"btn2_text","label":"WhatsApp Button Text","default":"💬 WhatsApp Us"}
  ],
  "presets": [{"name": "UV CTA Banner"}]
}
{% endschema %}