<style>
.rad-svc-trust { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0; font-family: 'Nunito Sans', sans-serif; }
.rad-svc-trust-inner { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: center; gap: 2.5rem; flex-wrap: wrap; }
.rad-svc-trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: #374151; }
.rad-svc-trust-item span:first-child { font-size: 1.25rem; }
@media (max-width: 768px) {
  .rad-svc-trust-inner { gap: 1rem 1.25rem; }
  .rad-svc-trust-item { font-size: 0.78rem; }
  .rad-svc-trust-item span:first-child { font-size: 1.05rem; }
}
</style>

<div class="rad-svc-trust">
  <div class="rad-svc-trust-inner">
    <div class="rad-svc-trust-item"><span>{{ section.settings.icon1 | default: "⭐" }}</span><span>{{ section.settings.text1 | default: "4.9 Google Rating" }}</span></div>
    <div class="rad-svc-trust-item"><span>{{ section.settings.icon2 | default: "🛡" }}</span><span>{{ section.settings.text2 | default: "NAR & GYEON Certified" }}</span></div>
    <div class="rad-svc-trust-item"><span>{{ section.settings.icon3 | default: "🚗" }}</span><span>{{ section.settings.text3 | default: "500+ Cars Serviced" }}</span></div>
    <div class="rad-svc-trust-item"><span>{{ section.settings.icon4 | default: "✅" }}</span><span>{{ section.settings.text4 | default: "Up to 7 Year Warranty" }}</span></div>
    <div class="rad-svc-trust-item"><span>{{ section.settings.icon5 | default: "📍" }}</span><span>{{ section.settings.text5 | default: "Karachi, Pakistan" }}</span></div>
  </div>
</div>

{% schema %}
{
  "name": "Services Trust Bar",
  "settings": [
    {"type":"header","content":"Item 1"},{"type":"text","id":"icon1","label":"Icon","default":"⭐"},{"type":"text","id":"text1","label":"Text","default":"4.9 Google Rating"},
    {"type":"header","content":"Item 2"},{"type":"text","id":"icon2","label":"Icon","default":"🛡"},{"type":"text","id":"text2","label":"Text","default":"NAR & GYEON Certified"},
    {"type":"header","content":"Item 3"},{"type":"text","id":"icon3","label":"Icon","default":"🚗"},{"type":"text","id":"text3","label":"Text","default":"500+ Cars Serviced"},
    {"type":"header","content":"Item 4"},{"type":"text","id":"icon4","label":"Icon","default":"✅"},{"type":"text","id":"text4","label":"Text","default":"Up to 7 Year Warranty"},
    {"type":"header","content":"Item 5"},{"type":"text","id":"icon5","label":"Icon","default":"📍"},{"type":"text","id":"text5","label":"Text","default":"Karachi, Pakistan"}
  ],
  "presets":[{"name":"Services Trust Bar"}]
}
{% endschema %}
