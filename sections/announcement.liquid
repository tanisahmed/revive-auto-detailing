<style>
.rad-announcement {
  background: #1e3a8a;
  color: #fff;
  text-align: center;
  padding: 0.6rem 1rem;
  font-size: 0.875rem;
  font-weight: 600;
  font-family: 'Nunito Sans', sans-serif;
  position: relative;
  z-index: 101;
}
.rad-announcement a {
  color: #fff;
  text-decoration: underline;
  margin-left: 0.5rem;
  font-weight: 700;
}
.rad-announcement a:hover { opacity: 0.85; }
.rad-ann-close {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  font-size: 1.1rem;
  opacity: 0.7;
  padding: 0.2rem 0.4rem;
}
.rad-ann-close:hover { opacity: 1; }
</style>

<div class="rad-announcement" id="rad-ann-bar">
  {{ section.settings.text | default: '🎉 Special Offer: Get 10% Off PPF Service This Month!' }}
  {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
    <a href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>
  {%- endif -%}
  <button class="rad-ann-close" onclick="document.getElementById('rad-ann-bar').style.display='none'" aria-label="Close">✕</button>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🎉 Special Offer: Get 10% Off PPF Service This Month!"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Book Now →"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1e3a8a"
    }
  ],
  "presets": [{"name": "Announcement Bar"}]
}
{% endschema %}
