{%- if section.settings.show_bar != false -%}
<style>
.rad-announcement {
  position: sticky;
  top: 0;
  z-index: 200;
  background: {{ section.settings.bg_color | default: "#1e3a8a" }};
  color: #fff;
  text-align: center;
  padding: 0.6rem 1rem;
  font-size: 0.875rem;
  font-weight: 600;
  font-family: 'Nunito Sans', sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.rad-announcement a {
  color: #fff;
  text-decoration: underline;
  font-weight: 700;
  white-space: nowrap;
}
.rad-announcement a:hover { opacity: 0.85; }
.rad-ann-divider {
  display: inline-block;
  width: 1px;
  height: 14px;
  background: rgba(255,255,255,0.4);
  vertical-align: middle;
}
@media (max-width: 640px) {
  .rad-announcement { font-size: 0.78rem; padding: 0.5rem 0.75rem; gap: 0.4rem; }
  .rad-ann-divider { display: none; }
}
</style>

<div class="rad-announcement">
  <span>{{ section.settings.text | default: "🛡️ Book PPF online & get 5% OFF — Limited slots available!" }}</span>
  {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
    <span class="rad-ann-divider"></span>
    <a href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🛡️ Book PPF online & get 5% OFF — Limited slots available this week!"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Button Text (optional)",
      "default": "Book Now →"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1e3a8a"
    }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}