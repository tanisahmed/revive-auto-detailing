<style>
.rad-ar-hero {
  position: relative; color: #fff; padding: 5rem 0;
  overflow: hidden; min-height: 540px; display: flex; align-items: center;
}
.rad-ar-hero-bg { position: absolute; inset: 0; z-index: 0; }
.rad-ar-hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-ar-hero-fallback { position: absolute; inset: 0; background: linear-gradient(135deg, #1a0a00 0%, #7c2d12 50%, #1a0a00 100%); }
.rad-ar-hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.35) 100%); }
.rad-ar-hero-inner { position: relative; z-index: 2; width: 100%; }
.rad-ar-hero-content { max-width: 640px; }
.rad-ar-tag {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(124,45,18,0.5); border: 1px solid rgba(251,146,60,0.4);
  padding: 0.35rem 1rem; border-radius: 100px;
  font-size: 0.8rem; font-weight: 700; color: #fed7aa;
  margin-bottom: 1rem; letter-spacing: 0.05em; text-transform: uppercase;
}
.rad-ar-mipa-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
  padding: 0.4rem 1rem; border-radius: 8px; margin-bottom: 1rem;
  font-size: 0.8rem; font-weight: 700; color: #fff; letter-spacing: 0.05em;
}
.rad-ar-hero-title {
  font-size: 3.25rem; font-weight: 800; line-height: 1.1;
  margin-bottom: 0.75rem; letter-spacing: -1px;
  font-family: 'Nunito Sans', sans-serif;
}
.rad-ar-hero-title span { color: #fb923c; }
.rad-ar-hero-sub { font-size: 1.1rem; color: #d1d5db; line-height: 1.7; margin-bottom: 2rem; }
.rad-ar-hero-badge { display: inline-block; margin-bottom: 0.75rem; }
.rad-ar-hero-tag { display: block; margin-bottom: 1rem; }
.rad-ar-hero-sub { font-size: 1.05rem; color: #d1d5db; line-height: 1.7; margin-bottom: 2rem; max-width: 540px; }
.rad-ar-hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.rad-ar-btn-primary {
  display: inline-flex; align-items: center; padding: 0.875rem 1.75rem;
  background: #1e3a8a; color: #fff; border-radius: 8px; font-weight: 700;
  font-size: 1rem; text-decoration: none; border: 2px solid #1e3a8a; transition: all 0.2s;
}
.rad-ar-btn-primary:hover { background: #1e40af; transform: translateY(-1px); }
.rad-ar-btn-wa {
  display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem;
  background: #10b981; color: #fff; border-radius: 8px; font-weight: 700;
  font-size: 1rem; text-decoration: none; border: 2px solid #10b981; transition: all 0.2s;
}
.rad-ar-btn-wa:hover { background: #059669; transform: translateY(-1px); }
.rad-ar-hero-stats { display: flex; gap: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15); flex-wrap: wrap; }
.rad-ar-stat-num { font-size: 1.75rem; font-weight: 800; color: #fb923c; display: block; }
.rad-ar-stat-lbl { font-size: 0.75rem; color: #9ca3af; display: block; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
@media (max-width: 900px) { .rad-ar-hero { padding: 3.5rem 0; min-height: 450px; } .rad-ar-hero-title { font-size: 2.25rem; } }
@media (max-width: 640px) {
  .rad-ar-hero { padding: 2.25rem 0; min-height: auto; }
  .rad-ar-hero-inner { padding: 0 1rem; }
  .rad-ar-hero-badge, .rad-ar-hero-tag { font-size: 0.65rem; }
  .rad-ar-hero-title { font-size: 1.6rem; line-height: 1.25; margin-bottom: 0.4rem; }
  .rad-ar-hero-sub { font-size: 0.95rem; margin-bottom: 1.25rem; }
  .rad-ar-hero-btns { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .rad-ar-btn-primary, .rad-ar-btn-wa { flex: 1; width: auto; justify-content: center; text-align: center; padding: 0.65rem 0.5rem; font-size: 0.78rem; white-space: nowrap; }
  .rad-ar-hero-stats { display: flex; flex-wrap: nowrap; gap: 0.5rem; padding-top: 1.1rem; justify-content: space-between; }
  .rad-ar-hero-stats > div { flex: 1; min-width: 0; text-align: center; }
  .rad-ar-stat-num { font-size: 1.05rem; white-space: nowrap; }
  .rad-ar-stat-lbl { font-size: 0.62rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
}
</style>

<section class="rad-ar-hero">
  {%- if section.settings.bg_image != blank -%}
    <div class="rad-ar-hero-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="Anti Rust Undercoating Karachi" loading="eager">
    </div>
  {%- else -%}
    <div class="rad-ar-hero-fallback"></div>
  {%- endif -%}
  <div class="rad-ar-hero-overlay"></div>
  <div class="container rad-ar-hero-inner">
    <div class="rad-ar-hero-content">
      <div class="rad-ar-hero-badge">{{ section.settings.badge }}</div>
      <div class="rad-ar-hero-tag">{{ section.settings.tag }}</div>
      <h1 class="rad-ar-hero-title">
        Anti-Rust Undercoating<br>
        <span>Protect Your Car's Chassis</span>
      </h1>
      <p class="rad-ar-hero-sub">{{ section.settings.subtitle }}</p>
      <div class="rad-ar-hero-btns">
        <a href="/pages/antirust-booking" class="rad-ar-btn-primary">View Pricing</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20know%20about%20Anti-Rust%20Undercoating" target="_blank" class="rad-ar-btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
      <div class="rad-ar-hero-stats">
        <div><span class="rad-ar-stat-num">100+</span><span class="rad-ar-stat-lbl">Cars Undercoated</span></div>
        <div><span class="rad-ar-stat-num">4 Years</span><span class="rad-ar-stat-lbl">Durability</span></div>
        <div><span class="rad-ar-stat-num">2 Years</span><span class="rad-ar-stat-lbl">Warranty</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Anti-Rust Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Brand Badge",
      "default": "🔒 MIPA Certified — Germany's #1 Undercoating"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "🛡️ Anti-Rust Protection Karachi"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline Line 1",
      "default": "Anti-Rust Undercoating"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Headline Line 2 (orange)",
      "default": "Protect Your Car's Chassis"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Protect your car with MIPA Rubberized anti-rust undercoating service in Karachi. Starting from Rs. 22,000/-"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1_num",
      "label": "Stat 1",
      "default": "100+"
    },
    {
      "type": "text",
      "id": "stat1_lbl",
      "label": "Stat 1 Label",
      "default": "Cars Undercoated"
    },
    {
      "type": "text",
      "id": "stat2_num",
      "label": "Stat 2",
      "default": "4 Years"
    },
    {
      "type": "text",
      "id": "stat2_lbl",
      "label": "Stat 2 Label",
      "default": "Durability"
    },
    {
      "type": "text",
      "id": "stat3_num",
      "label": "Stat 3",
      "default": "2 Years"
    },
    {
      "type": "text",
      "id": "stat3_lbl",
      "label": "Stat 3 Label",
      "default": "Warranty"
    }
  ],
  "presets": [
    {
      "name": "Anti-Rust Hero"
    }
  ]
}
{% endschema %}