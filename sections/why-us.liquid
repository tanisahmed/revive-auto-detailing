<style>
  .why-section {
    padding: 2rem 0;
    background: var(--color-secondary);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .benefit-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    padding: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  .benefit-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .benefit-content {}
  .benefit-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .benefit-desc {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .special-offer-banner {
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .special-offer-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
  }
  .special-offer-banner::after {
    content: '';
    position: absolute;
    bottom: -50%;
    left: -5%;
    width: 200px;
    height: 200px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
  }

  .special-offer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.15);
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .special-offer-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .special-offer-text {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }
  .special-offer-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-white);
    color: var(--color-primary);
    padding: 0.75rem 1.75rem;
    border-radius: var(--border-radius);
    font-weight: 700;
    font-size: 1rem;
    transition: var(--transition);
    position: relative;
    z-index: 1;
  }
  .special-offer-btn:hover {
    background: var(--color-secondary);
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .why-section { padding: 1.5rem 0; }
    .benefits-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="why-section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">Experience the difference that professional expertise makes</p>

    <div class="benefits-grid">
      {% assign benefits = 'Expert Technicians,Premium Products,Affordable Pricing,Fast Turnaround,Satisfaction Guaranteed,5% Off PPF Service' | split: ',' %}
      {% assign benefit_descs = 'Trained & certified professionals,Only top-grade materials used,Competitive rates guaranteed,Minimal wait time for results,We stand behind our work,Limited time savings for you' | split: ',' %}

      {% for benefit in benefits %}
        <div class="benefit-card">
          <div class="benefit-content">
            <p class="benefit-name">{{ benefit }}</p>
            <p class="benefit-desc">{{ benefit_descs[forloop.index0] }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Special Offer Banner -->
    <div class="special-offer-banner">
      <div class="special-offer-badge">🎉 Limited Time</div>
      <h3 class="special-offer-title">{{ section.settings.offer_title }}</h3>
      <p class="special-offer-text">{{ section.settings.offer_text }}</p>
      <a href="/pages/ppf-booking" class="special-offer-btn">
        Book Now & Save →
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why Choose RAD For Your Car Detailing?"
    },
    {
      "type": "header",
      "content": "Special Offer Banner"
    },
    {
      "type": "text",
      "id": "offer_title",
      "label": "Offer Title",
      "default": "Special Offer!"
    },
    {
      "type": "text",
      "id": "offer_text",
      "label": "Offer Text",
      "default": "Get 5% Off PPF Service This Month!"
    },
    {
      "type": "text",
      "id": "offer_btn",
      "label": "Offer Button Text",
      "default": "Book Now & Save"
    },
    {
      "type": "url",
      "id": "offer_url",
      "label": "Offer Button Link"
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}