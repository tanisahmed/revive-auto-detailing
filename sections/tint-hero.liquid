<style>
.rad-tint-hero {
  position: relative; color: #fff; padding: 5rem 0;
  overflow: hidden; min-height: 560px; display: flex; align-items: center;
}
.rad-tint-hero-bg { position: absolute; inset: 0; z-index: 0; }
.rad-tint-hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-tint-hero-fallback { position: absolute; inset: 0; background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #0f172a 100%); }
.rad-tint-hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to right, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.4) 100%); }
.rad-tint-hero-inner { position: relative; z-index: 2; width: 100%; }
.rad-tint-hero-content { max-width: 640px; }
.rad-tint-tag {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(30,58,138,0.5); border: 1px solid rgba(96,165,250,0.4);
  padding: 0.35rem 1rem; border-radius: 100px;
  font-size: 0.8rem; font-weight: 700; color: #93c5fd;
  margin-bottom: 1.25rem; letter-spacing: 0.05em; text-transform: uppercase;
}
.rad-tint-hero-title {
  font-size: 3.25rem; font-weight: 800; line-height: 1.1;
  margin-bottom: 0.75rem; letter-spacing: -1px;
  font-family: 'Nunito Sans', sans-serif;
}
.rad-tint-hero-title span { color: #60a5fa; }
.rad-tint-hero-sub { font-size: 1.1rem; color: #d1d5db; line-height: 1.7; margin-bottom: 2rem; }
.rad-tint-hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.rad-tint-btn-blue {
  display: inline-flex; align-items: center; padding: 0.875rem 1.75rem;
  background: #1e3a8a; color: #fff; border-radius: 8px; font-weight: 700;
  font-size: 1rem; text-decoration: none; border: 2px solid #1e3a8a; transition: all 0.2s;
}
.rad-tint-btn-blue:hover { background: #1e40af; transform: translateY(-1px); }
.rad-tint-btn-wa {
  display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem;
  background: #10b981; color: #fff; border-radius: 8px; font-weight: 700;
  font-size: 1rem; text-decoration: none; border: 2px solid #10b981; transition: all 0.2s;
}
.rad-tint-btn-wa:hover { background: #059669; transform: translateY(-1px); }
.rad-tint-hero-stats { display: flex; gap: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15); flex-wrap: wrap; }
.rad-tint-stat-num { font-size: 1.75rem; font-weight: 800; color: #60a5fa; display: block; }
.rad-tint-stat-lbl { font-size: 0.75rem; color: #9ca3af; display: block; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
.rad-tint-nar-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
  padding: 0.4rem 1rem; border-radius: 8px; margin-bottom: 1rem;
  font-size: 0.8rem; font-weight: 700; color: #fff; letter-spacing: 0.05em;
}
@media (max-width: 900px) { .rad-tint-hero { padding: 3.5rem 0; min-height: 450px; } .rad-tint-hero-title { font-size: 2.25rem; } }
@media (max-width: 640px) { .rad-tint-hero { padding: 3rem 0; } .rad-tint-hero-title { font-size: 1.85rem; } .rad-tint-hero-btns { flex-direction: column; } }
</style>

<section class="rad-tint-hero">
  {%- if section.settings.bg_image != blank -%}
    <div class="rad-tint-hero-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="Car Window Tint Karachi" loading="eager">
    </div>
  {%- else -%}
    <div class="rad-tint-hero-fallback"></div>
  {%- endif -%}
  <div class="rad-tint-hero-overlay"></div>

  <div class="container rad-tint-hero-inner">
    <div class="rad-tint-hero-content">
      <div class="rad-tint-nar-badge">🎬 NAR Window Film — Authorized Installer</div>
      <div class="rad-tint-tag">🌑 Karachi's Premium Window Tinting</div>
      <h1 class="rad-tint-hero-title">
        Premium Car Window Tint<br>
        <span>Heat Control Film Karachi</span>
      </h1>
      <p class="rad-tint-hero-sub">
        Get high-quality car window tinting in Karachi. Our NAR window films protect from heat, UV rays, and offer privacy. Expert installation, affordable rates!
      </p>
      <div class="rad-tint-hero-btns">
        <a href="#tint-pricing" class="rad-tint-btn-blue">View Pricing</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20to%20know%20about%20Car%20Window%20Tinting" target="_blank" class="rad-tint-btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
      <div class="rad-tint-hero-stats">
        <div><span class="rad-tint-stat-num">500+</span><span class="rad-tint-stat-lbl">Cars Tinted</span></div>
        <div><span class="rad-tint-stat-num">NAR</span><span class="rad-tint-stat-lbl">Certified Film</span></div>
        <div><span class="rad-tint-stat-num">⭐ 4.9</span><span class="rad-tint-stat-lbl">Google Rating</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tint Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Brand Badge",
      "default": "🎬 NAR Window Film — Authorized Installer"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "🌑 Karachi's Premium Window Tinting"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline Line 1",
      "default": "Premium Car Window Tint"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Headline Line 2 (blue)",
      "default": "Heat Control Film Karachi"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Get high-quality car window tinting in Karachi. Our NAR window films protect from heat, UV rays, and offer privacy."
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1_num",
      "label": "Stat 1",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat1_lbl",
      "label": "Stat 1 Label",
      "default": "Cars Tinted"
    },
    {
      "type": "text",
      "id": "stat2_num",
      "label": "Stat 2",
      "default": "NAR"
    },
    {
      "type": "text",
      "id": "stat2_lbl",
      "label": "Stat 2 Label",
      "default": "Certified Film"
    },
    {
      "type": "text",
      "id": "stat3_num",
      "label": "Stat 3",
      "default": "4.9 ⭐"
    },
    {
      "type": "text",
      "id": "stat3_lbl",
      "label": "Stat 3 Label",
      "default": "Google Rating"
    }
  ],
  "presets": [
    {
      "name": "Tint Hero"
    }
  ]
}
{% endschema %}