<script>
(function(){
  var prices = {
    hatchback: { gold: '{{ section.settings.gold_hatch }}', plat: '{{ section.settings.plat_hatch }}', ult: '{{ section.settings.ult_hatch }}' },
    sedan:     { gold: '{{ section.settings.gold_sedan }}', plat: '{{ section.settings.plat_sedan }}', ult: '{{ section.settings.ult_sedan }}' },
    suv:       { gold: '{{ section.settings.gold_suv }}',   plat: '{{ section.settings.plat_suv }}',   ult: '{{ section.settings.ult_suv }}' },
    xlsuv:     { gold: '{{ section.settings.gold_xlsuv }}', plat: '{{ section.settings.plat_xlsuv }}', ult: '{{ section.settings.ult_xlsuv }}' }
  };

  window.cerTab = function(el, vtype) {
    document.querySelectorAll('.rad-cer-tab').forEach(function(t){ t.classList.remove('active'); });
    el.classList.add('active');
    var p = prices[vtype];
    if(p) {
  document.getElementById('gold-price').textContent = p.gold;
      document.getElementById('plat-price').textContent = p.plat;
      document.getElementById('ult-price').textContent  = p.ult;
      var labels = {'hatchback':'Hatchback','sedan':'Sedan','suv':'SUV','xlsuv':'XL SUV'};
      var lbl = labels[vtype] || vtype;
      document.getElementById('gold-vehicle').textContent = lbl;
      document.getElementById('plat-vehicle').textContent = lbl;
      document.getElementById('ult-vehicle').textContent  = lbl;
    }
  };
})();
</script>

