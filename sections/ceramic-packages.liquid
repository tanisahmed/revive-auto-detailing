<style>
.rad-cer-pkg { padding: 3rem 0; background: #f3f4f6; }

/* Vehicle Selector Tabs */
.rad-cer-tabs {
  display: flex; justify-content: center; gap: 0.5rem;
  margin-bottom: 1.5rem; flex-wrap: wrap; margin-top: 0;
}
.rad-cer-tab {
  padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 700;
  font-size: 0.9rem; cursor: pointer; border: 2px solid #d1d5db;
  background: #fff; color: #6b7280; font-family: 'Nunito Sans', sans-serif;
  transition: all 0.2s;
}
.rad-cer-tab:hover { border-color: #1e3a8a; color: #1e3a8a; }
.rad-cer-tab.active { background: #1e3a8a; border-color: #1e3a8a; color: #fff; }

/* 3-column cards */
.rad-cer-cards {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem; max-width: 1100px; margin: 0 auto;
}

.rad-cer-card {
  background: #fff; border-radius: 14px; overflow: hidden;
  border: 2px solid #e5e7eb; transition: all 0.25s;
  display: flex; flex-direction: column; position: relative;
}
.rad-cer-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.12); transform: translateY(-4px); }
.rad-cer-card.popular { border-color: #1e3a8a; box-shadow: 0 4px 20px rgba(30,58,138,0.15); }

.rad-cer-popular-badge {
  position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
  background: #1e3a8a; color: #fff; font-size: 0.7rem; font-weight: 800;
  padding: 0.25rem 1rem; border-radius: 0 0 8px 8px;
  letter-spacing: 0.08em; text-transform: uppercase; white-space: nowrap;
}

/* Card Header */
.rad-cer-card-hdr {
  padding: 1.75rem 1.5rem 1.25rem; text-align: center;
  border-bottom: 1px solid #e5e7eb;
}
.rad-cer-card-hdr.gold-hdr { background: linear-gradient(135deg, #15803d, #16a34a); color: #fff; }
.rad-cer-card-hdr.plat-hdr { background: linear-gradient(135deg, #be185d, #ec4899); color: #fff; }
.rad-cer-card-hdr.ult-hdr { background: linear-gradient(135deg, #0f172a, #1e3a8a); color: #fff; }

.rad-cer-pkg-name { font-size: 1.2rem; font-weight: 800; margin-bottom: 0.25rem; font-family: 'Nunito Sans', sans-serif; }
.rad-cer-pkg-tagline { font-size: 0.8rem; opacity: 0.75; font-weight: 600; }

/* Price display */
.rad-cer-vehicle-label {
  font-size: 0.8rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.1em; color: #1e3a8a; margin-bottom: 0.25rem;
  background: rgba(30,58,138,0.08); display: inline-block;
  padding: 0.2rem 0.75rem; border-radius: 100px;
}
.rad-cer-price-display {
  padding: 1.25rem 1.5rem; text-align: center;
  border-bottom: 1px solid #f3f4f6;
}
.rad-cer-price-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: #9ca3af; font-weight: 700; margin-bottom: 0.35rem; }
.rad-cer-price-amount { font-size: 2rem; font-weight: 800; color: #1e3a8a; line-height: 1; }
.rad-cer-price-note { font-size: 0.75rem; color: #9ca3af; margin-top: 0.25rem; }

/* Features */
.rad-cer-card-features { padding: 1.25rem 1.5rem; flex: 1; }
.rad-cer-feat-list { display: flex; flex-direction: column; gap: 0.5rem; }
.rad-cer-feat-item {
  display: flex; align-items: flex-start; gap: 0.5rem;
  font-size: 0.82rem; color: #374151; line-height: 1.4;
}
.rad-cer-feat-item::before { content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0; font-size: 0.85rem; }

/* Duration badge */
.rad-cer-duration {
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  background: #f9fafb; border-top: 1px solid #f3f4f6;
  padding: 0.6rem; font-size: 0.78rem; color: #6b7280; font-weight: 600;
}

/* Book buttons */
.rad-cer-card-btns { padding: 1.25rem; padding-top: 0.75rem; display: flex; flex-direction: row; gap: 0.5rem; }
.rad-cer-book-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; text-align: center; padding: 0.75rem 0.5rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.85rem; text-decoration: none; transition: all 0.2s;
}
.rad-cer-book-btn:hover { background: #1e40af; }
.rad-cer-book-btn-wa {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  text-align: center; padding: 0.75rem 0.5rem;
  background: #10b981; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.85rem; text-decoration: none;
  border: 2px solid #10b981; transition: all 0.2s;
}
.rad-cer-book-btn-wa:hover { background: #059669; border-color: #059669; }

.rad-cer-note {
  text-align: center; margin-top: 1.5rem;
  font-size: 0.875rem; color: #6b7280;
  background: #fff; border-radius: 8px;
  padding: 1rem; border: 1px solid #e5e7eb;
  max-width: 1100px; margin-left: auto; margin-right: auto;
}

@media (max-width: 900px) {
  .rad-cer-cards { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
}
@media (max-width: 640px) {
  .rad-cer-pkg { padding: 2rem 0; }
  .rad-cer-inner { padding: 0 1rem; }
  .section-title { font-size: 1.5rem; }
  .rad-cer-cards { max-width: 100%; }
  .rad-cer-tabs { gap: 0.35rem; justify-content: center; }
  .rad-cer-tab { padding: 0.5rem 0.75rem; font-size: 0.8rem; }
  .rad-cer-card-hdr { padding: 1.1rem 1rem; }
  .rad-cer-card-name { font-size: 1rem; }
  .rad-cer-price { font-size: 1.75rem; }
  .rad-cer-card-body { padding: 1rem; }
  .rad-cer-card-btns { flex-direction: column; gap: 0.5rem; }
  .rad-cer-card-btns a { width: 100%; text-align: center; padding: 0.75rem; }
}
</style>

