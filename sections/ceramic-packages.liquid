<style>
.rad-cer-pkg { padding: 2rem 0; background: #f3f4f6; }
.rad-cer-pkg-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
.rad-cer-pkg-card {
  background: #fff; border: 2px solid #e5e7eb; border-radius: 16px;
  overflow: hidden; transition: all 0.25s; position: relative;
  display: flex; flex-direction: column;
}
.rad-cer-pkg-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.12); transform: translateY(-4px); border-color: #1e3a8a; }
.rad-cer-pkg-card.featured { border-color: #1e3a8a; box-shadow: 0 4px 20px rgba(30,58,138,0.2); }
.rad-cer-pkg-popular {
  position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
  background: #1e3a8a; color: #fff; font-size: 0.7rem; font-weight: 700;
  padding: 0.25rem 1rem; border-radius: 0 0 8px 8px; letter-spacing: 0.05em;
  text-transform: uppercase; white-space: nowrap;
}
.rad-cer-pkg-header {
  padding: 1.75rem 1.5rem 1.25rem;
  text-align: center;
  background: linear-gradient(135deg, #f8faff 0%, #eff6ff 100%);
  border-bottom: 1px solid #e5e7eb;
}
.rad-cer-pkg-name { font-size: 0.7rem; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; color: #6b7280; margin-bottom: 0.25rem; }
.rad-cer-pkg-package { font-size: 1.5rem; font-weight: 800; color: #1e3a8a; margin-bottom: 0.75rem; }
.rad-cer-pkg-gyeon { font-size: 0.7rem; color: #9ca3af; font-weight: 600; margin-bottom: 0.5rem; letter-spacing: 0.05em; }
.rad-cer-pkg-durability {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: rgba(30,58,138,0.08); color: #1e3a8a;
  padding: 0.3rem 0.75rem; border-radius: 100px;
  font-size: 0.75rem; font-weight: 700;
}
.rad-cer-pkg-body { padding: 1.25rem 1.5rem; flex: 1; display: flex; flex-direction: column; gap: 1rem; }
.rad-cer-pkg-applied-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 0.5rem; }
.rad-cer-pkg-features { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.5rem; }
.rad-cer-pkg-feat { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #1f2937; }
.rad-cer-pkg-feat::before { content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0; }
.rad-cer-pkg-free {
  background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;
  padding: 0.6rem 0.85rem; font-size: 0.8rem; font-weight: 700; color: #15803d;
  display: flex; align-items: center; gap: 0.4rem;
}
.rad-cer-pkg-pricing { border-top: 1px solid #e5e7eb; padding-top: 1rem; }
.rad-cer-pkg-pricing-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 0.75rem; }
.rad-cer-pkg-price-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1.25rem; }
.rad-cer-pkg-price-item { background: #f9fafb; border-radius: 8px; padding: 0.6rem 0.75rem; }
.rad-cer-pkg-price-vehicle { font-size: 0.75rem; color: #6b7280; font-weight: 600; margin-bottom: 0.15rem; }
.rad-cer-pkg-price-amount { font-size: 1rem; font-weight: 800; color: #1e3a8a; }
.rad-cer-pkg-btns { display: flex; flex-direction: column; gap: 0.6rem; margin-top: auto; }
.rad-cer-pkg-btn {
  display: block; text-align: center; padding: 0.75rem;
  background: #1e3a8a; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.9rem; text-decoration: none; transition: all 0.2s;
}
.rad-cer-pkg-btn:hover { background: #1e40af; }
.rad-cer-pkg-btn-wa {
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.65rem; background: #10b981; color: #fff; border-radius: 8px;
  font-weight: 700; font-size: 0.875rem; text-decoration: none; transition: all 0.2s;
}
.rad-cer-pkg-btn-wa:hover { background: #059669; }
@media (max-width: 900px) { .rad-cer-pkg-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; } }
</style>

