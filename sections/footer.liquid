<style>
/* ══ RAD Premium Footer v2 ══ */
.radf {
  background: #0f172a;
  font-family: 'Nunito Sans', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* Blue top accent line */
.radf-accent {
  height: 3px;
  background: linear-gradient(90deg, transparent 0%, #1e3a8a 25%, #3b82f6 50%, #1e3a8a 75%, transparent 100%);
}

/* ── Main body ── */
.radf-body {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 1.5rem 3rem;
  display: grid;
  grid-template-columns: 1.8fr 1fr 1fr 1.3fr;
  gap: 3.5rem;
}

/* Brand col */
.radf-logo { font-size: 1.5rem; font-weight: 900; color: #fff; margin-bottom: 0.25rem; letter-spacing: -0.01em; }
.radf-logo span { color: #3b82f6; }
.radf-logo-sub { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: #334155; margin-bottom: 1.25rem; }
.radf-desc { font-size: 0.9rem; color: #64748b; line-height: 1.75; margin-bottom: 1.75rem; max-width: 270px; }
.radf-wa {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: #10b981; color: #fff;
  padding: 0.7rem 1.25rem; border-radius: 8px;
  font-size: 0.875rem; font-weight: 700; text-decoration: none;
  transition: background 0.2s;
}
.radf-wa:hover { background: #059669; }

/* Col headers */
.radf-col-h {
  font-size: 0.72rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.12em; color: #fff;
  margin-bottom: 1.25rem; padding-bottom: 0.75rem;
  border-bottom: 1px solid #1e293b;
}

/* Service links */
.radf-links { display: flex; flex-direction: column; gap: 0.65rem; }
.radf-links a {
  font-size: 0.875rem; color: #64748b;
  text-decoration: none; display: flex; align-items: center; gap: 0.5rem;
  transition: color 0.2s;
}
.radf-links a:hover { color: #cbd5e1; }
.radf-links a::before { content: '→'; font-size: 0.75rem; color: #1e3a8a; }

/* Contact items */
.radf-contacts { display: flex; flex-direction: column; gap: 1rem; }
.radf-contact-row { display: flex; gap: 0.85rem; align-items: flex-start; }
.radf-contact-ico {
  width: 2rem; height: 2rem; border-radius: 6px;
  background: #1e293b; border: 1px solid #334155;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; flex-shrink: 0;
}
.radf-contact-lbl { font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #334155; margin-bottom: 0.15rem; }
.radf-contact-val { font-size: 0.875rem; color: #64748b; line-height: 1.5; }
.radf-contact-val a { color: #64748b; text-decoration: none; transition: color 0.2s; }
.radf-contact-val a:hover { color: #cbd5e1; }
.radf-directions {
  display: inline-flex; align-items: center; gap: 0.35rem;
  font-size: 0.8rem; color: #1e3a8a; font-weight: 700;
  text-decoration: none; margin-top: 0.25rem; transition: color 0.2s;
}
.radf-directions:hover { color: #3b82f6; }

/* Hours */
.radf-hours { display: flex; flex-direction: column; }
.radf-hour-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.55rem 0;
  border-bottom: 1px solid #1e293b;
  font-size: 0.875rem;
}
.radf-hour-row:last-child { border-bottom: none; }
.radf-hour-day { color: #94a3b8; font-weight: 600; }
.radf-hour-time { font-weight: 700; color: #22c55e; }
.radf-hour-time.closed { color: #ef4444; }

/* Book box */
.radf-book-box {
  margin-top: 1.5rem;
  background: #1e293b;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 1.1rem;
}
.radf-book-box-title { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #3b82f6; margin-bottom: 0.4rem; }
.radf-book-box-sub { font-size: 0.8rem; color: #475569; margin-bottom: 0.85rem; line-height: 1.5; }
.radf-book-btn {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: #1e3a8a; color: #fff;
  padding: 0.55rem 1rem; border-radius: 7px;
  font-size: 0.8rem; font-weight: 700; text-decoration: none;
  transition: background 0.2s;
}
.radf-book-btn:hover { background: #1e40af; }

/* ── Divider ── */
.radf-divider { border: none; border-top: 1px solid #1e293b; margin: 0; }

/* ── Bottom ── */
.radf-bottom {
  max-width: 1200px; margin: 0 auto;
  padding: 1.25rem 1.5rem;
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; flex-wrap: wrap;
}
.radf-copy { font-size: 0.8rem; color: #334155; }
.radf-bottom-links { display: flex; gap: 1.5rem; }
.radf-bottom-links a { font-size: 0.8rem; color: #334155; text-decoration: none; transition: color 0.2s; }
.radf-bottom-links a:hover { color: #64748b; }
.radf-made { font-size: 0.78rem; color: #1e293b; }

/* Social row */
.radf-social { display: flex; gap: 0.6rem; margin-top: 1.5rem; }
.radf-social a {
  width: 2.1rem; height: 2.1rem; border-radius: 7px;
  border: 1px solid #1e293b; background: #1e293b;
  display: flex; align-items: center; justify-content: center;
  color: #475569; text-decoration: none; transition: all 0.2s;
}
.radf-social a:hover { border-color: #1e3a8a; color: #3b82f6; background: #0f172a; }

/* Responsive */
@media (max-width: 1024px) {
  .radf-body { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
}
@media (max-width: 600px) {
  .radf-body { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 1.25rem 2rem; }
  .radf-bottom { flex-direction: column; text-align: center; padding: 1.25rem; }
  .radf-bottom-links { justify-content: center; flex-wrap: wrap; gap: 1rem; }
  .radf-desc { max-width: 100%; }
}
</style>

