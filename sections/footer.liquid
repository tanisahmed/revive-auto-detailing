<style>
  .site-footer {
    background: var(--color-black);
    color: #d1d5db;
    padding: 4rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #374151;
  }

  .footer-col-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }

  .footer-info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .footer-info-item .icon { flex-shrink: 0; font-size: 1rem; margin-top: 1px; }
  .footer-info-item a { color: #d1d5db; transition: var(--transition); }
  .footer-info-item a:hover { color: var(--color-white); }

  .footer-hours-item {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid #374151;
  }
  .footer-hours-item:last-child { border-bottom: none; }
  .footer-hours-item .day { color: #9ca3af; }
  .footer-hours-item .time { color: var(--color-white); font-weight: 600; }
  .footer-hours-item .closed { color: var(--color-error); font-weight: 600; }

  .footer-address { font-size: 0.9rem; line-height: 1.7; }

  .footer-map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    transition: var(--transition);
  }
  .footer-map-link:hover { color: #60a5fa; }

  .footer-bottom {
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .footer-bottom-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-bottom-links a {
    font-size: 0.875rem;
    color: #6b7280;
    transition: var(--transition);
  }
  .footer-bottom-links a:hover { color: var(--color-white); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { justify-content: center; text-align: center; }
    .footer-bottom-links { justify-content: center; }
  }
</style>

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <!-- Contact Us -->
      <div class="footer-col">
        <h3 class="footer-col-title">Contact Us</h3>
        <div class="footer-info-item">
          <span class="icon">📞</span>
          <a href="tel:{{ section.settings.phone }}">
            {{ section.settings.phone_display }}
          </a>
        </div>
        <div class="footer-info-item">
          <span class="icon">📧</span>
          <a href="mailto:{{ section.settings.email }}">
            {{ section.settings.email }}
          </a>
        </div>
        <div class="footer-info-item" style="margin-top:1rem;">
          <a href="https://wa.me/923037231111" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:0.5rem;color:#10b981;font-weight:700;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>

      <!-- Business Hours -->
      <div class="footer-col">
        <h3 class="footer-col-title">Business Hours</h3>
        <div class="footer-hours-item">
          <span class="day">Monday - Saturday</span>
          <span class="time">9:00 AM – 7:00 PM</span>
        </div>
        <div class="footer-hours-item">
          <span class="day">Sunday</span>
          <span class="closed">Closed</span>
        </div>
      </div>

      <!-- Location -->
      <div class="footer-col">
        <h3 class="footer-col-title">Location</h3>
        <p class="footer-address">
          📍 {{ section.settings.address }}
        </p>
        <a href="https://maps.google.com/?q=Revive+Auto+Detailing+Karachi" 
           target="_blank" rel="noopener" class="footer-map-link">
          View on Google Maps →
        </a>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <div class="footer-bottom-links">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone (tel link)",
      "default": "+923037231111"
    },
    {
      "type": "text",
      "id": "phone_display",
      "label": "Phone Display",
      "default": "+92 303 7231111"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@reviveautodetailing.pk"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "A-65, Main Shahrah-e-Qaideen, Central Jacob Lines Block 1, Khudadad Colony, Karachi, Sindh 74800"
    },
    {
      "type": "header",
      "content": "Business Hours"
    },
    {
      "type": "text",
      "id": "hours_weekdays",
      "label": "Weekdays Hours",
      "default": "9:00 AM – 7:00 PM"
    },
    {
      "type": "text",
      "id": "hours_sunday",
      "label": "Sunday",
      "default": "Closed"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright Text",
      "default": "© 2025 Revive Auto Detailing. All rights reserved."
    }
  ]
}
{% endschema %}