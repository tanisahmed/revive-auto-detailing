<style>
.radf {
  background: #111827;
  font-family: 'Nunito Sans', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* Blue top line */
.radf-topline {
  height: 3px;
  background: linear-gradient(90deg, transparent, #1e3a8a, #3b82f6, #1e3a8a, transparent);
}

/* Main grid */
.radf-grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3.5rem 1.5rem 3rem;
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
  gap: 3rem;
}

/* ── Brand ── */
.radf-brand-logo { margin-bottom: 1.25rem; }
.radf-logo-img { height: 72px; width: auto; display: block; }

.radf-brand-desc {
  font-size: 0.9rem;
  color: #9ca3af;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  max-width: 260px;
}

.radf-wa-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: #10b981;
  color: #ffffff;
  padding: 0.7rem 1.25rem;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 700;
  text-decoration: none;
  transition: background 0.2s;
  margin-bottom: 1.25rem;
}
.radf-wa-btn:hover { background: #059669; }

.radf-social { display: flex; gap: 0.6rem; }
.radf-social a {
  width: 2rem; height: 2rem;
  border-radius: 6px;
  border: 1px solid #374151;
  display: flex; align-items: center; justify-content: center;
  color: #9ca3af;
  text-decoration: none;
  transition: all 0.2s;
  font-size: 0.85rem;
}
.radf-social a:hover { border-color: #3b82f6; color: #3b82f6; }

/* ── Column title ── */
.radf-col-title {
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #ffffff;
  margin-bottom: 1.25rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid #1f2937;
}

/* ── Service links ── */
.radf-links {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.radf-links a {
  font-size: 0.9rem;
  color: #9ca3af;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: color 0.2s;
}
.radf-links a:hover { color: #e5e7eb; }
.radf-links a::before {
  content: '→';
  font-size: 0.75rem;
  color: #374151;
}

/* ── Contact ── */
.radf-contact-items { display: flex; flex-direction: column; gap: 1rem; }
.radf-contact-item { display: flex; gap: 0.75rem; align-items: flex-start; }
.radf-contact-icon {
  width: 2rem; height: 2rem;
  border-radius: 6px;
  background: #1f2937;
  border: 1px solid #374151;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem;
  flex-shrink: 0;
}
.radf-contact-label {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #6b7280;
  margin-bottom: 0.2rem;
}
.radf-contact-value {
  font-size: 0.875rem;
  color: #d1d5db;
  line-height: 1.5;
}
.radf-contact-value a {
  color: #d1d5db;
  text-decoration: none;
  transition: color 0.2s;
}
.radf-contact-value a:hover { color: #ffffff; }

.radf-directions {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.8rem;
  color: #3b82f6;
  font-weight: 600;
  text-decoration: none;
  margin-top: 0.5rem;
  transition: color 0.2s;
}
.radf-directions:hover { color: #60a5fa; }

/* ── Hours ── */
.radf-hours { display: flex; flex-direction: column; }
.radf-hour-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.6rem 0;
  border-bottom: 1px solid #1f2937;
  font-size: 0.875rem;
}
.radf-hour-row:last-child { border-bottom: none; }
.radf-hour-day { color: #9ca3af; font-weight: 600; }
.radf-hour-open { color: #34d399; font-weight: 700; }
.radf-hour-closed { color: #f87171; font-weight: 700; }

.radf-sole-box {
  margin-top: 1.5rem;
  background: #1f2937;
  border: 1px solid #374151;
  border-radius: 10px;
  padding: 1.1rem 1.25rem 1.25rem;
}
.radf-sole-title {
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #6b7280;
  margin-bottom: 0.85rem;
}
.radf-nar-logo {
  height: 44px;
  width: auto;
  display: block;
  filter: invert(1);
  opacity: 0.85;
}

/* ── Divider ── */
.radf-hr {
  border: none;
  border-top: 1px solid #1f2937;
  margin: 0;
}

/* ── Bottom bar ── */
.radf-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.radf-copy { font-size: 0.8rem; color: #6b7280; }
.radf-policy-links { display: flex; gap: 1.5rem; }
.radf-policy-links a {
  font-size: 0.8rem;
  color: #6b7280;
  text-decoration: none;
  transition: color 0.2s;
}
.radf-policy-links a:hover { color: #9ca3af; }
.radf-made { font-size: 0.75rem; color: #374151; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .radf-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
}
@media (max-width: 600px) {
  .radf-grid { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 1.25rem 2rem; }
  .radf-bottom { flex-direction: column; text-align: center; }
  .radf-policy-links { justify-content: center; flex-wrap: wrap; gap: 1rem; }
  .radf-brand-desc { max-width: 100%; }
}
</style>

