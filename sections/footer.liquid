<style>
/* ══════════════════════════════
   RAD — Premium Footer
   ══════════════════════════════ */
.rad-footer {
  background: #080c14;
  color: #94a3b8;
  font-family: 'Nunito Sans', sans-serif;
  position: relative;
  overflow: hidden;
}

/* Top glow accent */
.rad-footer::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #1e3a8a 30%, #3b82f6 50%, #1e3a8a 70%, transparent 100%);
}

/* ── Top Strip ── */
.rad-footer-top {
  background: #0d1320;
  padding: 1.25rem 0;
  border-bottom: 1px solid rgba(30,58,138,0.3);
}
.rad-footer-top-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
}
.rad-footer-tagline {
  font-size: 0.82rem; font-weight: 600; color: #475569;
  letter-spacing: 0.06em; text-transform: uppercase;
}
.rad-footer-tagline span { color: #3b82f6; }
.rad-footer-social { display: flex; gap: 0.75rem; }
.rad-footer-social a {
  width: 2rem; height: 2rem; border-radius: 6px;
  border: 1px solid rgba(30,58,138,0.4);
  display: flex; align-items: center; justify-content: center;
  color: #475569; font-size: 0.875rem; text-decoration: none;
  transition: all 0.2s;
}
.rad-footer-social a:hover { border-color: #3b82f6; color: #3b82f6; background: rgba(59,130,246,0.08); }

/* ── Main Grid ── */
.rad-footer-main {
  max-width: 1200px; margin: 0 auto; padding: 3.5rem 2rem;
  display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
  gap: 3rem;
}

/* Brand column */
.rad-footer-brand-name {
  font-size: 1.3rem; font-weight: 900; color: #fff;
  letter-spacing: 0.02em; margin-bottom: 0.35rem;
}
.rad-footer-brand-name span { color: #3b82f6; }
.rad-footer-brand-sub {
  font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.12em; color: #334155; margin-bottom: 1.25rem;
}
.rad-footer-brand-desc {
  font-size: 0.85rem; line-height: 1.7; color: #475569; margin-bottom: 1.5rem;
  max-width: 260px;
}
.rad-footer-wa-btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3);
  color: #10b981; padding: 0.6rem 1.1rem; border-radius: 8px;
  font-size: 0.82rem; font-weight: 700; text-decoration: none; transition: all 0.2s;
}
.rad-footer-wa-btn:hover { background: rgba(16,185,129,0.2); border-color: #10b981; }

/* Column headers */
.rad-footer-col-title {
  font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.12em; color: #fff; margin-bottom: 1.25rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid rgba(30,58,138,0.4);
}

/* Services links */
.rad-footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
.rad-footer-links li a {
  font-size: 0.85rem; color: #475569; text-decoration: none;
  display: flex; align-items: center; gap: 0.4rem; transition: all 0.2s;
}
.rad-footer-links li a::before { content: '›'; color: #1e3a8a; font-weight: 700; }
.rad-footer-links li a:hover { color: #94a3b8; padding-left: 4px; }

/* Contact info */
.rad-footer-contact { display: flex; flex-direction: column; gap: 0.85rem; }
.rad-footer-contact-item { display: flex; align-items: flex-start; gap: 0.7rem; }
.rad-footer-contact-icon {
  width: 1.75rem; height: 1.75rem; border-radius: 6px;
  background: rgba(30,58,138,0.2); border: 1px solid rgba(30,58,138,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.8rem; flex-shrink: 0; margin-top: 1px;
}
.rad-footer-contact-text { font-size: 0.82rem; line-height: 1.55; }
.rad-footer-contact-text a { color: #475569; text-decoration: none; transition: color 0.2s; }
.rad-footer-contact-text a:hover { color: #94a3b8; }
.rad-footer-contact-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #334155; margin-bottom: 0.1rem; }

/* Hours */
.rad-footer-hours { display: flex; flex-direction: column; gap: 0; }
.rad-footer-hour-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.45rem 0; border-bottom: 1px solid rgba(30,58,138,0.15);
  font-size: 0.8rem;
}
.rad-footer-hour-row:last-child { border-bottom: none; }
.rad-footer-hour-day { color: #334155; font-weight: 600; }
.rad-footer-hour-time { color: #64748b; font-weight: 500; }
.rad-footer-hour-time.open { color: #22c55e; }
.rad-footer-hour-time.closed { color: #ef4444; }

/* ── Divider ── */
.rad-footer-divider {
  max-width: 1200px; margin: 0 auto;
  height: 1px; background: linear-gradient(90deg, transparent, rgba(30,58,138,0.4), transparent);
}

/* ── Bottom Bar ── */
.rad-footer-bottom {
  max-width: 1200px; margin: 0 auto; padding: 1.25rem 2rem;
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; flex-wrap: wrap;
}
.rad-footer-copy { font-size: 0.78rem; color: #1e293b; }
.rad-footer-copy span { color: #334155; }
.rad-footer-bottom-links { display: flex; gap: 1.5rem; }
.rad-footer-bottom-links a { font-size: 0.78rem; color: #1e293b; text-decoration: none; transition: color 0.2s; }
.rad-footer-bottom-links a:hover { color: #475569; }
.rad-footer-made { font-size: 0.72rem; color: #1e293b; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .rad-footer-main { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
}
@media (max-width: 640px) {
  .rad-footer-main { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 1.25rem; }
  .rad-footer-top-inner { justify-content: center; text-align: center; }
  .rad-footer-bottom { justify-content: center; text-align: center; flex-direction: column; padding: 1.25rem; }
  .rad-footer-bottom-links { justify-content: center; }
  .rad-footer-brand-desc { max-width: 100%; }
}
</style>

