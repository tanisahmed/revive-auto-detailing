<style>
.rad-mwt { padding: 2rem 0; background: #fff; }
.rad-mwt.bg-gray { background: #f3f4f6; }
.rad-mwt-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}
.rad-mwt-grid.reverse { direction: rtl; }
.rad-mwt-grid.reverse > * { direction: ltr; }
.rad-mwt-img {
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 4/3;
  background: #e5e7eb;
}
.rad-mwt-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-mwt-img-placeholder {
  width: 100%; height: 100%; min-height: 300px;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #1e3a8a, #1e40af);
  font-size: 5rem;
}
.rad-mwt-tag {
  display: inline-block;
  background: rgba(30,58,138,0.1);
  color: #1e3a8a;
  padding: 0.3rem 0.85rem;
  border-radius: 100px;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.rad-mwt-title {
  font-size: 2rem;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.2;
  margin-bottom: 1rem;
  font-family: 'Nunito Sans', sans-serif;
}
.rad-mwt-text {
  font-size: 1rem;
  color: #6b7280;
  line-height: 1.8;
  margin-bottom: 1.5rem;
}
.rad-mwt-list { margin-bottom: 1.75rem; display: flex; flex-direction: column; gap: 0.6rem; }
.rad-mwt-list-item {
  display: flex; align-items: flex-start; gap: 0.6rem;
  font-size: 0.95rem; color: #1f2937; font-weight: 600;
}
.rad-mwt-list-item::before {
  content: '✓';
  color: #10b981;
  font-weight: 800;
  flex-shrink: 0;
  margin-top: 1px;
}
.rad-mwt-btn {
  display: inline-flex; align-items: center;
  padding: 0.875rem 1.75rem;
  background: #1e3a8a; color: #fff;
  border-radius: 8px; font-weight: 700;
  font-size: 1rem; text-decoration: none;
  transition: all 0.2s;
}
.rad-mwt-btn:hover { background: #1e40af; transform: translateY(-1px); }
.rad-mwt-btn.outline {
  background: transparent; color: #1e3a8a;
  border: 2px solid #1e3a8a;
}
.rad-mwt-btn.outline:hover { background: #1e3a8a; color: #fff; }
@media (max-width: 768px) {
  .rad-mwt-grid { grid-template-columns: 1fr; direction: ltr; }
  .rad-mwt-title { font-size: 1.5rem; }
}
</style>

<section class="rad-mwt {% if section.settings.bg_gray %}bg-gray{% endif %}">
  <div class="container">
    <div class="rad-mwt-grid {% if section.settings.reverse %}reverse{% endif %}">

      <!-- Image -->
      <div class="rad-mwt-img">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}"
               alt="{{ section.settings.title }}" loading="lazy">
        {%- else -%}
          <div class="rad-mwt-img-placeholder">🚗</div>
        {%- endif -%}
      </div>

      <!-- Content -->
      <div class="rad-mwt-content">
        {%- if section.settings.tag != blank -%}
          <span class="rad-mwt-tag">{{ section.settings.tag }}</span>
        {%- endif -%}
        <h2 class="rad-mwt-title">{{ section.settings.title }}</h2>
        <p class="rad-mwt-text">{{ section.settings.text }}</p>

        {%- assign points = section.settings.bullet_points | split: ',' -%}
        {%- if points.size > 0 and section.settings.bullet_points != blank -%}
          <ul class="rad-mwt-list">
            {%- for point in points -%}
              <li class="rad-mwt-list-item">{{ point | strip }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.btn_text != blank -%}
          <a href="{{ section.settings.btn_url }}"
             class="rad-mwt-btn {% if section.settings.btn_outline %}outline{% endif %}">
            {{ section.settings.btn_text }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image With Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag (small text)",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Our PPF is the Best in Karachi"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "We use only premium NAR certified PPF film that offers unmatched protection and clarity."
    },
    {
      "type": "textarea",
      "id": "bullet_points",
      "label": "Bullet Points (comma separated)",
      "default": "Self-healing technology,UV protection,10 year warranty,Invisible finish"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "btn_outline",
      "label": "Outline Button?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "Reverse Layout?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "bg_gray",
      "label": "Gray Background?",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Image With Text"
    }
  ]
}
{% endschema %}