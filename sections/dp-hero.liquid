    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "WhatsApp Us"
    }
  ],
  "presets": [
    {
      "name": "Denting Painting Hero"
    }
  ]
}
{% endschema %}