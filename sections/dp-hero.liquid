<style>
  .rad-dp-hero {
    background: var(--color-black, #0a0a0a);
    color: #fff;
    padding: 4.5rem 0;
    position: relative;
    overflow: hidden;
  }
  .rad-dp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 65% 50%, rgba(30,58,138,0.35) 0%, transparent 70%);
  }
  .rad-dp-hero-media { position: absolute; inset: 0; z-index: 0; }
  .rad-dp-hero-media img,
  .rad-dp-hero-media video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .rad-dp-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.4) 100%); z-index: 1; }
  .rad-dp-hero-inner {
    position: relative; z-index: 2;
    max-width: 760px;
    text-align: left;
  }
  .rad-dp-hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(30,58,138,0.4);
    border: 1px solid rgba(96,165,250,0.3);
    padding: 0.3rem 1rem; border-radius: 100px;
    font-size: 0.8rem; font-weight: 700; color: #93c5fd;
    margin-bottom: 1rem; letter-spacing: 0.05em; text-transform: uppercase;
  }
  .rad-dp-hero h1 { font-size: 3rem; font-weight: 800; line-height: 1.1; margin-bottom: 0.5rem; letter-spacing: -1px; }
  .rad-dp-hero-sub { font-size: 1.35rem; font-weight: 700; color: #60a5fa; margin-bottom: 1rem; }
  .rad-dp-hero-desc { font-size: 1.05rem; color: #d1d5db; line-height: 1.7; margin-bottom: 2rem; max-width: 480px; }
  .rad-dp-hero-features { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .rad-dp-hero-feature { display: flex; align-items: center; gap: 0.35rem; background: rgba(255,255,255,0.08); padding: 0.35rem 0.85rem; border-radius: 100px; font-size: 0.875rem; font-weight: 600; }
  .rad-dp-btn-primary { display:inline-flex; align-items:center; padding: 0.875rem 1.75rem; background:#1e3a8a; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
  .rad-dp-btn-primary:hover { background:#1e40af; }
  .rad-dp-btn-wa { display:inline-flex; align-items:center; gap:0.4rem; padding: 0.875rem 1.75rem; background:#10b981; color:#fff; border-radius:8px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.2s; }
  .rad-dp-btn-wa:hover { background:#059669; }
  @media (max-width: 640px) {
    .rad-dp-hero { padding: 2.25rem 0; }
    .rad-dp-hero-inner { padding: 0 1rem; }
    .rad-dp-hero h1 { font-size: 1.6rem; line-height: 1.25; margin-bottom: 0.4rem; }
    .rad-dp-hero-sub { font-size: 0.95rem; margin-bottom: 0.5rem; }
    .rad-dp-hero-desc { font-size: 0.88rem; margin-bottom: 1.25rem; }
    .rad-dp-hero-badge { font-size: 0.65rem; padding: 0.25rem 0.75rem; }
    .rad-dp-hero-features { gap: 0.4rem; margin-bottom: 1.25rem; }
    .rad-dp-hero-feature { font-size: 0.7rem; padding: 0.3rem 0.6rem; }
    .rad-dp-hero-btns { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; }
    .rad-dp-btn-primary, .rad-dp-btn-wa { flex:1;  text-align:center; padding:0.65rem 0.5rem; font-size:0.78rem; white-space:nowrap; }
  }
</style>

<div class="rad-dp-hero">

  {%- if section.settings.bg_video != blank -%}
    <div class="rad-dp-hero-media">
      <video src="{{ section.settings.bg_video.sources.last.url }}" autoplay muted loop playsinline></video>
    </div>
    <div class="rad-dp-hero-overlay"></div>
  {%- elsif section.settings.bg_image != blank -%}
    <div class="rad-dp-hero-media">
      <img src="{{ section.settings.bg_image | image_url: width: 1800 }}" alt="Denting Painting Background" loading="eager">
    </div>
    <div class="rad-dp-hero-overlay"></div>
  {%- endif -%}

  <div class="container">
    <div class="rad-dp-hero-inner">
      <div class="rad-dp-hero-badge">{{ section.settings.badge | default: "Denting & Painting Services • Karachi" }}</div>
      <h1>{{ section.settings.hero_title | default: "Professional" }} <span style="color:#60a5fa;">{{ section.settings.hero_highlight | default: "Denting & Painting" }}</span> {{ section.settings.hero_end | default: "in Karachi" }}</h1>
      <p class="rad-dp-hero-sub">{{ section.settings.hero_sub | default: "Expert Body Repair & Repainting" }}</p>
      <p class="rad-dp-hero-desc">{{ section.settings.hero_desc | default: "Expert dent removal, scratch repair, and panel repainting in Karachi using computerized OEM color matching." }}</p>
      <div class="rad-dp-hero-features">
        {%- if section.settings.feat1 != blank -%}<span class="rad-dp-hero-feature">{{ section.settings.feat1 }}</span>{%- endif -%}
        {%- if section.settings.feat2 != blank -%}<span class="rad-dp-hero-feature">{{ section.settings.feat2 }}</span>{%- endif -%}
        {%- if section.settings.feat3 != blank -%}<span class="rad-dp-hero-feature">{{ section.settings.feat3 }}</span>{%- endif -%}
        {%- if section.settings.feat4 != blank -%}<span class="rad-dp-hero-feature">{{ section.settings.feat4 }}</span>{%- endif -%}
      </div>
      <div class="rad-dp-hero-btns" style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="{{ section.settings.btn1_url | default: '/pages/book-appointment' }}" class="rad-dp-btn-primary">{{ section.settings.btn1_text | default: "View Pricing" }}</a>
        <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20denting%20and%20painting%20for%20my%20car" target="_blank" class="rad-dp-btn-wa">💬 {{ section.settings.btn2_text | default: "WhatsApp Us" }}</a>
      </div>
    </div>
  </div>

</div>

