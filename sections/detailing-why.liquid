<style>
.rad-det-why { padding: 2rem 0; background: #fff; }
.rad-det-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
/* ── Before/After Slider ── */
.rad-ba-wrap { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; position: relative; user-select: none; cursor: col-resize; background: #0f172a; }
.rad-ba-before, .rad-ba-after { position: absolute; inset: 0; }
.rad-ba-before img, .rad-ba-after img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rad-ba-after { clip-path: inset(0 50% 0 0); transition: clip-path 0s; }
/* Divider line */
.rad-ba-line { position: absolute; top: 0; bottom: 0; width: 2px; background: #fff; left: 50%; transform: translateX(-50%); pointer-events: none; z-index: 3; }
/* Handle */
.rad-ba-handle {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 2.75rem; height: 2.75rem;
  background: #fff; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  z-index: 4; pointer-events: none;
  box-shadow: 0 2px 12px rgba(0,0,0,0.3);
}
.rad-ba-handle svg { width: 1.1rem; height: 1.1rem; }
/* Labels */
.rad-ba-label-before, .rad-ba-label-after {
  position: absolute; bottom: 0.85rem;
  background: rgba(0,0,0,0.6); color: #fff;
  font-size: 0.7rem; font-weight: 800;
  padding: 0.2rem 0.6rem; border-radius: 4px;
  text-transform: uppercase; letter-spacing: 0.08em;
  z-index: 5; pointer-events: none;
}
.rad-ba-label-before { left: 0.75rem; }
.rad-ba-label-after  { right: 0.75rem; }
/* Placeholder when no images */
.rad-ba-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; color: #475569; font-size: 0.85rem; font-weight: 600; }
.rad-det-why-tag { display: inline-block; background: rgba(30,58,138,0.1); color: #1e3a8a; padding: 0.3rem 0.85rem; border-radius: 100px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.75rem; }
.rad-det-why-title { font-size: 1.85rem; font-weight: 800; color: #1f2937; line-height: 1.2; margin-bottom: 1.25rem; font-family: 'Nunito Sans', sans-serif; }
.rad-det-why-list { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 2rem; }
.rad-det-why-item { display: flex; align-items: flex-start; gap: 0.75rem; }
.rad-det-why-item-icon { width: 2rem; height: 2rem; background: rgba(30,58,138,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem; }
.rad-det-why-item-text h4 { font-size: 0.95rem; font-weight: 700; color: #1f2937; margin-bottom: 0.15rem; }
.rad-det-why-item-text p { font-size: 0.85rem; color: #6b7280; line-height: 1.5; }
.rad-det-why-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
.rad-det-why-btn { display: inline-flex; align-items: center; padding: 0.875rem 1.75rem; background: #1e3a8a; color: #fff; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-det-why-btn:hover { background: #1e40af; transform: translateY(-1px); }
.rad-det-why-btn-wa { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: transparent; color: #10b981; border: 2px solid #10b981; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: all 0.2s; }
.rad-det-why-btn-wa:hover { background: #10b981; color: #fff; }
@media (max-width: 768px) { .rad-det-why-grid { grid-template-columns: 1fr; } .rad-det-why-title { font-size: 1.5rem; } }
@media (max-width: 640px) {
  .rad-det-why-btns { flex-direction: row; flex-wrap: nowrap; gap: 0.5rem; }
  .rad-det-why-btn, .rad-det-why-btn-wa { flex: 1; width: auto; justify-content: center; text-align: center; padding: 0.65rem 0.5rem; font-size: 0.78rem; white-space: nowrap; }
}
</style>

<section class="rad-det-why">
  <div class="container">
    <div class="rad-det-why-grid">
      <div class="rad-ba-wrap" id="rad-ba-slider">
        <!-- Before image -->
        <div class="rad-ba-before">
          {%- if section.settings.img_before != blank -%}
            <img src="{{ section.settings.img_before | image_url: width: 900 }}" alt="Before Detailing" draggable="false">
          {%- else -%}
            <div class="rad-ba-placeholder">📷 Upload Before Image</div>
          {%- endif -%}
        </div>
        <!-- After image -->
        <div class="rad-ba-after" id="rad-ba-after">
          {%- if section.settings.img_after != blank -%}
            <img src="{{ section.settings.img_after | image_url: width: 900 }}" alt="After Detailing" draggable="false">
          {%- else -%}
            <div class="rad-ba-placeholder">📷 Upload After Image</div>
          {%- endif -%}
        </div>
        <!-- Divider -->
        <div class="rad-ba-line" id="rad-ba-line"></div>
        <div class="rad-ba-handle" id="rad-ba-handle">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1e3a8a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
            <polyline points="9 18 15 12 9 6" transform="translate(0,0)"></polyline>
          </svg>
        </div>
        <div class="rad-ba-label-before">Before</div>
        <div class="rad-ba-label-after">After</div>
      </div>

      <script>
      (function(){
        var wrap   = document.getElementById('rad-ba-slider');
        var after  = document.getElementById('rad-ba-after');
        var line   = document.getElementById('rad-ba-line');
        var handle = document.getElementById('rad-ba-handle');
        if(!wrap) return;

        var dragging = false;

        function setPos(x) {
          var rect = wrap.getBoundingClientRect();
          var pct  = Math.min(Math.max((x - rect.left) / rect.width * 100, 2), 98);
          after.style.clipPath  = 'inset(0 ' + (100 - pct) + '% 0 0)';
          line.style.left       = pct + '%';
          handle.style.left     = pct + '%';
        }

        // Mouse
        wrap.addEventListener('mousedown', function(e){ dragging = true; setPos(e.clientX); e.preventDefault(); });
        document.addEventListener('mousemove', function(e){ if(dragging) setPos(e.clientX); });
        document.addEventListener('mouseup',   function(){ dragging = false; });

        // Touch
        wrap.addEventListener('touchstart', function(e){ dragging = true; setPos(e.touches[0].clientX); }, {passive:true});
        wrap.addEventListener('touchmove',  function(e){ if(dragging) setPos(e.touches[0].clientX); }, {passive:true});
        wrap.addEventListener('touchend',   function(){ dragging = false; });
      })();
      </script>
      <div>
        <span class="rad-det-why-tag">{{ section.settings.tag }}</span>
        <h2 class="rad-det-why-title">{{ section.settings.title }}</h2>
        <div class="rad-det-why-list">
          <div class="rad-det-why-item">
            <div class="rad-det-why-item-icon">✨</div>
            <div class="rad-det-why-item-text">
              <h4>Restore Showroom Shine</h4>
              <p>Professional compounding and polishing removes swirl marks, scratches, and oxidation</p>
            </div>
          </div>
          <div class="rad-det-why-item">
            <div class="rad-det-why-item-icon">🪑</div>
            <div class="rad-det-why-item-text">
              <h4>Deep Interior Cleaning</h4>
              <p>Seats, carpets, dashboard — every corner professionally cleaned and dressed</p>
            </div>
          </div>
          <div class="rad-det-why-item">
            <div class="rad-det-why-item-icon">🛡️</div>
            <div class="rad-det-why-item-text">
              <h4>Paint Protection</h4>
              <p>Exterior protectant coating shields your paint from UV, dust, and environmental damage</p>
            </div>
          </div>
          <div class="rad-det-why-item">
            <div class="rad-det-why-item-icon">📈</div>
            <div class="rad-det-why-item-text">
              <h4>Increases Resale Value</h4>
              <p>A well-maintained car fetches significantly higher resale prices</p>
            </div>
          </div>
          <div class="rad-det-why-item">
            <div class="rad-det-why-item-icon">🏆</div>
            <div class="rad-det-why-item-text">
              <h4>Expert Technicians</h4>
              <p>800+ cars detailed in Karachi — certified professionals with premium products</p>
            </div>
          </div>
        </div>
        <div class="rad-det-why-btns">
          <a href="/pages/detailing-booking" class="rad-det-why-btn">Book Your Slot</a>
          <a href="https://wa.me/923037231111?text=Hi!%20I%20want%20car%20detailing%20for%20my%20vehicle" target="_blank" class="rad-det-why-btn-wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Get Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Detailing Why Section",
  "settings": [
    {"type":"header","content":"Before / After Images"},
    {"type":"image_picker","id":"img_before","label":"Before Image"},
    {"type":"image_picker","id":"img_after","label":"After Image"},
    {
      "type": "text",
      "id": "tag",
      "label": "Tag",
      "default": "Why Professional Detailing?"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "Make Your Car Look Brand New — Inside & Outside!"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Book Your Slot"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 Link"
    }
  ],
  "presets": [
    {
      "name": "Detailing Why Section"
    }
  ]
}
{% endschema %}